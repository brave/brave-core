# NOTE: brave_speech_recognition_engine must be compiled
# within the content library because it depends on
# content/browser/speech/speech_recognition_engine.h
# which is content-internal (not in content/public/).
brave_content_browser_sources = [
  "//brave/content/browser/devtools/adblock_devtools_instrumentation.cc",
  "//brave/content/browser/speech/brave_speech_recognition_engine.cc",
  "//brave/content/browser/speech/brave_speech_recognition_engine.h",
]

if (is_android) {
  brave_content_browser_sources += [
    "//brave/content/browser/screen_orientation/brave_screen_orientation_delegate_android.cc",
    "//brave/content/browser/screen_orientation/brave_screen_orientation_delegate_android.h",
  ]
}

brave_content_browser_deps = [
  "//brave/components/ai_chat/core/common/buildflags",
  "//brave/components/brave_service_keys",
  "//brave/components/brave_shields/core/common:mojom",
  "//brave/components/brave_wallet/common/buildflags",
  "//brave/components/local_ai/core:features",
  "//brave/components/local_ai/core:mojom",
  "//brave/components/speech_to_text",
]
