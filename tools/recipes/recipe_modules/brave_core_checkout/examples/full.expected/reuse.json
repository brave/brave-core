[
  {
    "cmd": [
      "git",
      "-C",
      "[WORKSPACE]/brave-browser/src/brave",
      "fetch",
      "--depth",
      "2",
      "origin",
      "master"
    ],
    "name": "fetch brave-core ref"
  },
  {
    "cmd": [
      "git",
      "-C",
      "[WORKSPACE]/brave-browser/src/brave",
      "checkout",
      "--force",
      "FETCH_HEAD"
    ],
    "name": "checkout brave-core ref"
  },
  {
    "cmd": [
      "git",
      "-C",
      "[WORKSPACE]/brave-browser/src/brave",
      "sparse-checkout",
      "list"
    ],
    "name": "sparse-checkout list"
  },
  {
    "cmd": [
      "git",
      "-C",
      "[WORKSPACE]/brave-browser/src/brave",
      "sparse-checkout",
      "add",
      "tools/cr/bootstrap"
    ],
    "name": "sparse-checkout add"
  },
  {
    "cmd": [
      "npm",
      "--version"
    ],
    "env_prefixes": {
      "PATH": [
        "[WORKSPACE]/brave-browser/src/brave/tools/cr/bootstrap"
      ]
    },
    "name": "npm version"
  },
  {
    "name": "$result"
  }
]
