[
  {
    "cmd": [
      "git",
      "clone",
      "--depth",
      "1",
      "https://chromium.googlesource.com/chromium/tools/depot_tools",
      "[WORKSPACE]/brave-browser/src/third_party/depot_tools"
    ],
    "name": "clone depot_tools"
  },
  {
    "cmd": [
      "gclient"
    ],
    "name": "verify gclient"
  },
  {
    "cmd": [
      "git",
      "log",
      "-1",
      "--oneline",
      "chrome/VERSION"
    ],
    "cwd": "[WORKSPACE]/brave-browser/src",
    "name": "check chrome/VERSION"
  },
  {
    "cmd": [
      "git",
      "fetch",
      "origin",
      "main"
    ],
    "cwd": "[WORKSPACE]/brave-browser/src",
    "name": "fetch ref"
  },
  {
    "cmd": [
      "git",
      "checkout",
      "--force",
      "FETCH_HEAD"
    ],
    "cwd": "[WORKSPACE]/brave-browser/src",
    "name": "checkout FETCH_HEAD"
  },
  {
    "cmd": [
      "gclient",
      "sync",
      "--force",
      "-D"
    ],
    "cwd": "[WORKSPACE]/brave-browser/src",
    "name": "gclient sync"
  },
  {
    "cmd": [
      "echo",
      "https://vhemnu34de4lf5cj6bx2wwshyy0egdxk.lambda-url.us-west-2.on.aws/windows-hermetic-toolchain/"
    ],
    "name": "win toolchain env"
  },
  {
    "name": "$result"
  }
]
