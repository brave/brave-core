[
  {
    "cmd": [
      "git",
      "clone",
      "--depth",
      "2",
      "--filter=blob:none",
      "--sparse",
      "--branch",
      "master",
      "git@github.com:brave/brave-core.git",
      "[WORKSPACE]/brave-browser/src/brave"
    ],
    "name": "clone brave-core (shallow, sparse)"
  },
  {
    "cmd": [
      "git",
      "-C",
      "[WORKSPACE]/brave-browser/src/brave",
      "sparse-checkout",
      "list"
    ],
    "name": "sparse-checkout list"
  },
  {
    "cmd": [
      "git",
      "-C",
      "[WORKSPACE]/brave-browser/src/brave",
      "sparse-checkout",
      "add",
      "tools/cr/toolchains"
    ],
    "name": "sparse-checkout add"
  },
  {
    "cmd": [
      "git",
      "clone",
      "--depth",
      "1",
      "https://chromium.googlesource.com/chromium/tools/depot_tools",
      "[WORKSPACE]/brave-browser/src/third_party/depot_tools"
    ],
    "name": "clone depot_tools"
  },
  {
    "cmd": [
      "gclient"
    ],
    "name": "verify gclient"
  },
  {
    "cmd": [
      "[WORKSPACE]/brave-browser/src/third_party/depot_tools/vpython3",
      "[WORKSPACE]/brave-browser/src/brave/tools/cr/toolchains/build_xcode_toolchain.py",
      "--out-dir",
      "[WORKSPACE]/out",
      "--chromium-tag",
      "150.0.7841.1",
      "--clear"
    ],
    "name": "build xcode toolchain"
  },
  {
    "name": "$result"
  }
]
