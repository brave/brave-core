[
  {
    "cmd": [
      "git",
      "-C",
      "[WORKSPACE]/brave-browser/src/brave",
      "fetch",
      "--depth",
      "2",
      "origin",
      "master"
    ],
    "name": "fetch brave-core ref"
  },
  {
    "cmd": [
      "git",
      "-C",
      "[WORKSPACE]/brave-browser/src/brave",
      "checkout",
      "--force",
      "FETCH_HEAD"
    ],
    "name": "checkout brave-core ref"
  },
  {
    "cmd": [
      "git",
      "-C",
      "[WORKSPACE]/brave-browser/src/brave",
      "sparse-checkout",
      "list"
    ],
    "name": "sparse-checkout list"
  },
  {
    "cmd": [
      "git",
      "-C",
      "[WORKSPACE]/brave-browser/src/brave",
      "sparse-checkout",
      "add",
      "third_party/node"
    ],
    "name": "sparse-checkout add"
  },
  {
    "cmd": [
      "git",
      "clone",
      "--depth",
      "1",
      "https://chromium.googlesource.com/chromium/tools/depot_tools",
      "[WORKSPACE]/brave-browser/src/third_party/depot_tools"
    ],
    "name": "clone depot_tools"
  },
  {
    "cmd": [
      "gclient"
    ],
    "name": "verify gclient"
  },
  {
    "cmd": [
      "[WORKSPACE]/brave-browser/src/third_party/depot_tools/vpython3",
      "[WORKSPACE]/brave-browser/src/brave/third_party/node/download_node.py",
      "--clear"
    ],
    "name": "download node"
  },
  {
    "cmd": [
      "[WORKSPACE]/brave-browser/src/third_party/depot_tools/vpython3",
      "[WORKSPACE]/brave-browser/src/brave/third_party/node/package_node.py",
      "--output-dir",
      "[WORKSPACE]/out"
    ],
    "name": "package node"
  },
  {
    "name": "$result"
  }
]
