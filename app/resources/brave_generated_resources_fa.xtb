<translation id="6374563306438145841">کلید API</translation>
<translation id="3295756655687327124">پشتیبانی از بینایی</translation>
<translation id="1415432774589088566">اینکه این مدل بتواند تصویر را به‌عنوان ورودی دریافت کند، مثلاً بینایی llama 3.2b</translation>
<translation id="8008271349880309090">نام مدل همانطور که در منوی انتخاب مدل ظاهر می‌شود</translation>
<translation id="1355326130503900056">نام مدل آنگونه که باید در درخواست چارچوب سرویس‌دهی نشان داده شود، یعنی phi-3 (توجه داشته باشید که اگر این نام دقیقاً با آنچه در چارچوب سرویس‌دهی انتظار می‌رود مطابقت نداشته باشد، ادغام کار نخواهد کرد)</translation>
<translation id="3213787232304349732">آدرس URLای که چارچوب سرویس‌دهنده شما در آن منتظر دریافت درخواست‌هاست. اگر مطمئن نیستید، مستندات چارچوب سرویس‌دهنده را بررسی کنید. برای مثال، برای Ollama، این آدرس همیشه http://localhost:11434/v1/chat/completions است</translation>
<translation id="1058790648388035953">برخی از چارچوب‌های سرویس‌دهی ممکن است به اعتبارنامه‌های احراز هویت، مانند یک کلید API یا یک توکن دسترسی نیاز داشته باشند. این موارد به سرصفحه درخواست اضافه خواهند شد.</translation>
<translation id="4335128003329183586">اندازه زمینه</translation>
<translation id="3153779001670804829">حداکثر تعداد توکن‌هایی که مدل می‌تواند در یک تعامل واحد پردازش کند. اندازه بزرگ‌تر زمینه به مدل امکان می‌دهد گفت‌وگوهای طولانی‌تری را مدیریت کند. مدل‌های مختلف از اندازه‌های متفاوت حداکثر زمینه پشتیبانی می‌کنند.</translation>
<translation id="217141195370578385">Brave این درخواست‌ها را پراکسی نمی‌کند، لطفاً شرایط حریم خصوصی ارائه‌دهنده انتخابی را بخوانید.</translation>
<translation id="2645532768679870478">نقاط پایان غیرمحلی باید پروتکل HTTPS را برای ایمن‌سازی انتقال داده‌ها پیاده‌سازی کنند.</translation>
<translation id="8177205483022887785">نشانی وب نامعتبری وارد کرده‌اید. لطفاً نشانی وب معتبری وارد کنید.</translation>
<translation id="6333402912272476257">این نقطه پایان به‌طور بالقوه ناامن است.</translation>
<translation id="4025470490371933693">آدرس‌های IP خصوصی مجاز نیستند</translation>
<translation id="3670571614478401810">آدرسی که وارد کرده‌اید به نظر می‌رسد از یک شبکه خصوصی است - مانند روتر یا سرور محلی شما. مرورگر Brave به‌طور خودکار این آدرس‌ها را برای حفظ امنیت شما مسدود می‌کند، اما اگر اطمینان دارید که امن است، می‌توانید آن‌ها را فعال کنید.</translation>
<translation id="4932437543207655965">برای ادامه، به آدرس brave://flags/ بروید، عبارت «brave-ai-chat-allow-private-ips» را جستجو کنید و این ویژگی را فعال کنید. پس از فعال‌سازی، می‌توانید از آدرس‌های شبکه خصوصی در تنظیمات Leo استفاده کنید.</translation>
<translation id="5249539665306267943">افزودن مدل جدید</translation>
<translation id="7265212806651512211">هنوز مدلی متصل نکرده‌اید.</translation>
<translation id="7304802428852949897">مدل‌های شما</translation>
<translation id="7435587476558117990">LLM خودمیزبان یا میزبان شخص ثالث خود را به Leo متصل کنید و از آن‌ها در مرورگر استفاده کنید.</translation>
<translation id="8137606697798069075">از هر چارچوب سازگار با پروتکل چت OpenAI مانند Ollama استفاده می‌کند. <ph name="BEGIN_LINK"/>اطلاعات بیشتر<ph name="END_LINK"/></translation>
<translation id="2642905648178380593">ذخیره کردن مدل</translation>
<translation id="6304169450064541679">پرامپت سیستم</translation>
<translation id="3081947790648024460">دستورالعمل‌ها و/یا زمینه‌های سفارشی که به مدل داده می‌شود تا پاسخ‌ها را در جهت یا سبک خاصی هدایت کند. وقتی می‌خواهید تاریخ و زمان فعلی درج شود، از %‎%datetime استفاده کنید.</translation>
<translation id="5688878061573389791"><ph name="TOKENS_COUNT"/>≈ توکن</translation>
<translation id="6911466383346197271">Leo را سفارشی‌سازی کنید</translation>
<translation id="5702085383070170010">درباره شما</translation>
<translation id="2493241731563937877">درباره خودتان به Leo بگویید تا پاسخ‌های شخصی‌سازی‌شده‌تری دریافت کنید. <ph name="BEGIN_LINK"/>بیشتر بدانید<ph name="END_LINK"/></translation>
<translation id="8536280915366791221">سفارشی‌سازی Leo را فعال کنید</translation>
<translation id="698972836993887081">حافظه کاربر را فعال کنید</translation>
