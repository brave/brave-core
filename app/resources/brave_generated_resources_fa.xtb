<translation id="2187778349654214731">برای شروع، باید در همه دستگاه‌هایی که قصد همگام‌سازی‌شان را دارید، Brave را نصب کنید، سپس با کد همگام‌سازی آنها را به‌صورت امن به هم پیوند دهید.</translation>
<translation id="7530575064080939974">مدیریت دستگاه‌های همگام‌سازی‌شده خود</translation>
<translation id="8668872235103666008">امکان همگام‌سازی Brave با دستگاه‌های شما وجود ندارد</translation>
<translation id="7575156386943878014">مدیر همگام‌سازی</translation>
<translation id="1755198127524719638">تنظیمات همگام‌سازی</translation>
<translation id="7558480201297099157">اطلاعاتی را که می‌خواهید بین دستگاه‌ها همگام‌سازی شود مدیریت کنید. این تنظیمات فقط در این دستگاه اعمال می‌شوند.</translation>
<translation id="7731928563672901833">فهرست دستگاه‌ها</translation>
<translation id="28332161031213248">فهرست دستگاه زیر حاوی همه دستگاه‌های موجود در زنجیره همگام‌سازی شما است. هر دستگاه می‌تواند از دستگاه دیگری مدیریت شود.</translation>
<translation id="1313162974556054106">نام دستگاه</translation>
