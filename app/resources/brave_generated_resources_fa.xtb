<translation id="1362393385416256849">نام دلخواهتان را وارد کنید تا Leo شما را با آن صدا بزند</translation>
<translation id="7841672648317556034">شغلتان چیست؟</translation>
<translation id="1228535384519357095">کمی درباره شغلتان به Leo بگویید</translation>
<translation id="1300619108689988155">Leo چگونه باید به سؤال‌هایتان پاسخ دهد؟</translation>
<translation id="5071940952740278148">لحن و ویژگی‌هایی را که می‌خواهید Leo هنگام پاسخ‌دادن به‌کار ببرد، توضیح دهید</translation>
<translation id="5647284470247510206">چیز دیگری هست که Leo باید درباره شما بداند؟</translation>
<translation id="7228073810237286235">هر ترجیحات دیگری که می‌خواهید Leo هنگام پاسخ‌دادن لحاظ کند، به او اطلاع دهید</translation>
<translation id="683188035663069399">تغییرات ذخیره شد</translation>
