<translation id="6129027151000961048">Leo</translation>
<translation id="2751872555001636931">نمایش آیکون Leo در نوار کناری</translation>
<translation id="8055509865174199683">نمایش Leo در منوی زمینه در وب‌سایت‌ها</translation>
<translation id="1529674267267221673">وقتی روی یک وب‌سایت کلیک راست می‌کنید، Leo در منوی زمینه ظاهر می‌شود. بدین ترتیب زمینه از صفحه وب فعلی به Leo ارسال می‌شود.</translation>
<translation id="5226020406479918122">حالت برگه متمرکز</translation>
<translation id="3705539672403311123">سازماندهی برگه‌ها را در صفحه «جستجوی برگه» فعال می‌کند. زمانی که این ویژگی باز شود، عناوین و مبدأ همه برگه‌های غیرخصوصی را به‌طور خودکار برای طبقه‌بندی به Leo ارسال می‌کند. <ph name="BEGIN_LINK"/>اطلاعات بیشتر<ph name="END_LINK"/></translation>
<translation id="9049433973274198706">مدل پیش‌فرض برای تمرکز تب</translation>
<translation id="8172263161008556851">نمایش دستورهای پیشنهادی در گفتگو</translation>
<translation id="5781842473834867765">سابقه گفتگوهایم را ذخیره کن</translation>
<translation id="1082960401708055995">غیرفعال کردن ذخیره‌سازی گفتگوها، تمام گفتگوهای ذخیره‌شده قبلی را برای همیشه پاک خواهد کرد. این اقدام بازگشت‌ناپذیر است.</translation>
<translation id="1014480593522400586">حذف داده‌های Leo</translation>
<translation id="5256236967791936135">بعد از بازنشانی هوش مصنوعی Leo، برای استفاده دوباره از Brave Leo AI در آینده دوباره باید وارد شوید و همچنین همه سوابق گفتگو، سفارشی‌سازی‌ها و حافظه‌های شما پاک می‌شود. پاک کردن سوابق گفتگو، تمام مکالمات قبلی شما با Brave Leo AI را حذف خواهد کرد. این اقدام بازگشت‌ناپذیر است.</translation>
<translation id="5574059574002819179">پیشنهادهای تکمیل خودکار را تنظیم کنید</translation>
<translation id="7942415993090181327">سابقه گفتگو</translation>
<translation id="5084498230659987096">Brave Leo سرویس چت مبتنی بر هوش مصنوعی و سایر قابلیت‌های مبتنی بر هوش مصنوعی را با رعایت حریم خصوصی در مرورگر ارائه می‌دهد. Leo هرگز از داده‌های شما برای یادگیری یا آموزش مدل استفاده نمی‌کند. تمام درخواست‌ها از طریق یک سرور ناشناس‌‌ساز منتقل می‌شوند.</translation>
<translation id="6458721693611638005">برای کسب اطلاعات بیشتر درباره روش‌های محافظت Brave از حریم خصوصی شما هنگام استفاده از هوش مصنوعی، خط‌مشی حریم خصوصی Leo را بخوانید. <ph name="BEGIN_LINK"/>اطلاعات بیشتر<ph name="END_LINK"/></translation>
<translation id="614530507403667291">مدل پیش‌فرض برای مکالمات جدید</translation>
<translation id="6340526405444716530">شخصی‌سازی</translation>
<translation id="5077965667729100040">حافظه‌ها و پاسخ‌های Leo را سفارشی‌سازی کنید</translation>
<translation id="8826914609353373601">مدیریت اشتراک ممتاز</translation>
<translation id="235457946228076038">مدل خودتان را داشته باشید</translation>
<translation id="8631951653187535788">مطمئنید می‌خواهید این مدل را حذف کنید؟ اگر از این مدل در هر مکالمه فعالی استفاده شود، آن مکالمه به استفاده از مدل پیش‌فرض Leo تغییر می‌کند.</translation>
