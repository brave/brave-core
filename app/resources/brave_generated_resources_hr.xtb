<translation id="8213464188712611711">Memorije</translation>
<translation id="736384197563279828">Sve ono što je Leo naučio o vama i neće zaboraviti. <ph name="BEGIN_LINK"/>Doznajte više<ph name="END_LINK"/></translation>
<translation id="4664222465181795837">Još nema memorija</translation>
<translation id="8914960762169062277">Dodajte memoriju kako biste pomogli Leu da vas bolje upozna.</translation>
<translation id="4358891361699697299">Dodaj novu memoriju</translation>
