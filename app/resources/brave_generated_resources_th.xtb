<translation id="698972836993887081">เปิดใช้งานหน่วยความจำของผู้ใช้</translation>
<translation id="4256342809997283108">Leo ควรเรียกคุณว่าอะไรดี</translation>
<translation id="1362393385416256849">กรุณากรอกชื่อที่คุณต้องการให้ Leo เรียกคุณ</translation>
<translation id="7841672648317556034">คุณทำงานอะไร</translation>
<translation id="1228535384519357095">บอก Leo หน่อยว่าคุณทำงานอะไร</translation>
<translation id="1300619108689988155">ให้ Leo ตอบคำถามคุณแบบไหนดี</translation>
<translation id="5071940952740278148">อธิบายโทนและลักษณะที่คุณอยากให้ Leo ใช้เมื่อตอบกลับ</translation>
<translation id="5647284470247510206">มีอะไรอีกไหมเกี่ยวกับคุณที่ลีโอควรรู้</translation>
<translation id="7228073810237286235">ให้ Leo รู้เกี่ยวกับความชอบต่างๆ ที่คุณต้องการให้ Leo คิดถึงเมื่อตอบคำถาม</translation>
<translation id="683188035663069399">บันทึกการเปลี่ยนแปลงแล้ว</translation>
<translation id="6708571471662618310">ข้อมูลนำเข้ามายาวเกินไป</translation>
