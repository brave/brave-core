<translation id="7885157704277298658">คัดลอกแล้ว!</translation>
<translation id="8802630444265810662">รหัส QR ให้สแกนด้วยอุปกรณ์มือถือเพื่อส่งรหัสซิงค์ของคุณ</translation>
<translation id="6221331245829088299">เกิดความผิดพลาดในการแสดงรหัส QR โปรดรีเฟรชแล้วลองอีกครั้ง</translation>
<translation id="298546024891487702">ขั้นตอนแรก คุณจะต้องทำการติดตั้ง Brave บนอุปกรณ์ทั้งหมดที่คุณต้องการซิงค์ จากนั้นหากต้องการผูกอุปกรณ์ทั้งหมดไว้ด้วยกัน ให้เริ่มทำซิงค์เชนที่คุณต้องการใช้งานขึ้นมาเพื่อเชื่อมโยงอุปกรณ์ทั้งหมดของคุณเข้าด้วยกันอย่างปลอดภัย</translation>
<translation id="6200528822592747640">เริ่มซิงค์เชนใหม่</translation>
<translation id="5184726904895809379">ฉันมีซิงค์โค้ด</translation>
<translation id="8780295742023331191">ดูซิงค์โค้ด</translation>
<translation id="9017050385815017931">โทรศัพท์/แท็บเล็ต</translation>
<translation id="1736420071277903564">คอมพิวเตอร์</translation>
<translation id="3407602902101449803">ซิงค์เชนคิวอาร์โค้ด</translation>
<translation id="8369686073965491869">ในอุปกรณ์มือถือของคุณ ให้ไปที่ Brave Sync ในแผงการตั้งค่า และคลิกปุ่ม</translation>
<translation id="6527776448555649991">“สแกนซิงค์โค้ด”.</translation>
<translation id="1400862780574843709">ใช้กล้องสแกนคิวอาร์โค้ดด้านล่าง</translation>
<translation id="5086223971958279691">ซิงค์เชนโค้ด</translation>
<translation id="2899261497479389619">ในคอมพิวเตอร์เป้าหมายของคุณ ให้ไปที่ Brave Sync ในการตั้งค่า และคลิกปุ่ม</translation>
<translation id="4827439149833241990">“ฉันมีซิงค์โค้ด”.</translation>
<translation id="8299617838343103908">ใส่รหัสอักษรซิงค์เชนที่แสดงด้านล่าง</translation>
<translation id="4485276108749547761">ดูแลรหัสนี้เหมือนกับรหัสผ่าน หากมีใครได้รหัสนี้ เขาสามารถอ่านและแก้ไขข้อมูลซิงค์ของคุณได้</translation>
<translation id="3034163433136515805">ดูคิวอาร์โค้ด</translation>
<translation id="5373825572723282843">ป้อนรหัสการซิงค์</translation>
<translation id="1265244359514651398">กรอกข้อความรหัสผ่านกลุ่มการซิงค์ของคุณด้านล่าง</translation>
<translation id="1061533051865606843">เพิ่มอุปกรณ์ใหม่</translation>
<translation id="5093410893656857925">เลือกประเภทอุปกรณ์</translation>
<translation id="4581190919849683048">อุปกรณ์ที่คุณต้องการซิงค์เป็นอุปกรณ์ชนิดใด?</translation>
<translation id="4112587618563511470">รหัสซิงค์ไม่ถูกต้อง โปรดตรวจสอบแล้วลองอีกครั้ง</translation>
<translation id="3995714999835224798">โค้ดไม่ถูกต้อง</translation>
<translation id="4432071071853308688">โค้ดนี้ว่างเปล่า</translation>
<translation id="955848693465029904">ข้อผิดพลาดภายในเมื่อตั้งค่าการซิงค์</translation>
<translation id="7456398316301207582">เกิดข้อผิดพลาดการลบบัญชีภายใน</translation>
<translation id="859506441384380749">รหัสนี้สร้างโดย Brave เวอร์ชันที่เลิกใช้แล้ว กรุณาอัปเกรดอุปกรณ์อื่นของคุณก่อน</translation>
<translation id="3132642509209154999">รหัสนี้หมดอายุแล้ว กรุณาสร้างรหัสใหม่บนอุปกรณ์อื่นของคุณแล้วลองอีกครั้ง</translation>
<translation id="2859229680945501779">รหัสนี้ไม่ถูกต้อง กรุณาตรวจสอบให้มั่นใจว่าคุณได้ตั้งค่าเวลาและเขตเวลาบนอุปกรณ์ของคุณถูกต้อง</translation>
<translation id="2339730291919608488">ออกจากกลุ่มการซิงค์</translation>
<translation id="115699408012835975">หากคุณรีเซ็ตซิงค์ คุณจะต้องกรอกรหัสซิงค์ใหม่จากอุปกรณ์อื่นเพื่อที่จะซิงค์กับอุปกรณ์นั้น ๆ แน่ใจว่าต้องการดำเนินการต่อ?</translation>
<translation id="6092564993102418148">คุณแน่ใจหรือไม่ว่าต้องการลบอุปกรณ์ที่เลือกจากซิงค์เชน</translation>
<translation id="4400414577602898435">คำเตือน: การดำเนินการนี้จะแบ่งปันข้อมูล Brave ของคุณ และอาจรวมถึงรหัสผ่านของคุณกับอุปกรณ์ที่สร้างข้อความโค้ดเหล่านี้

โปรดตรวจสอบข้อความโค้ดเหล่านี้อีกครั้งว่าสร้างโดยอุปกรณ์ที่คุณเป็นเจ้าของหรือไม่

คุณแน่ใจหรือว่าต้องการดำเนินการนี้</translation>
<translation id="7443185843787879670">Brave ไม่สามารถเข้าถึงพื้นที่เก็บข้อมูลที่ปลอดภัยในระบบปฏิบัติการของคุณได้ นี่คือสิ่งที่ใช้เพื่อรักษาความปลอดภัยของข้อมูล เช่น รหัสผ่านและคุกกี้ นอกจากนี้ Brave Sync ยังจำเป็นที่จะต้องเชื่อมต่อโปรไฟล์เบราว์เซอร์ของคุณระหว่างอุปกรณ์ต่างๆ ซึ่งหมายความว่า Brave Sync จะหยุดทำงาน ในการแก้ไขปัญหานี้ โปรดดูที่<ph name="BEGIN_LINK_SYNC_GUIDE"/>คำแนะนำในการแก้ไขปัญหา Brave Synce<ph name="END_LINK_SYNC_GUIDE"/></translation>
<translation id="6802736947576520626">ดูเหมือนว่ากุญแจเข้ารหัสการซิงค์ของคุณจะแตกต่างจากกุญแจที่คุณใช้เมื่อตั้งค่า Brave Sync ครั้งแรก วิธีแก้ไขที่ง่ายที่สุดคือการรีเซ็ตและเข้าร่วมกลุ่มการซิงค์ใหม่โดยใช้ข้อความรหัสผ่านจากอุปกรณ์อื่นของคุณที่ซิงค์แล้ว</translation>
<translation id="4889767840132638381">รีเซ็ตและเข้าร่วมกลุ่มการซิงค์ใหม่</translation>
<translation id="1680065323266179640">ลบบัญชีซิงค์</translation>
<translation id="9064376100690171155">ลบบัญชีถาวร</translation>
<translation id="228906529296554286">การลบบัญชีจะลบข้อมูลที่เข้ารหัสของคุณออกจากเซิร์ฟเวอร์ของ Brave และปิดการซิงค์บนอุปกรณ์ที่เชื่อมต่อทั้งหมด</translation>
<translation id="7578652532113583362">แต่จะไม่ลบข้อมูลใดๆ ที่เก็บไว้ในเครื่อง</translation>
<translation id="2516405584294312544">การลบนั้นเป็นถาวรและจะไม่สามารถกู้คืนข้อมูลได้ ถ้าคุณตัดสินใจที่จะ
 เริ่มใช้การซิงค์อีกครั้ง คุณจะต้องสร้างบัญชีใหม่และเพิ่มอุปกรณ์ใหม่ทีละเครื่อง</translation>
<translation id="4860996720371753023">กำลังทำการลบบัญชี...</translation>
<translation id="4094590686212463338">ไม่สามารถเข้าร่วมกลุ่มการซิงค์ได้เนื่องจากกลุ่มการซิงค์ถูกลบไปแล้ว</translation>
<translation id="4908081302669157000">หมายเลขโทรศัพท์ อีเมล และที่อยู่</translation>
<translation id="294985549514492876">เว็บแอป (PWA)</translation>
<translation id="7029809446516969842">รหัสผ่าน</translation>
<translation id="6011308810877101166">ปรับปรุงข้อเสนอแนะการค้นหา</translation>
<translation id="2332576387809612040">เมื่อเปิดใช้งาน Brave จะส่งสิ่งที่คุณพิมพ์ในแถบที่อยู่หรือกล่องค้นหาถึงเครื่องมือค้นหามาตรฐานของคุณเพื่อให้ได้ข้อเสนอแนะที่ดีกว่า เมื่อปิดใช้งาน Brave จะโชว์ข้อเสนอแนะที่สร้างขึ้นในอุปกรณ์ของคุณเท่านั้น ซึ่งจะปิดใช้งานเสมอในโหมดส่วนตัว</translation>
<translation id="5522403133543437426">เครื่องมือค้นหาที่ใช้ในแถบที่อยู่</translation>
<translation id="280472502078788655">เครื่องมือค้นหาที่ใช้ในแถบที่อยู่สำหรับหน้าต่างส่วนตัว</translation>
<translation id="7232120595886556478">หน้าต่างปกติ</translation>
<translation id="6739674350896546324">เสิร์ชเอนจินสำหรับโหมดส่วนตัว</translation>
<translation id="1280261732441045146"><ph name="SEARCH_ENGINE_NAME"/> ตอนนี้เป็นเครื่องมือค้นหาเริ่มต้นของคุณสำหรับหน้าต่างแบบส่วนตัว</translation>
<translation id="5363742888375478536">Brave Search ได้รับการแนะนำเพื่อประสบการณ์การท่องเว็บที่ดีที่สุดขณะใช้เบราว์เซอร์ Brave</translation>
<translation id="7298195798382681320">แนะนำ</translation>
<translation id="6864914031231797928">อนุญาตการล็อกอินด้วย Google สำหรับส่วนขยาย</translation>
<translation id="1519976482053221804">เราเตอร์สื่อจะเปิดใช้งานฟีเจอร์การส่งภาพในเบราว์เซอร์</translation>
<translation id="2707635989000984973">แก้ไขชื่อโดเมน Unstoppable Domains</translation>
<translation id="732344438514476996"><ph name="BEGIN_LINK"/>เรียนรู้เพิ่มเติม<ph name="END_LINK"/> เกี่ยวกับการพิจารณาความเป็นส่วนตัวของ Unstoppable Domains</translation>
<translation id="641308776160806829">แก้ไขชื่อโดเมน Ethereum Name Service (ENS)</translation>
<translation id="6421218422395686663">อนุญาตการค้นหานอกเครือข่ายบล็อกเชนของ ENS</translation>
<translation id="4608449984413688436">แก้ไขชื่อโดเมน Solana Name Service (SNS)</translation>
<translation id="7831978744512353629"><ph name="BEGIN_LINK"/>เรียนรู้เพิ่มเติม<ph name="END_LINK"/>เกี่ยวกับข้อควรพิจารณาด้านความเป็นส่วนตัวในการค้นหานอกเครือข่ายบล็อกเชนของ ENS</translation>
<translation id="6241402707160226266">หน้าต่างส่วนตัวด้วย Tor</translation>
<translation id="8762452230727230396">Tor จะซ่อนที่อยู่ IP ของคุณจากเว็บไซต์ที่คุณเยี่ยมชม</translation>
<translation id="951983619130191090">เลือกที่จะช่วยคนอื่นเชื่อมต่อเครือข่าย Tor</translation>
<translation id="2223668809371912019">เปิดการขยาย Snowflake เพื่ออนุญาตให้ผู้ใช้ในประเทศที่ถูกตรวจสอบเชื่อมต่อกับเครือข่าย Tor ผ่านการเชื่อมต่อเครือข่ายของคุณ</translation>
<translation id="2959986444009520721">ใช้สะพาน</translation>
<translation id="271237727681958372">บริดจ์ช่วยให้คุณเข้าถึงเครือข่าย Tor ในตำแหน่งที่ Tor ถูกบล็อก บริดจ์ตัวหนึ่งอาจทำงานได้ดีกว่าตัวอื่น โดยขึ้นอยู่กับตำแหน่งของคุณ</translation>
<translation id="7206799843254049470">การตั้งค่าการเชื่อมต่อทอร์</translation>
<translation id="3194502271166340944">ควบคุมวิธีที่วินโดว์ส่วนบุคคลด้วยทอร์เชื่อมต่อกับเครือข่ายทอร์</translation>
<translation id="3717364961460790491">ไม่สามารถดาวน์โหลดการขยาย Snowflake ที่จำเป็นสำหรับการทำงานนี้ โปรดตรวจสอบการเชื่อมต่ออินเทอร์เน็ตของคุณและลองอีกครั้ง</translation>
<translation id="4859228830700205299">เลือกสะพานในตัว</translation>
<translation id="3233137871426528317">ขอสะพานจาก torproject.org</translation>
<translation id="5701503934456421898">ขอสะพานใหม่...</translation>
<translation id="8149806369020180959">จัดหาสะพาน</translation>
<translation id="454073978993625597">ป้อนข้อมูลสะพานจากแหล่งที่เชื่อถือได้</translation>
<translation id="4425607417590286548">ใช้การเปลี่ยนแปลง</translation>
<translation id="2128143836897950793">คลิกที่ 'ขอสะพานใหม่...' เพื่อรับสะพาน</translation>
<translation id="3314921753580327793">พิมพ์ที่อยู่:พอร์ต (หนึ่งรายการต่อบรรทัด)</translation>
<translation id="3755189300481406891">ขอสะพาน</translation>
<translation id="6924425739431382319">ติดต่อ BridgeDB โปรดรอ</translation>
<translation id="811745063252080651">แก้ไข CAPTCHA เพื่อขอสะพาน</translation>
<translation id="6936835573742749135">ไม่สามารถขอ CAPTCHA ได้ โปรดลองอีกครั้งภายหลัง</translation>
<translation id="2653659639078652383">ส่ง</translation>
<translation id="1294350054292274934">แปลงเฉพาะที่อยู่ .onion ในหน้าต่าง Tor</translation>
<translation id="4745128937437681681">บริการ Onion จะไม่สามารถใช้งานได้นอกหน้าต่าง Tor</translation>
<translation id="6305528566126073902">ใช้องค์ประกอบการจัดการสิทธิ์ทางดิจิทัล Widevine (DRM) เพื่อดูสตรีมมิ่งวิดีโอที่มีการป้องกันและเนื้อหาอื่น ๆ ในเบราว์เซอร์</translation>
<translation id="1314131187310290315">ส่วนขยาย Manifest V2</translation>
<translation id="2488433650767270565">ส่วนขยาย Manifest V2 ต่อไปนี้จะถูกลบออกจาก Chrome เว็บสโตร์ แต่ยังคงรองรับใน Brave สลับเพื่อดาวน์โหลดและติดตั้งหรือถอนการติดตั้ง</translation>
<translation id="6918225713618473646">Brave เป็นโฮสต์ส่วนขยาย Manifest V2 เหล่านี้ไว้บนเซิร์ฟเวอร์ของ Brave เอง แต่ไม่ได้ตรวจสอบหรือยืนยันเนื้อหา ความปลอดภัย หรือพฤติกรรมของส่วนขยายนั้น ๆ
โปรดดูหน้าทางการของแต่ละส่วนขยายเพื่อขอความช่วยเหลือ
อ่านแผนของ Brave เกี่ยวกับ Manifest V2 ได้<ph name="BEGIN_LINK"/>ที่นี่<ph name="END_LINK"/></translation>
<translation id="578671172657727816">เปิดใช้งาน NoScript™</translation>
<translation id="9068475464170522036">NoScript คือส่วนขยาย Manifest V2 ที่จะช่วยให้คุณบล็อกหรือยกเลิกบล็อกสคริปต์ที่กำลังเรียกใช้หรือพยายามที่จะเรียกใช้ในหน้าที่กำหนด</translation>
<translation id="1394592156621788100">เปิดใช้งาน uBlock Origin™</translation>
<translation id="2638983091068889519">uBlock Origin คือส่วนขยาย Manifest V2 ที่ให้เครื่องมือบล็อกเนื้อหาอันทรงพลังที่มาพร้อมตัวเลือกมากมายให้กับผู้ใช้ขั้นสูง</translation>
<translation id="3909078036552544838">เปิดใช้งาน uMatrix™</translation>
<translation id="8796148218203577506">uMatrix คือส่วนขยาย Manifest V2 ที่ให้บริการไฟร์วอลล์เมตริกซ์แบบ Point-and-Click พร้อมเครื่องมือยกระดับความเป็นส่วนตัวอีกมากมาย</translation>
<translation id="2385774023523989298">เปิดใช้งาน AdGuard™</translation>
<translation id="188228077840632890">AdGuard คือส่วนขยาย Manifest V2 ที่ให้การบล็อกโฆษณา ตัวเลือกการควบคุมโดยผู้ปกครอง และการผสานรวมกับข้อเสนอบริการ AdGuard อื่นๆ</translation>
<translation id="8137559199583651773">จัดการส่วนขยาย</translation>
<translation id="7013485839273047434">รับส่วนขยายเพิ่มเติม</translation>
<translation id="4954512758656527938">วอลเล็ต Ethereum เริ่มต้น</translation>
<translation id="7701023802820268122">วอลเล็ต Solana เริ่มต้น</translation>
<translation id="3991455933137809014">วอลเล็ต Cardano เริ่มต้น</translation>
<translation id="8488282162676695335">Brave Wallet</translation>
<translation id="6942354363301686374">ส่วนขยาย (ไม่มีการสำรองข้อมูล)</translation>
<translation id="702381242110464396">ส่วนขยาย (สำรองข้อมูล Brave วอลเล็ท)</translation>
<translation id="4718664830805652430">สกุลเงินพื้นฐานเริ่มต้น</translation>
<translation id="7992507032049865603">สกุลเงินคริปโตพื้นฐานเริ่มต้น</translation>
<translation id="3044369626313583722">แสดงปุ่ม Brave Wallet</translation>
<translation id="7568430944629653319">เปิดใช้งาน NFT discovery</translation>
<translation id="970496996377628529">เพิ่ม NFT ของคุณไปยังวอลเล็ทโดยอัตโนมัติด้วย API ของบุคคลที่สาม</translation>
<translation id="8421293929927030255">เปิดใช้งาน กระเป๋าเงิน Brave ในหน้าต่างแบบส่วนตัว</translation>
<translation id="1729224157015744629">คำเตือน: การใช้ที่อยู่ของวอลเล็ทซ้ำในเซสชันหน้าต่างแบบส่วนตัวอาจเป็นการเปิดใช้งานเว็บไซต์เพื่อเชื่อมโยงเซสชันหน้าต่างแบบส่วนตัวกับเซสชันหน้าต่างที่ไม่ใช่แบบส่วนตัวได้</translation>
<translation id="8239147115686034860">ล็อค Brave วอลเล็ตโดยอัตโนมัติ</translation>
<translation id="414639769490080648">จำนวนนาทีที่ต้องรอจนกว่า Brave วอลเล็ตจะล็อคโดยอัตโนมัติ</translation>
<translation id="856371974127598760">เครือข่ายกระเป๋าเงิน</translation>
<translation id="5975930666279943472">ล้าข้อมูลธุรกรรมในกระเป๋าเงินและข้อมูล Nonce</translation>
<translation id="5693968582510626466">การล้างข้อมูลธุรกรรมอาจเป็นประโยชน์ต่อนักพัฒนาหรือเป็นประโยชน์เมื่อล้างสถานะบนเซิร์ฟเวอร์ภายใน</translation>
<translation id="6171369470447621882">รีเซตสถานะการซิงค์ของ Zcash</translation>
<translation id="6705112675071480687">รีเซตความคืบหน้าในการซิงค์ Zcash สำหรับบัญชีที่ได้รับการป้องกันทั้งหมด</translation>
<translation id="2012093487873597892">คุณแน่ใจหรือไม่ว่าต้องการรีเซตสถานะการซิงค์ของ Zcash ความคืบหน้าในการซิงค์ของบัญชีที่ได้รับการป้องกันทั้งหมดจะถูกลบ พิมพ์ "<ph name="CONFIRMATION_PHRASE"/>" เพื่อยืนยัน</translation>
<translation id="5031551083187285762">สถานะการซิงค์ของบัญชี Zcash ของคุณถูกรีเซตแล้ว</translation>
<translation id="9216386092464743272">คุณแน่ใจหรือไม่ว่าต้องการรีเซ็ตข้อมูลธุรกรรมในกระเป๋าเงินและข้อมูล Nonce ซึ่งตัวเลือกนี้ส่วนใหญ่จะใช้โดยนักพัฒนาที่รันเซิร์ฟเวอร์ทดสอบในเครื่อง กรุณาพิมพ์ "<ph name="CONFIRMATION_PHRASE"/>" เพื่อยืนยัน</translation>
<translation id="2326850911705720398">รีเซ็ตและล้างข้อมูลวอลเล็ต</translation>
<translation id="6369495274982305511">คุณแน่ใจหรือไม่ว่าต้องการรีเซ็ตกระเป๋าเงินของคุณ หากไม่ได้สำรองกระเป๋าเงินของคุณไว้ จะทำให้คุณสูญเสียข้อมูลบัญชีทั้งหมด (รวมถึงเงินที่เกี่ยวข้อง) พิมพ์ "<ph name="CONFIRMATION_PHRASE"/>" เพื่อยืนยัน</translation>
<translation id="3752403403443723332">รีเซ็ตกระเป๋าเงินของคุณแล้ว!</translation>
<translation id="594766067816395072">รีเซ็ตข้อมูลธุรกรรมในกระเป๋าเงินของคุณแล้ว</translation>
<translation id="57798285717509216">ดูผลการทำธุรกรรมก่อนเซ็นชื่อ <ph name="BEGIN_LINK"/>&lt;u&gt;เรียนรู้เพิ่มเติม&lt;/u&gt;<ph name="END_LINK"/></translation>
