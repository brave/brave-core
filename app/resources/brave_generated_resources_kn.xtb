<translation id="8275068909952022340">ಇನ್ನಷ್ಟು…</translation>
<translation id="71316462802471551">ಈಮೇಲ್‌ ವಿಳಾಸ</translation>
<translation id="1990886731975529483">Google Widevine ಸ್ಥಾಪಿಸಿ ಮತ್ತು ರನ್ ಮಾಡಿ</translation>
<translation id="8926389886865778422">ಮತ್ತೆ ಕೇಳಬೇಡಿ</translation>
<translation id="4900351245762303149">Google Widevine ಸ್ಥಾಪಿಸಿ</translation>
<translation id="2313383941300459392">Google Widevine ಸಕ್ರಿಯಗೊಳಿಸಲು ಬ್ರೌಸರ್ ರಿಸ್ಟಾರ್ಟ್ ಮಾಡಿ</translation>
<translation id="8342816622062204340">ಸಂರಕ್ಷಿತ Google Widevine ವಿಷಯವನ್ನು ಪ್ಲೇ ಮಾಡಲು <ph name="URL"/> ಬಯಸುತ್ತದೆ, ಇದಕ್ಕಾಗಿ ನೀವು Widevine ಗೆ Android ಸಿಸ್ಟಮ್ ಬೆಂಬಲವನ್ನು ಅನುಮತಿಸಬೇಕಾಗುತ್ತದೆ. ಅನುಮತಿಸುವ ಮೂಲಕ, ನೀವು Google ನ ಬಳಕೆಯ ನಿಯಮಗಳನ್ನು ಒಪ್ಪುತ್ತೀರಿ.</translation>
<translation id="2200626478572277092">ವೆಬ್‌ಪುಟದಲ್ಲಿ ಮೀಡಿಯಾ ಪ್ಲೇ ಮಾಡುವುದಕ್ಕಾಗಿ ಕೆಲವೊಮ್ಮೆ Widevine ಅಗತ್ಯವಿರುತ್ತದೆ. ಇದು Google ಸರ್ವರ್‌ಗಳಿಂದ ಲೋಡ್ ಮಾಡಲಾದ Google ವಿಸ್ತರಣೆಯಾಗಿದ್ದು, ಅದನ್ನು Brave ಬೆಂಬಲಿಸುವುದಿಲ್ಲ. ಸ್ಥಾಪಿಸುವ ಮೂಲಕ, ನೀವು Google ನ ಸೇವಾ ನಿಯಮಗಳಿಗೆ ಒಪ್ಪುತ್ತೀರಿ.</translation>
<translation id="4931114810905682683"><ph name="LEARN_MORE_ABOUT_WIDEVINE"/>.
ಅಥವಾ <ph name="SETTINGS_EXTENIONS_LINK"/> ನಲ್ಲಿ ನಂತರದಲ್ಲಿ ಬದಲಾಯಿಸಿ.</translation>
<translation id="6229752134959014186">Widevine ಕುರಿತು ಹೆಚ್ಚು ತಿಳಿಯಿರಿ</translation>
<translation id="6061083111980694767"><ph name="SITE_NAME"/> ನಿಮಗೆ ಹೀಗೆ ಮಾಡಲು ಕೇಳುತ್ತಿದೆ</translation>
<translation id="3218385319396786393">ಈ ಪುಟದಲ್ಲಿ ಸ್ವಯಂಪ್ಲೇ ನಿರ್ಬಂಧಿಸಲಾಗಿದೆ</translation>
<translation id="4988333904713528597"><ph name="HOST"/> ನಲ್ಲಿ ಯಾವಾಗಲೂ ಸ್ವಯಂಪ್ಲೇ ಅನುಮತಿಸಿ</translation>
<translation id="4150684676757176434">ಸ್ವಯಂಪ್ಲೇ ನಿರ್ಬಂಧಿಸುವಿಕೆಯನ್ನು ಮುಂದುವರಿಸಿ</translation>
<translation id="3477357195688115718">ಸುರಕ್ಷತೆ ಹಾಗೂ ರಕ್ಷಣೆಗಾಗಿ ಎಕ್ಸ್‌ಟೆನ್ಶನ್‌ಗಳನ್ನು Brave ಪರಿಶೀಲಿಸುವುದಿಲ್ಲ. ನೀವು ಡೆವಲಪರ್ ಮೇಲೆ ನಂಬಿಕೆ ಹೊಂದಿದ್ದಲ್ಲಿ ಮಾತ್ರ ಈ ಎಕ್ಸ್‌ಟೆನ್ಶನ್‌ ಅನ್ನು ಇನ್‌ಸ್ಟಾಲ್ ಮಾಡಿ.</translation>
<translation id="2928844661231356557">ಬ್ಲೂಟೂತ್ ಸಾಧನಕ್ಕೆ ಪ್ರವೇಶವನ್ನು ನೀಡುವುದರಿಂದ ಗುರುತಿಸಬಹುದಾದ ಮತ್ತು ನಿಮ್ಮ ಕುರಿತಾದ ಸಂಭಾವ್ಯವಾಗಿ ಸೂಕ್ಷ್ಮ ಮಾಹಿತಿಯನ್ನು ರೀಡ್ ಮಾಡಲು ಸೈಟ್‌ಗೆ ಅನುಮತಿಸುತ್ತದೆ. ಬ್ಲೂಟೂತ್ ಸಾಧನಗಳನ್ನು ಪ್ರವೇಶಿಸಲು ನೀವು ವಿಶ್ವಾಸ ಇರಿಸುವ ಸೈಟ್‌ಗಳಿಗೆ ಮಾತ್ರ ಅನುಮತಿಸಿ. <ph name="LEARN_MORE"/></translation>
<translation id="9005883459983913482">Tor ವಿಂಡೋಗಳು</translation>
<translation id="7965178729203412357">ಹೊಸ Tor ಗುರುತಿಸುವಿಕೆ</translation>
