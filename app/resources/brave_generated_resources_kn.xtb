<translation id="6333402912272476257">ಈ ಅಂತಿಮ ಬಿಂದುವು ಅಸುರಕ್ಷಿತವಾಗಿದೆ.</translation>
<translation id="4025470490371933693">ಖಾಸಗಿ IPಗಳನ್ನು ಅನುಮತಿಸಲಾಗುವುದಿಲ್ಲ</translation>
<translation id="3670571614478401810">ನೀವು ನಮೂದಿಸಿದ ವಿಳಾಸವು ನಿಮ್ಮ ರೂಟರ್ ಅಥವಾ ಸ್ಥಳೀಯ ಸರ್ವರ್‌ನಂತಹ ಖಾಸಗಿ ನೆಟ್‌ವರ್ಕ್‌ನಿಂದ ಬಂದಿರುವಂತೆ ತೋರುತ್ತಿದೆ. ನಿಮ್ಮನ್ನು ಸುರಕ್ಷಿತವಾಗಿರಿಸಲು ಬ್ರೇವ್ ಇವುಗಳನ್ನು ಸ್ವಯಂಚಾಲಿತವಾಗಿ ನಿರ್ಬಂಧಿಸುತ್ತದೆ, ಆದರೆ ಇದು ಸುರಕ್ಷಿತವಾಗಿದೆ ಎಂದು ನಿಮಗೆ ವಿಶ್ವಾಸವಿದ್ದರೆ ನೀವು ಅವುಗಳನ್ನು ಸಕ್ರಿಯಗೊಳಿಸಬಹುದು.</translation>
<translation id="4932437543207655965">ಮುಂದುವರೆಯಲು, brave://flags/ ಗೆ ಭೇಟಿ ನೀಡಿ, "brave-ai-chat-allow-private-ips" ಗಾಗಿ ಹುಡುಕಿ ಮತ್ತು ಫೀಚರ್‌ನ್ನು ಸಕ್ರಿಯಗೊಳಿಸಿ. ಒಮ್ಮೆ ಸಕ್ರಿಯಗೊಳಿಸಿದರೆ, ನೀವು lEO ಸೆಟ್ಟಿಂಗ್‌ಗಳಲ್ಲಿ ಖಾಸಗಿ ನೆಟ್‌ವರ್ಕ್ ವಿಳಾಸಗಳನ್ನು ಬಳಸಬಹುದು.</translation>
<translation id="5249539665306267943">ಹೊಸ ಫೋಲ್ಡರ್ ಸೇರಿಸಿ</translation>
<translation id="7265212806651512211">ನೀವು ಇನ್ನೂ ಮಾದರಿಯನ್ನು ಸಂಪರ್ಕಿಸಿಲ್ಲ.</translation>
<translation id="7304802428852949897">ನಿಮ್ಮ ಮಾದರಿಗಳು</translation>
<translation id="7435587476558117990">ನಿಮ್ಮ ಸ್ವಯಂ-ಹೋಸ್ಟ್ ಮಾಡಿದ ಅಥವಾ ಥರ್ಡ್‌-ಪಾರ್ಟಿ ಹೋಸ್ಟ್ ಮಾಡಿದ LLM ಅನ್ನು Leo ಗೆ ಸಂಪರ್ಕಿಸಿ ಮತ್ತು ಅವುಗಳನ್ನು ಬ್ರೌಸರ್‌ನಲ್ಲಿ ಬಳಸಿ.</translation>
<translation id="8137606697798069075">Ollama ನಂತಹ ಪ್ರೋಟೋಕಾಲ್‌ಗೆ ಹೊಂದಬಲ್ಲ ಯಾವುದೇ OpenAI ಚಾಟ್ ಬಳಸಿ. <ph name="BEGIN_LINK"/>ಇನ್ನಷ್ಟು ತಿಳಿಯಿರಿ<ph name="END_LINK"/></translation>
<translation id="2642905648178380593">ಮಾದರಿಯನ್ನು ಉಳಿಸಿ</translation>
<translation id="6304169450064541679">ಸಿಸ್ಟಮ್ ಪ್ರಾಂಪ್ಟ್</translation>
<translation id="3081947790648024460">ನಿರ್ದಿಷ್ಟ ಸೂಚನೆ ಅಥವಾ ಮಾರ್ಗದರ್ಶನ ಅಥವಾ ಪ್ರತಿಕ್ರಿಯೆ ಪಡೆಯಲು ಕಸ್ಟಮ್ ಸೂಚನೆಗಳಿಗಾಗಿ ಕಾಂಟೆಕ್ಸ್ಟ್‌ ನೀಡಲಾಗಿದೆ. ಮತ್ತು/ಅಥವಾ ಸಂದರ್ಭವನ್ನು ನೀಡಲಾಗಿದೆ. ನೀವು ಬಯಸಿದಲ್ಲಿ %datetime% ಅನ್ನು ಬಳಸಿ ಪ್ರಸ್ತುತ ದಿನಾಂಕ ಮತ್ತು ಸಮಯವನ್ನು ಸೇರಿಸಬಹುದು.</translation>
<translation id="5688878061573389791"><ph name="TOKENS_COUNT"/> ಟೋಕನ್ಸ್</translation>
<translation id="6911466383346197271">ಲಿಯೋವನ್ನು ಕಸ್ಟಮೈಸ್ ಮಾಡಿ</translation>
<translation id="5702085383070170010">ನಿಮ್ಮ ಬಗ್ಗೆ</translation>
<translation id="2493241731563937877">ಹೆಚ್ಚು ವೈಯಕ್ತಿಕಗೊಳಿಸಿದ ಉತ್ತರಗಳನ್ನು ಪಡೆಯಲು ನಿಮ್ಮ ಬಗ್ಗೆ ಲಿಯೋಗೆ ಹೇಳಿ. <ph name="BEGIN_LINK"/>ಇನ್ನಷ್ಟು ತಿಳಿಯಿರಿ<ph name="END_LINK"/></translation>
<translation id="8536280915366791221">ಲಿಯೋ ಕಸ್ಟಮೈಸೇಷನ್‌ ಸಕ್ರಿಯಗೊಳಿಸಿ</translation>
<translation id="698972836993887081">ಬಳಕೆದಾರರ ಮೆಮೊರೀಸ್‌ ಸಕ್ರಿಯಗೊಳಿಸಿ</translation>
<translation id="4256342809997283108">ಲಿಯೋ ನಿಮ್ಮನ್ನು ಏನೆಂದು ಕರೆಯಬೇಕು?</translation>
<translation id="1362393385416256849">ಲಿಯೋ ನಿಮ್ಮನ್ನು ಕರೆಯಲು ನಿಮ್ಮ ಆದ್ಯತೆಯ ಹೆಸರನ್ನು ನಮೂದಿಸಿ</translation>
<translation id="7841672648317556034">ನೀವು ಏನು ಮಾಡುತ್ತೀರಿ?</translation>
<translation id="1228535384519357095">ನೀವು ಏನು ಮಾಡುತ್ತೀರಿ ಎಂಬ ಬಗ್ಗೆ ಲಿಯೋಗೆ ಸ್ವಲ್ಪ ಹೇಳಿ</translation>
<translation id="1300619108689988155">ಲಿಯೋ ನಿಮ್ಮ ಪ್ರಶ್ನೆಗಳಿಗೆ ಹೇಗೆ ಉತ್ತರಿಸಬೇಕು?</translation>
<translation id="5071940952740278148">ಉತ್ತರಿಸುವಾಗ ಲಿಯೋ ಯಾವ ಟೋನ್‌ ಮತ್ತು ಗುಣಲಕ್ಷಣಗಳನ್ನು ಬಳಸಬೇಕೆಂದು ನೀವು ಬಯಸುತ್ತೀರಿ ಎಂದು ವಿವರಿಸಿ</translation>
<translation id="5647284470247510206">ಲಿಯೋ ನಿಮ್ಮ ಬಗ್ಗೆ ಇನ್ನೂ ಏನಾದರೂ ತಿಳಿದುಕೊಳ್ಳಬೇಕಾ?</translation>
<translation id="7228073810237286235">ಉತ್ತರಿಸುವಾಗ ನೀವು ನೆನಪಿನಲ್ಲಿಟ್ಟುಕೊಳ್ಳಲು ಬಯಸುವ ಯಾವುದೇ ಆದ್ಯತೆಗಳ ಬಗ್ಗೆ ಲಿಯೋಗೆ ತಿಳಿಸಿ</translation>
<translation id="683188035663069399">ಬದಲಾವಣೆಗಳನ್ನು ಉಳಿಸಲಾಗಿದೆ</translation>
<translation id="6708571471662618310">ಇನ್‌ಪುಟ್ ತುಂಬಾ ದೀರ್ಘವಾಗಿದೆ</translation>
<translation id="8213464188712611711">ಮೆಮೊರೀಸ್</translation>
<translation id="736384197563279828">ಲಿಯೋ ನಿಮ್ಮ ಬಗ್ಗೆ ಕಲಿತ ಮತ್ತು ಮರೆಯದ ಎಲ್ಲಾ ವಿಷಯಗಳು. <ph name="BEGIN_LINK"/>ಇನ್ನಷ್ಟು ತಿಳಿಯಿರಿ<ph name="END_LINK"/></translation>
<translation id="4664222465181795837">ಇನ್ನೂ ಯಾವುದೇ ‌ಮೆಮೊರೀಸ್‌ ರಚನೆಯಾಗಿಲ್ಲ</translation>
<translation id="8914960762169062277">ಲಿಯೋ ನಿಮ್ಮನ್ನು ಚೆನ್ನಾಗಿ ತಿಳಿದುಕೊಳ್ಳಲು ಸಹಾಯ ಮಾಡಲು ಒಂದು ನೆನಪನ್ನು ಸೇರಿಸಿ.</translation>
<translation id="4358891361699697299">ಹೊಸ ಮೆಮೊರಿ ಸೇರಿಸಿ</translation>
<translation id="6028732745612718012">ಈ ಮೆಮೊರಿ ಎಡಿಟ್‌ ಮಾಡಿ</translation>
<translation id="3970015815965490773">ಹೊಸ ಮೆಮೋರಿ ರಚಿಸಿ</translation>
<translation id="1206639071829035972">ಲಿಯೋ ಏನು ನೆನಪಿಸಿಕೊಳ್ಳಬೇಕು ಎಂದು ನೀವು ಬಯಸುತ್ತೀರಿ?</translation>
<translation id="2076082422799949288">ಈ ಮೆಮೊರಿಯನ್ನು ಅಳಿಸಿ</translation>
<translation id="1721787502053471881">ಈ ಮೆಮೊರಿಯನ್ನು ಅಳಿಸಲು ನೀವು ಖಚಿತವಾಗಿ ಬಯಸುವಿರಾ? ಈ ಕ್ರಿಯೆಯನ್ನು ರದ್ದುಗೊಳಿಸಲಾಗುವುದಿಲ್ಲ.</translation>
<translation id="5239685926753073108">ಎಲ್ಲಾ ಮೆಮೊರೀಸ್‌ ಅಳಿಸಿ</translation>
<translation id="2600803466586623124">ನೀವು ಎಲ್ಲಾ ನೆನಪುಗಳನ್ನು ಅಳಿಸಲು ಖಚಿತವಾಗಿ ಬಯಸುವಿರಾ? ಈ ಕ್ರಿಯೆಯನ್ನು ರದ್ದುಗೊಳಿಸಲು ಸಾಧ್ಯವಿಲ್ಲ.</translation>
<translation id="7311244614769792472">ಯಾವುದೇ ಫಲಿತಾಂಶಗಳು ಕಂಡುಬಂದಿಲ್ಲ</translation>
<translation id="1838374766361614909">ಹುಡುಕಾಟವನ್ನು ತೆರವುಗೊಳಿಸಿ</translation>
<translation id="5126255551970171328">ಒಂದು ಮೆಮೊರಿಗಾಗಿ ಹುಡುಕಿ</translation>
<translation id="7402116145895962069">ನಿಮ್ಮ Ollama ಸ್ಥಳೀಯ ಮಾದರಿಗಳನ್ನು ಸಿಂಕ್ ಮಾಡಿ</translation>
<translation id="4835154437390745810">Ollama ಮೂಲಕ ನಿರ್ವಹಿಸಲಾಗುತ್ತದೆ</translation>
<translation id="5985516785067818307">ಸರ್ವೆ ಪ್ಯಾನೆಲಿಸ್ಟ್</translation>
<translation id="8347743943525229984">ಬ್ರೇವ್ ಸಮೀಕ್ಷೆಗಳಿಗೆ ಅನುಮತಿ ನೀಡಿ</translation>
<translation id="3204080538332044581">ಹೊಸ ಟ್ಯಾಬ್ ಪುಟದಲ್ಲಿ ಖಾಸಗಿ ಸಮೀಕ್ಷೆಗಳಿಗೆ ಲಿಂಕ್‌ಗಳನ್ನು ತೋರಿಸಲು ಬ್ರೇವ್‌ಗೆ ಅನುಮತಿಸುತ್ತದೆ. ಸಮೀಕ್ಷೆಗಳು ನಮಗೆ ಉತ್ತಮ ಫೀಚರ್‌ಗಳನ್ನು ರೂಪಿಸಲು ಮತ್ತು ಬ್ರೌಸರ್ ಆಧರಿತ ಜಾಹೀರಾತು ಅಭಿಯಾನಗಳು ಎಷ್ಟು ಪರಿಣಾಮಕಾರಿ ಎಂದು ಅಳೆಯಲು ಸಹಾಯ ಮಾಡುತ್ತವೆ. <ph name="BEGIN_LINK"/>ಇನ್ನಷ್ಟು ತಿಳಿಯಿರಿ<ph name="END_LINK"/></translation>
<translation id="349846214503465941">ಪ್ಲೇಪಟ್ಟಿಯನ್ನು ಸಕ್ರಿಯಗೊಳಿಸಿ</translation>
<translation id="7903608716704052878">ಆಫ್‌ಲೈನ್ ವೀಕ್ಷಣೆಗಾಗಿ ಸ್ವಯಂಚಾಲಿತವಾಗಿ ಫೈಲ್‌ಗಳನ್ನು ಸೇರಿಸಿ</translation>
<translation id="384666453982355633">ಈ ಆಯ್ಕೆಯು ಸ್ವಯಂಚಾಲಿತವಾಗಿ ಮೀಡಿಯಾ ಫೈಲ್‌ಗಳನ್ನು ಕ್ಯಾಶ್ ಮಾಡುತ್ತದೆ ಇದರಿಂದ ನೀವು ಇಂಟರ್ನೆಟ್ ಸಂಪರ್ಕವಿಲ್ಲದೆಯೇ ಅವುಗಳನ್ನು ಪ್ಲೇ ಮಾಡಬಹುದು.</translation>
<translation id="8950562208228589873">Quad9 ಗಾಗಿ OS ಡೀಫಾಲ್ಟ್</translation>
<translation id="5646330590189545860">Wikimedia ಗಾಗಿ OS ಡೀಫಾಲ್ಟ್</translation>
<translation id="2026075482948458926">Cloudflare ಗಾಗಿ OS ಡೀಫಾಲ್ಟ್</translation>
<translation id="6624718837376802990">ಅವತಾರ್ ಎಡ್ಜಿ ರಿವಾರ್ಡ್‌ಗಳು</translation>
<translation id="6617313057407561765">ಅವತಾರ್ ಎಡ್ಜಿ Brave</translation>
<translation id="6754445808455578019">ಅವತಾರ್ ಎಡ್ಜಿ ಓಷಿಯನ್</translation>
<translation id="1202230982786524987">ಅವತಾರ್ ಎಡ್ಜಿ ಗ್ರಾಸ್</translation>
<translation id="5795513892420634319">ಅವತಾರ್ ಎಡ್ಜಿ ಕಾರ್ನ್</translation>
<translation id="3561521017993720050">ಅವತಾರ್ ಎಡ್ಜಿ ರಾಯಲ್</translation>
<translation id="1235866128911626592">ಅವತಾರ್ ಎಡ್ಜಿ ನಿಂಜಾ</translation>
<translation id="2090755120827623384">ಅವತಾರ್ ಪಲಾಡಿನ್ ರಿವಾರ್ಡ್‌ಗಳು</translation>
<translation id="2018119859356143702">ಅವತಾರ್ ಪಲಾಡಿನ್ Brave</translation>
<translation id="4740488466586929481">ಅವತಾರ್ ಪಲಾಡಿನ್ ಓಷಿಯನ್</translation>
<translation id="5006207620676644913">ಅವತಾರ್ ಪಲಾಡಿನ್ ಗ್ರಾಸ್</translation>
<translation id="3989232963815817109">ಅವತಾರ್ ಪಲಾಡಿನ್ ಕಾರ್ನ್</translation>
<translation id="4594102608669574640">ಅವತಾರ್ ಪಲಾಡಿನ್ ರಾಯಲ್</translation>
<translation id="2183738260538789532">ಅವತಾರ್ ಪಲಾಡಿನ್ ನಿಂಜಾ</translation>
<translation id="1364533449989493534">ಅವತಾರ್ ಗ್ಲೀಮ್ ರಿವಾರ್ಡ್‌ಗಳು</translation>
<translation id="7885078296101135895">ಅವತಾರ್ ಗ್ಲೀಮ್ Brave</translation>
<translation id="5569105529336093187">ಅವತಾರ್ ಗ್ಲೀಮ್ ಓಷಿಯನ್</translation>
<translation id="8905105122495847950">ಅವತಾರ್ ಗ್ಲೀಮ್ ಗ್ರಾಸ್</translation>
<translation id="5118043134512650846">ಅವತಾರ್ ಗ್ಲೀಮ್ ಕಾರ್ನ್</translation>
<translation id="7054896317531348319">ಅವತಾರ್ ಗ್ಲೀಮ್ ರಾಯಲ್</translation>
<translation id="5493441852328628982">ಅವತಾರ್ ಗ್ಲೀಮ್ ನಿಂಜಾ</translation>
<translation id="2752844432779340213">ಅವತಾರ್ ಓವಲ್ ರಿವಾರ್ಡ್‌ಗಳು</translation>
<translation id="3981340065784739675">ಅವತಾರ್ ಓವಲ್ Brave</translation>
<translation id="8950124663623888116">ಅವತಾರ್ ಓವಲ್ ಓಷಿಯನ್</translation>
<translation id="1029136880675307651">ಅವತಾರ್ ಓವಲ್ ಗ್ರಾಸ್</translation>
<translation id="3285059582709531888">ಅವತಾರ್ ಓವಲ್ ಕಾರ್ನ್</translation>
<translation id="8540390244071055918">ಅವತಾರ್ ಓವಲ್ ರಾಯಲ್</translation>
<translation id="3435440003463944104">ಅವತಾರ್ ಓವಲ್ ನಿಂಜಾ</translation>
<translation id="4222150638283443362">ಅವತಾರ್ ಬೋನ್‌ಬೋನ್ ರಿವಾರ್ಡ್‌ಗಳು</translation>
<translation id="8888471219870198387">ಅವತಾರ್ ಬೋನ್‌ಬೋನ್ Brave</translation>
<translation id="2883756935342108947">ಅವತಾರ್ ಬೋನ್‌ಬೋನ್ ಓಷಿಯನ್</translation>
<translation id="6280956561199400472">ಅವತಾರ್ ಬೋನ್‌ಬೋನ್ ಗ್ರಾಸ್</translation>
<translation id="5318548116565208315">ಅವತಾರ್ ಬೋನ್‍ಬೋನ್ ಕಾರ್ನ್</translation>
<translation id="1959966725083452288">ಅವತಾರ್ ಬೋನ್‌ಬೋನ್ ರಾಯಲ್</translation>
<translation id="2039034364578911089">ಅವತಾರ್ ಬೋನ್‍ಬೋನ್ ನಿಂಜಾ</translation>
<translation id="154702742922788359">ಓಪನ್ ಕೋಡ್</translation>
<translation id="2249111429176737533">ಟ್ಯಾಬ್‌ ವಿಂಡೊ ತೆರೆಯಿರಿ</translation>
<translation id="7022756207310403729">ಬ್ರೌಸರ್‌ನಲ್ಲಿ ತೆರೆಯಿರಿ</translation>
