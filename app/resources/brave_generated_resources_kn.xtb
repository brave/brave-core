<translation id="7400808612454224939">ಲಿಯೋ AI ಸೆಟ್ಟಿಂಗ್ಸ್‌ ನಿರ್ವಹಿಸಿ</translation>
<translation id="5385064007245738696">LEO AI ಬಗ್ಗೆ</translation>
<translation id="4928988318462976765">ವೆಬ್ ವಿಸ್ತರಣೆಗಳು ಸ್ಟೋರ್</translation>
<translation id="9181207987584064303">ವೆಬ್ ವಿಸ್ತರಣೆಗಳು ಸ್ಟೋರ್‌ನಲ್ಲಿ ವೀಕ್ಷಿಸಿ</translation>
<translation id="3161744659507801211">ಎಚ್ಚರಿಕೆ: ನಿಮ್ಮ ಬ್ರೌಸಿಂಗ್‌ ಇತಿಹಾಸದಲ್ಲಿ ರೆಕಾರ್ಡಿಂಗ್‌ನಿಂದ ವಿಸ್ತರಣೆಗಳನ್ನು ಪಡೆಯುವುದನ್ನು ತಡೆಯಲು Brave ಗೆ ಸಾಧ್ಯವಿಲ್ಲ.</translation>
<translation id="2162109630536601963">ಈ ವಿಸ್ತರಣೆಯು ನೆಟ್‌ವರ್ಕ್ ವಿನಂತಿಗಳನ್ನು ಮಾಡಿದರೆ, ಆಗ Tor ಅಥವಾ ಖಾಸಗಿ ಮೋಡ್ ಅನ್ನು ಅವುಗಳು ಬಳಸುವುದಿಲ್ಲ.</translation>
<translation id="2725327089319971976">ಖಾಸಗಿ ಮೋಡ್‌ ಮತ್ತು Tor ಮೋಡ್‌ನಲ್ಲಿ ಈ ವಿಸ್ತರಣೆಯನ್ನು ನಿಷ್ಕ್ರಿಯಗೊಳಿಸಲು, ಈ ಆಯ್ಕೆಯನ್ನು ಅನ್‌ಸೆಲೆಕ್ಟ್ ಮಾಡಿ.</translation>
<translation id="438106944087726695">ಬ್ರೇವ್‌-ಹೋಸ್ಟೆಡ್</translation>
