<translation id="3719826155360621982">ಮುಖಪುಟ</translation>
<translation id="5448570825852364919">ಖಾಲಿ ಪುಟ</translation>
<translation id="8244387390464017490">ಹೊಸ ಟ್ಯಾಬ್ ಪುಟವನ್ನು ಕಸ್ಟಮೈಸ್ ಮಾಡಿ</translation>
<translation id="7537601449003285327">ಕಾರ್ಯಪಟ್ಟಿಗೆ ಪಿನ್‌ ಮಾಡಿ</translation>
<translation id="7461924472993315131">ಪಿನ್</translation>
<translation id="735832369569964359">ಪಿನ್ ಅನ್ನು ಕ್ಲಿಕ್ ಮಾಡಿ ಮತ್ತು ಮುಂದಿನ Windows ಪ್ರಕಟಣೆಗಳನ್ನು ದೃಢಪಡಿಸಿ</translation>
<translation id="7506648566440714944">Brave ಅನ್ನು ಈಗಾಗಲೇ ಪಿನ್ ಮಾಡಲಾಗಿದೆ</translation>
<translation id="2307973900865360088">ಡಾಕ್‌ನಲ್ಲಿರಿಸಿ</translation>
<translation id="239275665037555969">ಡಾಕ್</translation>
<translation id="4057614912106618659">Brave ಈಗಾಗಲೇ ಡಾಕ್‌ನಲ್ಲಿದೆ</translation>
<translation id="3195845168740336657">ಶೀಲ್ಡ್ಸ್ ಸೆಟ್ಟಿಂಗ್‌ಗಳು</translation>
<translation id="754769152790647708">ಶೀಲ್ಡ್ಸ್ ಸ್ಥಿತಿ</translation>
<translation id="4868109105992358853">ಟ್ರ್ಯಾಕರ್‌ಗಳು, ಜಾಹೀರಾತುಗಳು ಮತ್ತು ಫಿಂಗರ್‌ಪ್ರಿಂಟಿಂಗ್ ಅನ್ನು ಶೀಲ್ಡ್ಸ್ ನಿರ್ಬಂಧಿಸಬಹುದು</translation>
<translation id="5690973901138662477">ಶೀಲ್ಡ್ಸ್ ಅಪ್</translation>
<translation id="4697275813919189958">ಶೀಲ್ಡ್ಸ್ ಡೌನ್</translation>
<translation id="6303294677342628402">ಶೀಲ್ಡ್‌ಗಳು</translation>
<translation id="5128768857590582420">ವೆಬ್ ನಾದ್ಯಂತ‌ ನಿಮ್ಮನ್ನು ಅನುಸರಿಸುವ‌ ಟ್ರ್ಯಾಕರ್‌‌ಗಳು ಹಾಗೂ ಜಾಹೀರಾತುಗಳನ್ನು ನಿರ್ಬಂಧಿಸಿ</translation>
<translation id="2761825942249694703">ಇವು ಡೀಫಾಲ್ಟ್ ಶೀಲ್ಡ್ಸ್ ಸೆಟ್ಟಿಂಗ್‌ಗಳು. ನೀವು ಶೀಲ್ಡ್ಸ್ ಪ್ಯಾನೆಲ್‌ನಲ್ಲಿ ಏನನ್ನಾದರೂ ನಿರ್ದಿಷ್ಟ ಸೈಟಿನಲ್ಲಿ ಬದಲಾಯಿಸದೇ ಇದ್ದಲ್ಲಿ ಅವು ಎಲ್ಲ ವೆಬ್‌ಸೈಟ್‌ಗಳಿಗೆ ಅನ್ವಯಿಸುತ್ತವೆ. ಇವುಗಳನ್ನು ಬದಲಾಯಿಸುವುದು ನಿಮ್ಮ ಸದ್ಯದ ಪ್ರತಿ ಸೈಟಿನ ಸೆಟ್ಟಿಂಗ್‌‌ಗಳನ್ನು ಪ್ರಭಾವಿಸುವುದಿಲ್ಲ.</translation>
<translation id="8452536890042542134">ಇದು ವೆಬ್‌ಸೈಟ್‌ಗಳಲ್ಲಿ ಹೆಚ್ಚಿನ ಜಾಹೀರಾತುಗಳನ್ನು ನಿರ್ಬಂಧಿಸುತ್ತದೆ.</translation>
<translation id="4800195524776354947">ಶೀಲ್ಡ್‌ಗಳ ಐಕಾನ್‌ನಲ್ಲಿ ನಿರ್ಬಂಧಿಸಲಾದ ಐಟಂಗಳ ಸಂಖ್ಯೆಯನ್ನು ತೋರಿಸಿ</translation>
<translation id="5510493033031835532">AMP ಪೇಜ್‌ಗಳನ್ನು ಸ್ವಯಂ ಮರುನಿರ್ದೇಶನಗೊಳಿಸಿ</translation>
<translation id="7630031867325944356">AMP ಮತ್ತು ಅಂತಹುದೇ ಆವೃತ್ತಿಗಳ ಬದಲಿಗೆ ಪ್ರಕಾಶಕರ ಪುಟ URL ಗಳಿಗೆ ಆದ್ಯತೆ ನೀಡಿ.</translation>
<translation id="920638232916443453">URL ಗಳನ್ನು ಟ್ರ್ಯಾಕ್ ಮಾಡುವುದನ್ನು ಸ್ವಯಂ-ಮರುನಿರ್ದೇಶಿಸಿ</translation>
<translation id="1118970888826017401">ಪ್ರಮುಖ-ಮಟ್ಟದ ಮರುನಿರ್ದೇಶನ ಟ್ರ್ಯಾಕಿಂಗ್ URL ಗಳನ್ನು ಬೈಪಾಸ್ ಮಾಡುವುದಕ್ಕಾಗಿ ಬೆಂಬಲವನ್ನು ಸಕ್ರಿಯಗೊಳಿಸಿ.</translation>
<translation id="7607166182943595829">ನನ್ನ ಭಾಷೆಯ ಆದ್ಯತೆಗಳ ಆಧಾರದಲ್ಲಿ ನನ್ನನ್ನು ಫಿಂಗರ್‌ಪ್ರಿಂಟ್ ಮಾಡದಂತೆ ಸೈಟ್‌ಗಳನ್ನು ತಡೆಯಿರಿ</translation>
<translation id="1940747376931821321">ಈ ಸೆಟ್ಟಿಂಗ್ ಅನ್ನು ಸಕ್ರಿಯಗೊಳಿಸುವುದರಿಂದ ನಿಮ್ಮ ಭಾಷೆ ಆದ್ಯತೆಗಳನ್ನು ಎಷ್ಟು ವೆಬ್ ಸೈಟ್‌ಗಳು ತಿಳಿದುಕೊಳ್ಳಬಹುದು ಎಂಬುದು ಕಡಿಮೆಯಾಗುತ್ತದೆ.</translation>
<translation id="2133317862976486547">ಟ್ರ್ಯಾಕರ್‌ಗಳು &amp; ಜಾಹೀರಾತುಗಳನ್ನು ನಿರ್ಬಂಧಿಸಲಾಗಿದೆ</translation>
<translation id="4078738236287221428">ಆಕ್ರಮಣಕಾರಿ</translation>
<translation id="7740996059027112821">ಪ್ರಮಾಣಿತ</translation>
<translation id="4824468494729001999">ನಿರ್ಬಂಧಿತ ಲಿಪಿಗಳು</translation>
<translation id="6531019308847917584">ಫಿಂಗರ್‌ಪ್ರಿಂಟಿಂಗ್‌ ನಿರ್ಬಂಧಿಸಿ</translation>
<translation id="5533533363827555308">ಕಟ್ಟುನಿಟ್ಟಾದ, ಸೈಟ್‌ಗಳನ್ನು ವಿಂಗಡಿಸಬಹುದು</translation>
<translation id="3570081523466826008">HTTPS ಗೆ ಸಂಪರ್ಕಗಳನ್ನು ಮೇಲ್ದರ್ಜೆಗೇರಿಸಿ</translation>
<translation id="3357319404342882895">ಸ್ಟ್ರಿಕ್ಟ್</translation>
<translation id="8823559166155093873">ಕುಕೀಗಳನ್ನು ನಿರ್ಬಂಧಿಸಿ</translation>
<translation id="7093267802941377072">"ಎಲ್ಲ ಕುಕೀಗಳನ್ನು ನಿರ್ಬಂಧಿಸುವ" ಆಯ್ಕೆಗೆ ಸಮ್ಮತಿ ನೀಡಿಲ್ಲ. ಈ ಆಯ್ಕೆಯನ್ನು ಒತ್ತಾಯ ಪೂರ್ವಕವಾಗಿ ಸಕ್ರಿಯಗೊಳಿಸುವುದು ಹೇಗೆ ಎಂದು ತಿಳಿಯಲು, <ph name="BEGIN_LINK"/>ನಮ್ಮ ಸಹಾಯ ಪುಟಕ್ಕೆ<ph name="END_LINK"/></translation>
<translation id="6196640612572343990">ಥರ್ಡ್ ಪಾರ್ಟಿ ಕುಕೀಗಳನ್ನು ನಿರ್ಬಂಧಿಸಿ</translation>
<translation id="5657156137487675418">ಎಲ್ಲಾ ಕುಕೀಗಳನ್ನು ಅನುಮತಿಸಿ</translation>
<translation id="6883611015375728278">ಎಲ್ಲಾ ಕುಕೀಗಳನ್ನು ನಿರ್ಬಂಧಿಸಿ</translation>
<translation id="7390783310074170337">ಡೀಫಾಲ್ಟ್ ವೀಕ್ಷಣೆ</translation>
<translation id="130615081792797568">ಸರಳ ವೀಕ್ಷಣೆ</translation>
<translation id="2360360976480535628">ಸುಧಾರಿತ ವೀಕ್ಷಣೆ</translation>
<translation id="101592339984642584">ವಿಷಯ ಫಿಲ್ಟರಿಂಗ್</translation>
<translation id="2398817776566547893">ಪ್ರಾದೇಶಿಕ ಮತ್ತು ಭಾಷೆ-ನಿರ್ದಿಷ್ಟ ಟ್ರ್ಯಾಕರ್‌ಗಳು ಮತ್ತು ಅಹಿತಕರ ಸಂಗತಿಗಳನ್ನು ನಿರ್ಬಂಧಿಸುವ ಕಸ್ಟಮ್ ಫಿಲ್ಟರ್‌ಗಳನ್ನು ಸಕ್ರಿಯಗೊಳಿಸಿ</translation>
<translation id="3482656215021340727">ಕಸ್ಟಮ್ ಫಿಲ್ಟರ್ ಪಟ್ಟಿಗಳನ್ನು ಸೇರಿಸಿ</translation>
<translation id="1020877116991797978">ನಿಮ್ಮ ವಿಶ್ವಾಸಾರ್ಹ ಸಮುದಾಯವು ರಚಿಸಿದ ಮತ್ತು ನಿರ್ವಹಣೆ ಮಾಡಿದ ಹೆಚ್ಚುವರಿ ಪಟ್ಟಿಗಳನ್ನು ಸೇರಿಸಿ.</translation>
<translation id="7617831480435794399">ನೀವು ನಂಬುವ ಸಂಸ್ಥೆಗಳ ಪಟ್ಟಿಗಳಿಗೆ ಮಾತ್ರ ಚಂದಾದಾರರಾಗಿ. ನೀವು ನಮೂದಿಸುವ URL ನಿಂದ ಪಟ್ಟಿ ಅಪ್‌ಡೇಟ್‌ಗಳಿಗೆ ನಿಮ್ಮ ಬ್ರೌಸರ್ ನಿಯತಕಾಲಿಕವಾಗಿ ಪರಿಶೀಲಿಸುತ್ತದೆ ಮತ್ತು ಈ ಮೂಲಕ ಅದರ ಸರ್ವರ್‌ಗೆ ನಿಮ್ಮ IP ವಿಳಾಸವನ್ನು ಬಹಿರಂಗಪಡಿಸುತ್ತದೆ.</translation>
<translation id="8580328754808744073">ಕಸ್ಟಮ್ ಫಿಲ್ಟರ್‌ಗಳನ್ನು ರಚಿಸಿ</translation>
<translation id="4618274268052410139">ಕೆಳಗಿನ ಕ್ಷೇತ್ರದಲ್ಲಿ, ಪ್ರತಿ ಸಾಲಿಗೆ ಒಂದರಂತೆ, ನೀವು ರಚಿಸಿದ ಕಸ್ಟಮ್ ಫಿಲ್ಟರ್‌ಗಳನ್ನು ಸೇರಿಸಿ. <ph name="BEGIN_LINK"/>ಜಾಹೀರಾತು ನಿರ್ಬಂಧ ಫಿಲ್ಟರ್ ಸಿಂಟಾಕ್ಸ್<ph name="END_LINK"/> ಬಳಸುವುದನ್ನು ಖಚಿತಪಡಿಸಿಕೊಳ್ಳಿ.</translation>
<translation id="7791543448312431591">ಸೇರಿಸು</translation>
<translation id="3075903430639801825">ಪಟ್ಟಿ ಶೀರ್ಷಿಕೆ</translation>
<translation id="9204006549413740506">ಕೊನೆಯದಾಗಿ ಅಪ್‌ಡೇಟ್ ಮಾಡಿರುವುದು</translation>
<translation id="6745592621698551453">ಈಗ ಅಪ್‌ಡೇಟ್‌ ಮಾಡು</translation>
<translation id="5334844597069022743">ಮೂಲ ವೀಕ್ಷಿಸಿ</translation>
<translation id="4720556299488643018">ಅನ್‌ಸಬ್‌ಸ್ಕ್ರೈಬ್ ಮಾಡಿ</translation>
