<translation id="6873781976650514089">ಈ ಸೆಟ್ಟಿಂಗ್</translation>
<translation id="4684633335323013758">ನಿಮ್ಮ <ph name="PART_ONE"/>ಸಾಮಾನ್ಯ ಸ್ಥಳ<ph name="PART_ONE_END"/>ಕ್ಕೆ ಈ ಸೈಟ್ ವಿನಂತಿಸಿದೆ. <ph name="PART_TWO"/>ಹೆಚ್ಚು ತಿಳಿಯಿರಿ<ph name="PART_TWO_END"/></translation>
<translation id="8117247596084706514">ನಿಮ್ಮ <ph name="PART_ONE"/>ನಿಖರ ಸ್ಥಳ<ph name="PART_ONE_END"/>ಕ್ಕೆ ಈ ಸೈಟ್ ವಿನಂತಿಸಿದೆ. <ph name="PART_TWO"/>ಹೆಚ್ಚು ತಿಳಿಯಿರಿ<ph name="PART_TWO_END"/></translation>
<translation id="5486652646100591203">ನಿಮ್ಮ <ph name="PART_ONE"/>ನಿಖರ ಸ್ಥಳ<ph name="PART_ONE_END"/>ಕ್ಕೆ ಈ ಸೈಟ್ ವಿನಂತಿಸಿದೆ. <ph name="PART_THREE"/>ಸ್ಥಳ ಸೇವೆಗಳು<ph name="PART_THREE_END"/> ಅನ್ನು ನಿಷ್ಕ್ರಿಯಗೊಳಿಸಿರುವ ಕಾರಣದಿಂದ <ph name="PART_TWO"/>ಸಾಮಾನ್ಯ ಸ್ಥಳ<ph name="PART_TWO_END"/> ಡೇಟಾ ಒದಗಿಸಲು ಮಾತ್ರ Brave ಗೆ ಸಾಧ್ಯವಾಗುತ್ತದೆ. <ph name="PART_FOUR"/>ಹೆಚ್ಚು ತಿಳಿಯಿರಿ<ph name="PART_FOUR_END"/></translation>
<translation id="8915916167043355778">ಎಲ್ಲವನ್ನೂ ಮುಚ್ಚಿ</translation>
<translation id="4870911314065352661">ಎಲ್ಲಾ ಟ್ಯಾಬ್‌ಗಳನ್ನು ಮುಚ್ಚುವುದೇ?</translation>
<translation id="7551864359422178684">ಈ ಬ್ರೌಸರ್ ವಿಂಡೋದಲ್ಲಿ ನೀವು <ph name="NUMBER_OF_TABS"/> ಟ್ಯಾಬ್‌ಗಳನ್ನು ತೆರೆದಿರುವಿರಿ.</translation>
<translation id="2571596981920752023"><ph name="NUMBER_OF_TABS"/> ಟ್ಯಾಬ್‌ಗಳು</translation>
<translation id="1307431692088049276">ನನಗೆ ಮತ್ತೊಮ್ಮೆ ಕೇಳಬೇಡ</translation>
<translation id="6919364924256365253">ಅದನ್ನು Google ಮಾಡಬೇಡಿ. ಅದನ್ನು Bing ಮಾಡಬೇಡಿ. ಕೇವಲ ಅದನ್ನು Brave ಮಾಡಿ.</translation>
<translation id="2640297688005939449">Brave ಹುಡುಕಾಟವು ನಿಮ್ಮನ್ನು ಪ್ರೊಫೈಲ್ ಮಾಡುವುದಿಲ್ಲ. ಮತ್ತು ಇದು 100% ಸ್ವತಂತ್ರವಾಗಿದೆ.</translation>
<translation id="7295094278358921487">ಹುಡುಕಿ ಮತ್ತು ನಿಮಗೆ ಕಂಡುಬರುತ್ತದೆ. ಖಾಸಗಿಯಾಗಿ.</translation>
<translation id="3462465068145800637">Brave ಹುಡುಕಾಟವು ನಿಮ್ಮನ್ನು ಪ್ರೊಫೈಲ್ ಮಾಡುವುದಿಲ್ಲ. ಮತ್ತು ಇದು ಬಿಗ್ ಟೆಕ್‌ನಿಂದ 100% ಸ್ವತಂತ್ರವಾಗಿದೆ.</translation>
<translation id="42032117189492785">ಅನನ್ಯ ಇಂಡೆಕ್ಸ್ ಮೂಲಕ AI-ಇನ್‌ಫ್ಯೂಸ್ ಮಾಡಲಾದ ಹುಡುಕಾಟ.</translation>
<translation id="8606416238399082160">ಸಂಪೂರ್ಣವಾಗಿ ಖಾಸಗಿ, 100% ಸ್ವತಂತ್ರ ಮತ್ತು ಅತ್ಯುತ್ತಮ AI ವೈಶಿಷ್ಟ್ಯಗಳೊಂದಿಗೆ.</translation>
<translation id="4381193110021038941">ಉತ್ತಮ ಫಲಿತಾಂಶಗಳನ್ನು ಪಡೆಯಿರಿ</translation>
<translation id="3846545273704969734">Bing ಗಿಂತ (ಅಥವಾ DuckDuckGo ನಂತಹ Bing ಕ್ಲೋನ್‌ಗಳು) Brave ಉತ್ತಮ ಫಲಿತಾಂಶಗಳನ್ನು ಹೊಂದಿರುವುದಾಗಿ ಸ್ವತಂತ್ರವಾಗಿ ಖಚಿತಪಡಿಸಿಕೊಳ್ಳಲಾಗಿದೆ.</translation>
<translation id="2841164160723712537">ಹುಡುಕಾಟ ಫಲಿತಾಂಶಗಳನ್ನು ಸುಧಾರಿಸಿ</translation>
<translation id="4639001639513524869">ಹೆಚ್ಚಿನ ಪ್ರಶ್ನೆಗಳಿಗೆ DuckDuckGo ಗಿಂತ Brave ಹುಡುಕಾಟ ಉತ್ತಮ ಫಲಿತಾಂಶಗಳನ್ನು ಹೊಂದಿದೆ. ಮತ್ತು ಅದು ನಿಜವಾಗಿಯೂ ಖಾಸಗಿಯಾಗಿದೆ.</translation>
<translation id="5240031343741051161">Brave ಹುಡುಕಾಟ ಪ್ರಯತ್ನಿಸಿ ನೋಡಿ</translation>
<translation id="5234764350956374838">ವಜಾಗೊಳಿಸಿ</translation>
<translation id="8722651357687610395">Brave ಅನ್ನು ಡಿಫಾಲ್ಟ್ ಆಗಿ ಹೊಂದಿಸಿ</translation>
<translation id="2370739752330685659">ಬಹುಶಃ ನಂತರ</translation>
<translation id="5100490448228945668">Brave ಹುಡುಕಾಟ ಪರಿವರ್ತನೆಯನ್ನು ವಜಾಗೊಳಿಸಿ, ಈ ಸಲಹೆಯನ್ನು ತೆಗೆದುಹಾಕಲು ಎಂಟರ್ ಒತ್ತಿ</translation>
<translation id="6213208892248046484">Brave ಸರ್ಚ್‌ಗೆ ಬದಲಿಸಿ</translation>
<translation id="9194637241566114638">ಅನಾಮಧೇಯ ಬಳಕೆಯ ಡೇಟಾ ಕಳುಹಿಸುವ ಮೂಲಕ <ph name="SEARCH_NAME"/> ಸುಧಾರಿಸಲು ಸಹಾಯ ಮಾಡಿ. <ph name="MORE_INFO"/></translation>
<translation id="7404610376221341525">Brave ಹುಡುಕಾಟ</translation>
<translation id="8184318863960255706">ಹೆಚ್ಚಿನ ಮಾಹಿತಿ</translation>
<translation id="780301667611848630">ಬೇಡ, ಧನ್ಯವಾದಗಳು</translation>
<translation id="1162706247109707219">ಓಕೆ ಕ್ಲಿಕ್ ಮಾಡುವ ಮೂಲಕ, ನೀವು Windows 10 ಅಥವಾ ನಂತರದ್ದಕ್ಕೆ ನೀವು ಅಪ್‌ಡೇಟ್ ಮಾಡುವ ತನಕ ಗಂಭೀರ ಭದ್ರತೆ ಸರಿಪಡಿಸುವಿಕೆಗಳನ್ನು Brave ನ ನಿಮ್ಮ ಸ್ಥಾಪನೆಯು ಸ್ವೀಕರಿಸುವುದಿಲ್ಲ. ಈ ಎಚ್ಚರಿಕೆಯನ್ನು ಮತ್ತೊಮ್ಮೆ ತೋರಿಸಲಾಗುವುದಿಲ್ಲ.</translation>
<translation id="9164786361657554526">ಓಕೆ ಕ್ಲಿಕ್ ಮಾಡುವ ಮೂಲಕ, ನೀವು macOS 10.15 ಅಥವಾ ನಂತರದ್ದಕ್ಕೆ ನೀವು ಅಪ್‌ಡೇಟ್ ಮಾಡುವ ತನಕ ಗಂಭೀರ ಭದ್ರತೆ ಸರಿಪಡಿಸುವಿಕೆಗಳನ್ನು Brave ನ ನಿಮ್ಮ ಸ್ಥಾಪನೆಯು ಸ್ವೀಕರಿಸುವುದಿಲ್ಲ. ಈ ಎಚ್ಚರಿಕೆಯನ್ನು ಮತ್ತೊಮ್ಮೆ ತೋರಿಸಲಾಗುವುದಿಲ್ಲ.</translation>
<translation id="6020553119523541665">ಮತ್ತೊಂದು ವಿಂಡೋದಲ್ಲಿ ಈ ಟ್ಯಾಬ್ ಸಕ್ರಿಯವಾಗಿದೆ</translation>
<translation id="4987392683074136770">ಈ ಟ್ಯಾಬ್ ಕ್ಲಿಕ್ ಮಾಡುವುದರಿಂದ ಅದರ ವಿಷಯಗಳು ಈ ವಿಂಡೋಗೆ ಬರುತ್ತವೆ</translation>
<translation id="8355523213948477234">ಸ್ಪ್ಲಿಟ್ ವೀಕ್ಷಣೆ ಮೆನು ಬಟನ್</translation>
<translation id="6040143037577758943">ಮುಚ್ಚಿ</translation>
<translation id="6665472986740899785">Brave ಅಧಿಸೂಚನೆ ಜಾಹೀರಾತು</translation>
<translation id="5582087890067572966">🎉 ನೀವು ಇದೀಗ ಗಳಿಸುತ್ತಿರುವಿರಿ!</translation>
<translation id="4364336119478610380">ಇಂತಹ ನೋಟಿಫಿಕೇಶನ್ ನಿಮ್ಮ ಸ್ಕ್ರೀನ್‌ನಲ್ಲಿ ಗೋಚರಿಸಿದಾಗಲೆಲ್ಲಾ ನೀವು ಗಳಿಸುತ್ತೀರಿ. ಗಳಿಸುವುದಕ್ಕಾಗಿ ನೀವು ಕ್ಲಿಕ್ ಮಾಡುವ ಅಗತ್ಯವಿಲ್ಲ.</translation>
<translation id="5893017172751072752">Brave ಜಾಹೀರಾತುಗಳ ನೋಟಿಫಿಕೇಶನ್ ಗೋಚರಿಸಿದಾಗ ನೀವು ಗಳಿಸುತ್ತೀರಿ</translation>
<translation id="3447730462826640312">ಗಳಿಸಲು ನೀವು ಕ್ಲಿಕ್ ಮಾಡಬೇಕಾಗಿಲ್ಲ, ಆದರೆ ನೀವು ಆಸಕ್ತಿ ಹೊಂದಿದ್ದರೆ ಕ್ಲಿಕ್ ಮಾಡಿ!</translation>
<translation id="5253166205743627564">ಖಾಸಗಿ ಜಾಹೀರಾತನ್ನು ಕ್ಲಿಕ್ ಮಾಡುವ ಮೂಲಕ ಬ್ರೇವ್ ಸರ್ಚ್‌ನ್ನು ಬೆಂಬಲಿಸಿದ್ದಕ್ಕಾಗಿ ಧನ್ಯವಾದಗಳು. ಬಿಗ್ ಟೆಕ್‌ಗಿಂತ ಭಿನ್ನವಾಗಿ, ನಿಮ್ಮ ಗೌಪ್ಯತೆಯನ್ನು ಕಾಪಾಡಲು ನಾವು ಜಾಹೀರಾತು ಕಾರ್ಯಕ್ಷಮತೆಯನ್ನು ಅನಾಮಧೇಯವಾಗಿ ಅಳೆಯುತ್ತೇವೆ.</translation>
<translation id="8748471354357836070">ಇನ್ನಷ್ಟು ತಿಳಿಯಿರಿ / ಆಯ್ಕೆಗಳಿಂದ ಹೊರಗುಳಿಯಿರಿ</translation>
<translation id="5927196110206824867">ಪ್ರಾಯೋಜಿತ ಬ್ಯಾಕ್‌ ಗ್ರೌಂಡ್‌ ಚಿತ್ರಗಳು ಸ್ವತಂತ್ರ ಧ್ಯೇಯವನ್ನು ಬೆಂಬಲಿಸುತ್ತವೆ. ಯೂಸರ್‌ ಫಸ್ಟ್‌ ವೆಬ್‌ ಪ್ರಧಾನ. ಬಿಗ್ ಟೆಕ್‌ಗಿಂತ ಭಿನ್ನವಾಗಿ, ನಿಮ್ಮ ಗೌಪ್ಯತೆಯನ್ನು ಕಾಪಾಡುತ್ತೇವೆ. ಜಾಹೀರಾತು ಕಾರ್ಯಕ್ಷಮತೆಯನ್ನು ಅನಾಮಧೇಯವಾಗಿ ಅಳೆಯುತ್ತೇವೆ.</translation>
<translation id="4174337572777167894">ವೆಬ್ ಅನ್ವೇಷಣೆ ಪ್ರಾಜೆಕ್ಟ್</translation>
<translation id="8659271182272561965">Brave ಹುಡುಕಾಟ ಸುಧಾರಿಸುವುದಕ್ಕಾಗಿ ಕೆಲವು ಅನಾಮಧೇಯ ಹುಡುಕಾಟ &amp; ಬ್ರೌಸಿಂಗ್ ಡೇಟಾದ ಕೊಡುಗೆ ನೀಡಿ.</translation>
<translation id="1516554614404600536">Brave ಟೂಲ್‌ಟಿಪ್</translation>
<translation id="4375473250631001683">ಸೈಡ್‌ಬಾರ್ ಐಕಾನ್ ಮರೆಮಾಡಿ</translation>
<translation id="2613033293035359003">ಸೈಡ್‌ಬಾರ್ ಮರೆಮಾಡಿ</translation>
<translation id="4233010476457917696">ಸೈಡ್‌ಬಾರ್ ತೋರಿಸಿ</translation>
<translation id="7829322605042304637">ಸೈಡ್‌ಬಾರ್ ಐಕಾನ್ ಮರೆಮಾಡಿ</translation>
<translation id="7349915168363514678">ಸೈಡ್‌ಬಾರ್ ಮರೆಮಾಡಿ</translation>
<translation id="5404213409401164238">ಸೈಡ್‌ಬಾರ್ ತೋರಿಸಿ</translation>
