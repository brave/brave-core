<translation id="2776571540844891267">ಪಟ್ಟಿಗಳನ್ನು ಅಪ್‌ಡೇಟ್ ಮಾಡಿ</translation>
<translation id="7424267932649051704">ಅಪ್‌ಡೇಟ್ ವಿಫಲವಾಗಿದೆ - ಮರುಪ್ರಯತ್ನಿಸಿ</translation>
<translation id="8426801388284487512">ಪಟ್ಟಿಗಳನ್ನು ಅಪ್‌ಡೇಟ್ ಮಾಡಲಾಗಿದೆ</translation>
<translation id="3422250445565385437">ಪಟ್ಟಿಗಳು ಅಪ್‌ಡೇಟ್ ಆಗುತ್ತಿವೆ</translation>
<translation id="1340263054776016283">ಫಿಲ್ಟರ್ ಪಟ್ಟಿ URL ನಮೂದಿಸಿ</translation>
