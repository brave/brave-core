<translation id="5524306331330789642">ಹೊಸ ಸ್ಕ್ರಿಪ್ಟ್‌ಲೆಟ್ ಸೇರಿಸಿ</translation>
<translation id="3865146371459790194">ಸ್ಕ್ರಿಪ್‌ಲೆಟ್‌ ಎಡಿಟ್‌ ಮಾಡಿ</translation>
<translation id="5584409054843451563">ಈ ಸ್ಕ್ರಿಪ್ಟ್‌ಲೆಟ್‌ನ್ನು ಅಳಿಸಲು ಖಚಿತವಾಗಿ ಬಯಸುವಿರಾ? ಈ ಸ್ಕ್ರಿಪ್ಟ್‌ಲೆಟ್‌ನ್ನು ಯಾವುದೇ ಕಸ್ಟಮ್ ಫಿಲ್ಟರ್‌ನಲ್ಲಿ ಬಳಸಿದರೆ, ಅದು ಇನ್ನು ಮುಂದೆ ಕಾರ್ಯ ನಿರ್ವಹಿಸುವುದಿಲ್ಲ.</translation>
<translation id="4545850500562727184">ಸ್ಕ್ರಿಪ್‌ಲೆಟ್‌ ಈಗಾಗಲೇ ಅಸ್ತಿತ್ವದಲ್ಲಿದೆ.</translation>
<translation id="4877521822848390663">ಸ್ಕ್ರಿಪ್ಟ್‌ಲೆಟ್ ಹೆಸರು ಅಮಾನ್ಯವಾಗಿದೆ.</translation>
<translation id="2718718846210516552">ಸ್ಕ್ರಿಪ್ಟ್‌ಲೆಟ್‌ ಕಾಣುತ್ತಿಲ್ಲ.</translation>
<translation id="4088315951291671239">ನಿಮಗೆ ಅರ್ಥವಾಗದ ಅಥವಾ ನೀವೇ ಪರಿಶೀಲಿಸದ ಕೋಡ್‌ನ್ನು ಇಲ್ಲಿ ಪೇಸ್ಟ್‌ ಮಾಡಬೇಡಿ. ಸೈಬರ್‌ ಅಟ್ಯಾಕರ್ಸ್‌ ನಿಮ್ಮ ಗುರುತನ್ನು ಕದಿಯಲು ಅಥವಾ ನಿಮ್ಮ ಕಂಪ್ಯೂಟರ್‌ನ ನಿಯಂತ್ರಣವನ್ನು ತೆಗೆದುಕೊಳ್ಳಲು ಇದು ಅನುಮತಿಸುವ ಅಪಾಯವಿದೆ.</translation>
<translation id="3020183492814296499">ಶಾರ್ಟ್‌ಕಟ್‌ಗಳು</translation>
<translation id="2935698011275148880">Brave Origin</translation>
<translation id="2587535830241068901">ನೀವು Brave ಅನ್ನು ಬೆಂಬಲಿಸುತ್ತಲೇ ನಿಮ್ಮ ಬ್ರೌಸರ್ ಅನ್ನು ಅನುಭವಕ್ಕೆ ತಕ್ಕಂತೆ ಕಸ್ಟಮೈಸ್ ಮಾಡಿ</translation>
<translation id="553273341094971255">Brave Origin ನಿಮಗಿಷ್ಟವಾದಂತೆ Brave ಅನ್ನು ಹೊಂದಿಸಲು ಸಹಾಯ ಮಾಡುತ್ತದೆ ಮತ್ತು ಎಲ್ಲ ಇನ್-ಆಪ್ ಪ್ರಚಾರ ಕೊಡುಗೆಗಳು, ಬ್ರ್ಯಾಂಡ್ ಮಾಡಿದ ಜಾಹೀರಾತುಗಳು ಹಾಗು ನಿಮ್ಮಿಂದ ಸ್ಥಾಪನೆಯ ಸಮಯದಲ್ಲಿ ಸಕ್ರಿಯಗೊಳಿಸಬಹುದಾದ ಅನಾಮಧೇಯ ವಿಶ್ಲೇಷಣೆಯನ್ನು ತೆಗೆದುಹಾಕುತ್ತದೆ.</translation>
<translation id="534725333104202278">ನೀವು ಹಿಂದಿನದಾಗಿ ಸಕ್ರಿಯಗೊಳಿಸಿದ್ದ ಅಥವಾ ಬಳಸದಿರುವ ಯಾವುದೇ ಆಡ್-ಆನ್‌ಗಳು ಅಥವಾ ವೈಶಿಷ್ಟ್ಯಗಳು ಕಾಣಬರುತ್ತವೆ ಮತ್ತು ಸಂಯೋಜಿತವಾಗಿರುತ್ತವೆ, ಉಳಿದವುಗಳನ್ನು ಅಶಕ್ತಗೊಳಿಸಲಾಗುತ್ತದೆ. Brave ಗೆ ನಾವು ಹೊಸ ವೈಶಿಷ್ಟ್ಯಗಳನ್ನು ತರುವಾಗ ನೀವು ಅದನ್ನು ಹೊಂದಿಸುತ್ತ ಮುಂದುವರಿಯಿರಿ. ಇವು Brave Origin ನ ನಿಯಂತ್ರಣ ಫಲಕದಲ್ಲಿ ಮೌನವಾಗಿ ಮತ್ತು ಮರೆಮಾಡಲ್ಪಟ್ಟ ರೀತಿಯಲ್ಲಿ ಪ್ರಬಲಗೊಳ್ಳುತ್ತವೆ.</translation>
<translation id="1919345977826869612">ಜಾಹೀರಾತುಗಳು</translation>
<translation id="944736176598169208">ರಿವಾರ್ಡ್‌ಗಳು</translation>
<translation id="2839742394543397416">ವಿಶ್ಲೇಷಣೆಗಳು</translation>
<translation id="1799030480311994998">ವೈಶಿಷ್ಟ್ಯಗಳು</translation>
<translation id="6709133671862442373">ಸುದ್ದಿ</translation>
<translation id="6297791103122079275">ಮಾತನಾಡಿ</translation>
<translation id="1458638489455808030">Wayback Machine</translation>
<translation id="1199170151481311646">ಗೌಪ್ಯತೆ ಕಾಯ್ದುಕೊಳ್ಳುವ ವಿಶ್ಲೇಷಣೆ</translation>
<translation id="5990642573624858459">ಅಂಕಿಅಂಶ ವರದಿ</translation>
<translation id="2441719842399509963">ಎಲ್ಲವನ್ನೂ ಡೀಫಾಲ್ಟ್‌ಗಳಿಗೆ ಮರುಹೊಂದಿಸಿ</translation>
<translation id="4530494379350999373">ಮೂಲ</translation>
<translation id="2964215604640804042">Brave Origin ಎಂದರೆ ಬ್ರೌಜರ್‌ನ ಪೇಯ್‌ಡ್ ಆವೃತ್ತಿ, ಅದು ಬ್ರೇವ್‌ನನ್ನು ವ್ಯವಹಾರವಾಗಿ ಬೆಂಬಲಿಸುವ ಎಲ್ಲಾ ವೈಶಿಷ್ಟ್ಯಗಳ ಅಗತ್ಯವಿಲ್ಲದ ಬಳಕೆದಾರರಿಗೆ, ಆದರೆ ಇನ್ನೂ ಬ್ರೇವ್ ಮಾತ್ರ ನೀಡುವ ಗೌಪ್ಯತೆ ಬಯಸುತ್ತಾರೆ. Brave Origin ಬಳಕೆದಾರರು ನಮ್ಮ ಶಿಲ್ಪ-ನೇತೃತ್ವಾಧೀನ ಗೌಪ್ಯತೆ, ಆಧ್ಯಾಪಕ, ಮತ್ತು ವೇಗ (Brave ಶೀಲ್ಡ್ಸ್‌ ಮೂಲಕ), ಹಾಗೆಯೇ ನಿಯಮಿತ ಸಾಫ್ಟ್‌ವೇರ್ ನವೀಕರಣಗಳು, Chromium ಪ್ಯಾಚ್‌ಗಳು, ಮತ್ತು ಸುರಕ್ಷತೆ ಮತ್ತು ಗೌಪ್ಯತೆ ಸುಧಾರಣೆಗಳಿಂದ ಲಾಭ ಪಡೆಯುವುದನ್ನು ಮುಂದುವರಿಸುತ್ತಾರೆ. ಅವರು ಕೃತ್ರಿಮ ಬುದ್ಧಿಮತ್ತೆ, ರಿವಾರ್ಡ್‌ಗಳು, ವಾಲೆಟ್, VPN, Web3 ಡೊಮೇನ್‌ಗಳು, ಮತ್ತು ಹೆಚ್ಚಿನವುಗಳಂತಹ ವೈಶಿಷ್ಟ್ಯಗಳನ್ನು ನಿಷ್ಕ್ರಿಯಗೊಳಿಸುವ ಆಯ್ಕೆಯನ್ನೂ ಅನ್ಲಾಕ್ ಮಾಡುತ್ತಾರೆ.</translation>
<translation id="9130916892338379417">Brave Origin ಒಂದು ಬಾರಿ ಖರೀದಿಯ ಮೂಲಕ ಲಭ್ಯವಿದೆ. ಮೊಬೈಲ್ (Android ಮತ್ತು iOS) ಮತ್ತು ಡೆಸ್ಕ್ಟಾಪ್‌ನಲ್ಲಿ, Origin ನಿಮ್ಮ ಅಸ್ತಿತ್ವದ ರಿಲೀಸ್ ಆವೃತ್ತಿಗೆ ಅಪ್‌ಗ್ರೇಡ್ ಆಗಿ ಖರೀದಿಸಬಹುದು. ಡೆಸ್ಕ್ಟಾಪ್‌ನಲ್ಲಿ, Origin ಎಂಬುದು ಪ್ರತ್ಯೇಕ, ಸ್ವತಂತ್ರ ಅಪ್ಲಿಕೇಶನವಾಗಿಯೂ ಲಭ್ಯವಿದೆ. Origin ಬಳಕೆದಾರರು Settings ಮೆನುವಿನಲ್ಲಿ ಹೊಸ ನಿಯಂತ್ರಣ ಫಲಕ ನೋಡುವರು. ಅಸ್ತಿತ್ವದ ವೈಶಿಷ್ಟ್ಯಗಳು—ಹಾಗೆಯೇ ಭವಿಷ್ಯತ್ತಿನಲ್ಲಿ ನಾವು ರವಾನಿಸುವ ಯಾವುದೇ ನೂತನ ವೈಶಿಷ್ಟ್ಯಗಳು—ಇಲ್ಲಿ ಕಾಣಿಸುತ್ತವೆ, ಮತ್ತು ಡಿಫಾಲ್ಟ್ ಆಗಿ ಸ್ವಿಚ್ ಆಫ್ ಆಗುತ್ತವೆ.</translation>
<translation id="7984508421152399880">ಈಗಿನ್ನೇ ಖರೀದಿಸಿ</translation>
<translation id="5567412479632285879">Brave ರಿವಾರ್ಡ್ಸ್ ಅನ್ನು ನಿಷ್ಕ್ರಿಯಗೊಳಿಸಲಾಗಿದೆ</translation>
<translation id="413570371620795359">ಸಕ್ರಿಯಗೊಳಿಸಲು ಮತ್ತು ಪ್ರಾರಂಭಿಸಲು ಬಹುಮಾನಗಳ ಫಲಕವನ್ನು ತೆರೆಯಿರಿ</translation>
<translation id="1051600834033686945">ಸಂಪೂರ್ಣ Brave Rewards ಸೆಟ್ಟಿಂಗ್‌ಗಳನ್ನು ತೆರೆಯಿರಿ</translation>
<translation id="8826461509529116322">Brave ರಿವಾರ್ಡ್ಸ್ ಬಟನ್ ತೋರಿಸಿ</translation>
<translation id="4859866966646365361">ಜಾಹೀರಾತು ತಡೆ ಮಾತ್ರ ಇರುವ ಮೋಡ್</translation>
<translation id="4146834954839563870">ಜಾಹೀರಾತು ತಡೆ ಮಾತ್ರ ಇರುವ ಮೋಡ್ ಅನ್ನು ಬಳಸಿ</translation>
<translation id="420732343671200734">ಜಾಹೀರಾತು ತಡೆ ಮಾತ್ರ ಇರುವ ಮೋಡ್ Brave ಶೀಲ್ಡ್ಸ್‌ ನ ಮೂಲವಾದ ಜಾಹೀರಾತು ತಡೆ ನಿಯಮಗಳನ್ನು ಕಾಯ್ದಿರುತ್ತದೆ. ಎಚ್ಚರಿಕೆ: ಇದು ಎಲ್ಲಾ ಗೌಪ್ಯತಾ ರಕ್ಷಣೆಗಳನ್ನು ತೆಗೆದು ಹಾಕುತ್ತದೆ. Brave ಯ ಗೌಪ್ಯತಾ ರಕ್ಷಣೆಯಿಂದ ಹಾಳಾಗಿರುವ ವೆಬ್‌ಸೈಟ್‌ಗಳಿಗೆ ನೀವು ಶೀಲ್ಡ್ಸ್ ಅನ್ನು DOWN ಗೆ ಹೊಂದಿಸಬಹುದು. ಇದು ಪ್ರಾಯೋಗಿಕ ಮೋಡ್ ಆಗಿದೆ. <ph name="BEGIN_LINK"/>ಮೆಚ್ಚಿಕೊಳ್ಳಿ<ph name="END_LINK"/></translation>
<translation id="3055675200351793825">ಶೀಲ್ಡ್ಸ್‌ ಆಯ್ಕೆಗಳೆಲ್ಲಾ ತಾತ್ಕಾಲಿಕವಾಗಿ ಅಶಕ್ತಗೊಂಡಿವೆ.</translation>
<translation id="2687830906359353344">Brave ಶೀಲ್ಡ್ಸ್‌ ನ ಮೂಲವಾದ ಜಾಹೀರಾತು ತಡೆ ನಿಯಮಗಳನ್ನು ಜಾಹೀರಾತು ತಡೆ ಮಾತ್ರ ಇರುವ ಮೋಡ್ ಕಾಯ್ದಿರಿಸುತ್ತದೆ ಮತ್ತು ಗೌಪ್ಯತಾ ರಕ್ಷಣೆಗಳನ್ನು ನಿಷ್ಕ್ರಿಯಗೊಳಿಸುತ್ತದೆ. ನೀವು ಪ್ರಮಾಣಿತ ಶೀಲ್ಡ್ಸ್ ಅನ್ನು ಸಕ್ರಿಯಗೊಳಿಸಲು ಇಚ್ಛಿಸುತ್ತಿದ್ದರೆ, ಈ ಮೋಡ್ ಅನ್ನು ನಿಷ್ಕ್ರಿಯಗೊಳಿಸಿ.</translation>
<translation id="3809423899581611047">ಜಾಹೀರಾತು ತಡೆ ಮಾತ್ರ ಇರುವ ಮೋಡ್ ಅನ್ನು ಆಫ್ಜ್ ಮಾಡಿ</translation>
<translation id="9185018653595759199">ಸಾಮಾಜಿಕ ಮಾಧ್ಯಮವನ್ನು ನಿರ್ಬಂಧಿಸುವಿಕೆ</translation>
<translation id="863171915776379000">ಫೇಸ್‌ಬುಕ್ ಲಾಗಿನ್‌ಗಳನ್ನು ಮತ್ತು ಎಂಬೆಡ್ ಮಾಡಿದ ಪೋಸ್ಟ್‌ಗಳನ್ಮು ಅನುಮತಿಸಿ</translation>
<translation id="7791141927430186653">X (ಹಿಂದಿನ Twitter) ಎಂಬೆಡ್ ಮಾಡಲಾದ ಟ್ವೀಟ್‌ಗಳಿಗೆ ಅನುಮತಿಸಿ</translation>
<translation id="958971637207126733">ಎಂಬೆಡ್ ಮಾಡಲಾದ ಫೋಸ್ಟ್‌ಗಳನ್ನು LinkedIn ನಲ್ಲಿ ಅನುಮತಿಸಿ</translation>
<translation id="1244912498725894944">ಕೆಲವು ಕುಕೀ ಸೆಟ್ಟಿಂಗ್‌ಗಳನ್ನು ಬ್ರೇವ್ ಶೀಲ್ಡ್ಸ್ ನಿಯಂತ್ರಿಸುತ್ತದೆ. ನೀವು ಅವುಗಳನ್ನು &lt;a href="/content/braveShields"&gt;ಇಲ್ಲಿ&lt;/a&gt; ನಲ್ಲಿ ನೋಡಬಹುದು;.</translation>
<translation id="5352519841984162795">ಈ ಸೆಟ್ಟಿಂಗ್‌ನ್ನು ಬ್ರೇವ್ ಶೀಲ್ಡ್ಸ್ ನಿಯಂತ್ರಿಸುತ್ತದೆ.</translation>
<translation id="352287031024189516">ಈ ಸೆಟ್ಟಿಂಗ್‌ನ್ನು Google ಸೈನ್-ಇನ್ ನಿಯಂತ್ರಿಸುತ್ತದೆ.</translation>
<translation id="8792121506918889955">WebRTC IP ನಿರ್ವಹಣೆ ನೀತಿ</translation>
<translation id="8798099450830957504">ಡಿಫಾಲ್ಟ್</translation>
<translation id="1822560017823072927">ಡೀಫಾಲ್ಟ್ ಸಾರ್ವಜನಿಕ ಮತ್ತು ಖಾಸಗಿ ಇಂಟರ್ಫೇಸ್‌ಗಳು</translation>
<translation id="5825943197137337319">ಡೀಫಾಲ್ಟ್ ಸಾರ್ವಜನಿಕ ಇಂಟರ್ಫೇಸ್ ಮಾತ್ರ</translation>
<translation id="1689062823386843231">ಪ್ರಾಕ್ಸಿಡ್-ಅಲ್ಲದ UDP ನಿಷ್ಕ್ರಿಯಗೊಳಿಸಿ</translation>
<translation id="3540231253392253941">ಪುಶ್ ಸಂದೇಶ ಕಳುಹಿಸುವಿಕೆಗಾಗಿ Google ಸೇವೆಗಳನ್ನು ಬಳಸಿ</translation>
<translation id="933652931229970927">ಸ್ವಯಂಚಾಲಿತವಾಗಿ ಡಯಾಗ್ನಾಸ್ಟಿಕ್ ವರದಿಗಳನ್ನು ಕಳುಹಿಸಿ</translation>
<translation id="8868426106596092089">Brave ಬ್ರೌಸರ್ ಕ್ರ್ಯಾಶ್ ಆದಾಗ ಅಥವಾ ಫ್ರೀಜ್ ಆದಾಗ ಸ್ವಯಂಚಾಲಿತವಾಗಿ ಡಯಾಗ್ನಾಸ್ಟಿಕ್ ವರದಿಗಳನ್ನು ಕಳುಹಿಸುವ ಮೂಲಕ Brave ನ ಉತ್ಪನ್ನ ಸ್ಥಿರತೆಯನ್ನು ಸುಧಾರಿಸಲು ಸಹಾಯ ಮಾಡಿ.</translation>
<translation id="4891600875049212418">ಸೂಕ್ಷ್ಮ ಸೈಟ್‌ಗಳಿಗೆ ಭೇಟಿ ನೀಡುವಾಗ ಆಫ್-ದಿ-ರೆಕಾರ್ಡ್ ಸ್ಥಿತಿಗೆ ಹೋಗಿ</translation>
<translation id="509873765238158442">ಮೈಕ್ರೋಸಾಫ್ಟ್ ರಿಕಾಲ್‌ನ್ನು ಬ್ಲಾಕ್‌ ಮಾಡಿ</translation>
<translation id="4763421121695677716">ಯಾವುದೇ ತೆರೆದ ಬ್ರೇವ್ ಟ್ಯಾಬ್‌ಗಳು 
 ಸ್ಕ್ರೀನ್‌ಶಾಟ್‌ಗಳನ್ನು ಸ್ವಯಂಚಾಲಿತವಾಗಿ ತೆಗೆದುಕೊಳ್ಳುವುದರಿಂದ ಮೈಕ್ರೋಸಾಫ್ಟ್‌ ವಿಂಡೋಸ್‌ ಕಂಪ್ಯೂಟರ್‌ಗಳಲ್ಲಿ ರೀಕಾಲ್‌ ಫೀಚರ್‌ ಬ್ಲಾಕ್‌ ಮಾಡಿ.</translation>
<translation id="1968895725257436430">ಡೇಟಾ ಸಂಗ್ರಹಣೆ</translation>
<translation id="1700052872056357670">ನಿರ್ಗಮಿಸುವಲ್ಲಿ ತೆರವುಗೊಳಿಸಿ</translation>
<translation id="216468847346280584">Brave ಜಾಹೀರಾತುಗಳ ಡೇಟಾ ಕ್ಲಿಯರ್ ಮಾಡಿ...</translation>
<translation id="2808630562319398131">Brave Rewards ಡೇಟಾ ಮರುಹೊಂದಿಸಿ...</translation>
<translation id="6438096877646138757">ನೀವು ಅವುಗಳನ್ನು ಮುಚ್ಚಿದಾಗ ಕುಕೀಗಳನ್ನು ಕ್ಲಿಯರ್ ಮಾಡುವ ಸೈಟ್‌ಗಳು</translation>
<translation id="2988792685798128092">ಸೈಟ್ ಮುಚ್ಚಿದಾಗ ಕ್ಲಿಯರ್ ಮಾಡಿ</translation>
<translation id="7702907602086592255">ಡೊಮೇನ್</translation>
<translation id="3202131003361292969">ಪಾಥ್</translation>
<translation id="5390743329570580756">ಇದಕ್ಕಾಗಿ ಕಳುಹಿಸಿ</translation>
<translation id="6742339027238151589">ಸ್ಕ್ರಿಪ್ಟ್‌ಗೆ ಪ್ರವೇಶಿಸುವಂತಹದ್ದು</translation>
<translation id="1067048845568873861">ರಚಿಸಲಾಗಿದೆ</translation>
<translation id="5747552184818312860">ಅವಧಿ ಮೀರುವುದು</translation>
<translation id="3858860766373142691">ಹೆಸರು</translation>
<translation id="361106536627977100">ಫ್ಲ್ಯಾಶ್ ಡೇಟಾ</translation>
<translation id="8195027750202970175">ಡಿಸ್ಕ್‌ನಲ್ಲಿನ ಗಾತ್ರ</translation>
<translation id="9116465289595958864">ಕೊನೆಯದಾಗಿ ಮಾರ್ಪಡಿಸಿರುವುದು</translation>
<translation id="4590324241397107707">ಡೇಟಾಬೇಸ್ ಸಂಗ್ರಹಣೆ</translation>
<translation id="5338503421962489998">ಸ್ಥಳೀಯ ಸಂಗ್ರಹಣೆ</translation>
<translation id="6032912588568283682">ಫೈಲ್ ಸಿಸ್ಟಂ</translation>
<translation id="8016266267177410919">ತಾತ್ಕಾಲಿಕ ಸಂಗ್ರಹ</translation>
<translation id="4175737294868205930">ಶಾಶ್ವತವಾಗಿರುವ ಸಂಗ್ರಹಣೆ</translation>
<translation id="1234808891666923653">ಸೇವೆ ಕೆಲಸಗಾರರು</translation>
<translation id="3432762828853624962">ಹಂಚಿಕೊಳ್ಳಲಾದ ಕೆಲಸಗಾರರು</translation>
<translation id="2927017729816812676">ಕ್ಯಾಶ್ ಸಂಗ್ರಹಣೆ</translation>
<translation id="1389601498324964367">ಕೋಟಾ-ನಿರ್ವಹಿತ ಸಂಗ್ರಹಣೆ</translation>
<translation id="814018970995616154">Brave ನಲ್ಲಿ ಸಂಗ್ರಹಿಸಲಾಗಿರುವ ಅಸುರಕ್ಷಿತ ಸೈಟ್‌ಗಳ ಪಟ್ಟಿಯೊಂದಿಗೆ URL ಗಳನ್ನು ಪರಿಶೀಲಿಸುತ್ತದೆ.</translation>
<translation id="1144810021918451336">ಅಪಾಯಕಾರಿ ವೆಬ್‌ಸೈಟ್‌ಗಳು, ಡೌನ್‌ಲೋಡ್‌ಗಳು ಮತ್ತು ವಿಸ್ತರಣೆಗಳ ವಿರುದ್ಧ ನಿಮ್ಮನ್ನು ರಕ್ಷಿಸುವುದಿಲ್ಲ.</translation>
<translation id="4905744245455598930">ಅಪಾಯಕಾರಿ ಎನ್ನಿಸುವ ಸೈಟ್‌ಗಳು, ಡೌನ್‌ಲೋಡ್‌ ಮತ್ತು 
ಎಕ್ಸ್‌ಟೆನ್ಷನ್ಸ್‌ ವಿರುದ್ಧ ರಕ್ಷಿಸುತ್ತದೆ.</translation>
<translation id="5570470519803062774">ಸೈಟ್ ಮತ್ತು ಶೀಲ್ಡ್‌ಗಳ ಸೆಟ್ಟಿಂಗ್‌ಗಳು</translation>
<translation id="410351446219883937">ಸ್ವಯಂಪ್ಲೇ</translation>
<translation id="3512883292907992390">ವೀಡಿಯೊಗಳನ್ನು ಆಟೋಪ್ಲೇ ಮಾಡಲು ಸೈಟ್‌ಗಳಿಗೆ ಅನುಮತಿಸಿ</translation>
<translation id="1876603079388924308">ವೀಡಿಯೊಗಳನ್ನು ಆಟೋಪ್ಲೇ ಮಾಡದಂತೆ ಸೈಟ್‌ಗಳನ್ನು ನಿರ್ಬಂಧಿಸಿ</translation>
<translation id="1448289340149908413">ಈಥೆರಿಯಮ್</translation>
<translation id="6583467242903731748">ಎಥೇರಿಯಮ್ ಒದಗಿಸುವವರ API ಪ್ರವೇಶಿಸಲು ಸೈಟ್ ಬಯಸುವ ಸಮಯದಲ್ಲಿ ಕೇಳಿ</translation>
<translation id="7017590444693657895">ಎಥೇರಿಯಮ್ ಒದಗಿಸುವವರ API ಪ್ರವೇಶಿಸದಂತೆ ಸೈಟ್‌ಗಳನ್ನು ನಿರ್ಬಂಧಿಸಿ</translation>
<translation id="5390923430722428146">Solana</translation>
<translation id="4539536028173362640">Solana ಪ್ರೊವೈಡರ್ API ಅನ್ನು ಪ್ರವೇಶಿಸಲು ಸೈಟ್ ಬಯಸಿದಾಗ ಕೇಳಿ</translation>
<translation id="2777102601740875941">Solana ಪೂರೈಕೆದಾರ API ಅನ್ನು ಪ್ರವೇಶಿಸದಂತೆ ಸೈಟ್‌ಗಳನ್ನು ನಿರ್ಬಂಧಿಸಿ</translation>
<translation id="6420374098612710803">ಕಾರ್ಡಾನೋ</translation>
<translation id="2791323819881188032">ಒಂದು ಸೈಟ್ ಅಕ್ಸೆಸ್‌ ಕೇಳಿದಾಗ ಕಾರ್ಡಾನೊ ಪೂರೈಕೆದಾರ APIನ್ನು ಕೇಳಿ</translation>
<translation id="2354424632502836676">ಸೈಟ್‌ಗಳು ಅಕ್ಸೆಸ್‌ ಆಗದಂತೆ ಕಾರ್ಡಾನೊ ಪೂರೈಕೆದಾರ API ಅನ್ನುನಿರ್ಬಂಧಿಸಿ</translation>
<translation id="4206299587103092719">Google ಸೈನ್-ಇನ್</translation>
<translation id="9110294136812584522">ತೃತೀಯ-ಪಕ್ಷದ ಕುಕೀಗಳ ಮೂಲಕ ಸಾಂಪ್ರದಾಯಿಕ Google ಸೈನ್-ಇನ್ ಬಳಸುವಂತೆ ಸೈಟ್‌ಗಳು ಕೇಳಬಹುದು</translation>
<translation id="2903783737778379345">ತೃತೀಯ-ಪಕ್ಷದ ಕುಕೀಗಳ ಮೂಲಕ ಸಾಂಪ್ರದಾಯಿಕ Google ಸೈನ್-ಇನ್‌ಗೆ ಅನುಮತಿಸಬೇಡಿ</translation>
<translation id="2570833232754279153">ಸಾಂಪ್ರದಾಯಿಕ Google ಸೈನ್-ಇನ್‌ಗೆ ತೃತೀಯ- ಪಕ್ಷದ ಕುಕೀಗಳನ್ನು ಬಳಸಲು ಅನುಮತಿಸಲಾಗಿಲ್ಲ</translation>
<translation id="6880817299303842099">ಸಾಂಪ್ರದಾಯಿಕ Google ಸೈನ್-ಇನ್‌ಗೆ ತೃತೀಯ- ಪಕ್ಷದ ಕುಕೀಗಳನ್ನು ಬಳಸಲು ಅನುಮತಿಸಲಾಗಿದೆ</translation>
<translation id="5794692721727586076">Leo AI ಚಾಟ್</translation>
<translation id="8115153008662981040">Leo AI ಚಾಟ್ ತೆರೆಯಲು ಸೈಟ್‌ಗಳು ಕೇಳಬಹುದು</translation>
<translation id="1145070115730668595">Leo AI ಚಾಟ್ ತೆರೆಯಲು ಸೈಟ್‌ಗಳಿಗೆ ಅನುಮತಿಸಬೇಡಿ</translation>
<translation id="5565355416171743213">ಸಿಂಕ್ ಬಳಸಲು ಪ್ರಾರಂಭಿಸಿ</translation>
<translation id="4332558599726753990">ಸಿಂಕ್ ಸೆಟಪ್</translation>
<translation id="2187778349654214731">ಪ್ರಾರಂಭಿಸಲು, ನೀವು ಸಿಂಕ್ ಮಾಡಲು ಯೋಜಿಸಿರುವ ಎಲ್ಲಾ ಸಾಧನಗಳಲ್ಲಿ Brave ಅನ್ನು ಸ್ಥಾಪಿಸಬೇಕಾಗುತ್ತದೆ. ನಂತರ, ಅವುಗಳನ್ನು ಸಿಂಕ್ ಕೋಡ್‌ನೊಂದಿಗೆ ಸುರಕ್ಷಿತವಾಗಿ ಲಿಂಕ್ ಮಾಡಿ.</translation>
<translation id="7530575064080939974">ನಿಮ್ಮ ಸಿಂಕ್ ಮಾಡಿದ ಸಾಧನಗಳನ್ನು ನಿರ್ವಹಿಸಿ</translation>
<translation id="8668872235103666008">ನಿಮ್ಮ ಸಾಧನಗಳಿಗೆ Brave ಸಿಂಕ್ ಮಾಡಲು ಸಾಧ್ಯವಾಗಲಿಲ್ಲ</translation>
<translation id="7575156386943878014">ಸಿಂಕ್ ಮ್ಯಾನೇಜರ್</translation>
<translation id="1755198127524719638">ಸಿಂಕ್ ಸೆಟ್ಟಿಂಗ್‌ಗಳು</translation>
<translation id="7558480201297099157">ನೀವು ಸಾಧನಗಳ ನಡುವೆ ಯಾವ ಮಾಹಿತಿಯನ್ನು ಸಿಂಕ್ ಮಾಡಲು ಬಯಸುತ್ತೀರಿ ಎಂಬುದನ್ನು ನಿರ್ವಹಿಸಿ. ಈ ಸೆಟ್ಟಿಂಗ್‌ಗಳು ಕೇವಲ ಈ ಸಾಧನದ ಮೇಲೆ ಪರಿಣಾಮ ಬೀರುತ್ತವೆ.</translation>
<translation id="7731928563672901833">ಸಾಧನ ಪಟ್ಟಿ</translation>
<translation id="28332161031213248">ಕೆಳಗಿನ ಸಾಧನ ಪಟ್ಟಿಯು ನಿಮ್ಮ ಸಿಂಕ್ ಚೈನ್‌ನಲ್ಲಿರುವ ಎಲ್ಲಾ ಸಾಧನಗಳನ್ನು ಹೊಂದಿದೆ. ಇತರ ಯಾವುದೇ ಸಾಧನದಿಂದ ಪ್ರತಿಯೊಂದು ಸಾಧನವನ್ನು ನಿರ್ವಹಿಸಬಹುದು.</translation>
<translation id="1313162974556054106">ಸಾಧನದ ಹೆಸರು</translation>
<translation id="923757506389336140"><ph name="DEVICE_NAME"/> (ಈ ಸಾಧನ)</translation>
<translation id="3686835020221422649">ಕೊನೆಯದಾಗಿ ಸಕ್ರಿಯವಾಗಿರುವುದು</translation>
<translation id="2569646144216067185">ಪದ ಎಣಿಕೆ: <ph name="WORD_COUNT"/></translation>
<translation id="7885157704277298658">ನಕಲಿಸಲಾಗಿದೆ!</translation>
<translation id="8802630444265810662">ನಿಮ್ಮ ಸಿಂಕ್ ಕೋಡ್ ಅನ್ನು ರವಾನಿಸಲು ಮೊಬೈಲ್ ಸಾಧನದೊಂದಿಗೆ ಸ್ಕ್ಯಾನ್ ಮಾಡಬೇಕಾದ QR ಕೋಡ್</translation>
<translation id="6221331245829088299">QR ಕೋಡ್ ಪ್ರದರ್ಶಿಸುವಲ್ಲಿ ದೋಷ ಕಂಡುಬಂದಿದೆ, ದಯವಿಟ್ಟು ರಿಫ್ರೆಶ್ ಮಾಡಿ ಮತ್ತು ಮತ್ತೆ ಪ್ರಯತ್ನಿಸಿ.</translation>
<translation id="298546024891487702">ಪ್ರಾರಂಭಿಸಲು, ನೀವು ಸಿಂಕ್ ಮಾಡಲು ಯೋಜಿಸಿರುವಂತಹ ಎಲ್ಲಾ ಸಾಧನಗಳಲ್ಲಿ ನೀವು Brave ಇನ್‌ಸ್ಟಾಲ್ ಮಾಡಿರಬೇಕು. ಅವನ್ನು ಜೊತೆಯಾಗಿ ಚೈನ್ ಮಾಡಲು, ನಿಮ್ಮ ಎಲ್ಲಾ ಸಾಧನಗಳನ್ನು ಜೊತೆಯಾಗಿ ಸುಭದ್ರವಾಗಿ ಲಿಂಕ್ ಮಾಡಲು ನೀವು ಬಳಸುವಂತಹ ಸಿಂಕ್ ಚೈನ್ ಅನ್ನು ಆರಂಭಿಸಿ.</translation>
<translation id="6200528822592747640">ಹೊಸ ಸಿಂಕ್ ಚೈನ್ ಅನ್ನು ಪ್ರಾರಂಭಿಸಿ</translation>
<translation id="5184726904895809379">ನಾನು ಸಿಂಕ್ ಕೋಡ್ ಹೊಂದಿದ್ದೇನೆ</translation>
<translation id="8780295742023331191">ಸಿಂಕ್ ಕೋಡ್ ವೀಕ್ಷಿಸಿ</translation>
<translation id="9017050385815017931">ಫೋನ್/ಟ್ಯಾಬ್ಲೆಟ್</translation>
<translation id="1736420071277903564">ಕಂಪ್ಯೂಟರ್</translation>
<translation id="3407602902101449803">ಚೈನ್ QR ಕೋಡ್ ಅನ್ನು ಸಿಂಕ್ ಮಾಡಿ</translation>
<translation id="8369686073965491869">ನಿಮ್ಮ ಮೊಬೈಲ್ ಸಾಧನದಲ್ಲಿ, ಸೆಟ್ಟಿಂಗ್‌ಗಳ ಫಲಕದಲ್ಲಿ Brave ಸಿಂಕ್‌ಗೆ ನ್ಯಾವಿಗೇಟ್ ಮಾಡಿ ಮತ್ತು ಬಟನ್ ಕ್ಲಿಕ್ ಮಾಡಿ</translation>
<translation id="6527776448555649991">“ಸಿಂಕ್ ಕೋಡ್ ಅನ್ನು ಸ್ಕ್ಯಾನ್ ಮಾಡಿ”.</translation>
<translation id="1400862780574843709">ಕೆಳಗಿನ QR ಕೋಡ್ ಅನ್ನು ಸ್ಕ್ಯಾನ್ ಮಾಡಲು ನಿಮ್ಮ ಕ್ಯಾಮೆರಾವನ್ನು ಬಳಸಿ.</translation>
<translation id="5086223971958279691">ಚೈನ್ ಕೋಡ್ ಅನ್ನು ಸಿಂಕ್ ಮಾಡಿ</translation>
<translation id="2899261497479389619">ನಿಮ್ಮ ಟಾರ್ಗೆಟ್ ಕಂಪ್ಯೂಟರ್‌ನಲ್ಲಿ, ಸೆಟ್ಟಿಂಗ್‌ಗಳಲ್ಲಿ Brave ಸಿಂಕ್‌ಗೆ ನ್ಯಾವಿಗೇಟ್ ಮಾಡಿ ಮತ್ತು ಬಟನ್ ಅನ್ನು ಕ್ಲಿಕ್ ಮಾಡಿ</translation>
<translation id="4827439149833241990">“ನಾನು ಸಿಂಕ್ ಕೋಡ್ ಹೊಂದಿದ್ದೇನೆ”.</translation>
<translation id="8299617838343103908">ಕೆಳಗೆ ತೋರಿಸಿದ ಸಿಂಕ್ ಚೈನ್ ಕೋಡ್ ಪದಗಳನ್ನು ನಮೂದಿಸಿ.</translation>
<translation id="4485276108749547761">ಈ ಕೋಡ್ ಅನ್ನು ಪಾಸ್‌ವರ್ಡ್‌ನಂತೆ ಪರಿಗಣಿಸಿ. ಅದು ಯಾರಿಗಾದರೂ ಸಿಕ್ಕಿದರೆ, ಅವರು ನಿಮ್ಮ ಸಿಂಕ್ ಮಾಡಿದ ಡೇಟಾವನ್ನು ಓದಬಹುದು ಮತ್ತು ಮಾರ್ಪಡಿಸಬಹುದು.</translation>
<translation id="3034163433136515805">QR ಕೋಡ್ ವೀಕ್ಷಿಸಿ</translation>
<translation id="5373825572723282843">ಸಿಂಕ್ ಕೋಡ್ ನಮೂದಿಸಿ</translation>
<translation id="1265244359514651398">ಕೆಳಗೆ ನಿಮ್ಮ ಸಿಂಕ್ ಚೈನ್ ಪಾಸ್‌ಫ್ರೇಸ್ ನಮೂದಿಸಿ.</translation>
<translation id="1061533051865606843">ಹೊಸ ಸಾಧನವನ್ನು ಸೇರಿಸಿ</translation>
<translation id="5093410893656857925">ಸಾಧನ ಪ್ರಕಾರ ಆರಿಸಿ</translation>
<translation id="4581190919849683048">ನೀವು ಯಾವ ರೀತಿಯ ಸಾಧನಕ್ಕೆ ಸಿಂಕ್ ಮಾಡಲು ಬಯಸುತ್ತೀರಿ?</translation>
<translation id="4112587618563511470">ಅಮಾನ್ಯ ಸಿಂಕ್ ಕೋಡ್, ದಯವಿಟ್ಟು ಪರಿಶೀಲಿಸಿ ಹಾಗೂ ಮತ್ತೆ ಪ್ರಯತ್ನಿಸಿ.</translation>
<translation id="3995714999835224798">ಈ ಕೋಡ್ ಅಮಾನ್ಯವಾಗಿದೆ</translation>
<translation id="4432071071853308688">ಈ ಕೋಡ್ ಖಾಲಿಯಾಗಿದೆ</translation>
<translation id="955848693465029904">ಆಂತರಿಕ ಸಿಂಕ್ ಸೆಟಪ್ ದೋಷ</translation>
<translation id="7456398316301207582">ಆಂತರಿಕ ಖಾತೆ ಅಳಿಸುವಿಕೆ ದೋಷ</translation>
<translation id="859506441384380749">ಈ ಕೋಡ್ ಅನ್ನು Brave ನ ಡೆಪ್ರಿಕೇಟ್ ಮಾಡಲಾದ ಆವೃತ್ತಿಯ ಮೂಲಕ ಜೆನರೇಟ್ ಮಾಡಲಾಗಿದೆ, ದಯವಿಟ್ಟು ಮೊದಲು ನಿಮ್ಮ ಮತ್ತೊಂದು ಸಾಧನವನ್ನು ಅಪ್‌ಗ್ರೇಡ್ ಮಾಡಿ</translation>
<translation id="3132642509209154999">ಈ ಕೋಡ್ ಅವಧಿ ಮೀರಿದೆ. ದಯವಿಟ್ಟು ಹೊಸತೊಂದನ್ನು ನಿಮ್ಮ ಮತ್ತೊಂದು ಸಾಧನದಲ್ಲಿ ಜೆನರೇಟ್ ಮಾಡಿ ಹಾಗೂ ಮತ್ತೊಮ್ಮೆ ಪ್ರಯತ್ನಿಸಿ.</translation>
<translation id="2859229680945501779">ಈ ಕೋಡ್ ಅಮಾನ್ಯವಾಗಿದೆ. ಸಮಯ ಮತ್ತು ಸಮಯವಲಯವನ್ನು ನಿಮ್ಮ ಸಾಧನದಲ್ಲಿ ಸರಿಯಾಗಿ ಹೊಂದಿಸಲಾಗಿದೆ ಎಂಬುದನ್ನು ದಯವಿಟ್ಟು ಪರಿಶೀಲಿಸಿ.</translation>
<translation id="2339730291919608488">ಸಿಂಕ್ ಚೈನ್ ತೊರೆಯಿರಿ</translation>
<translation id="115699408012835975">ನೀವು ಸಿಂಕ್ ಅನ್ನು ಮರುಹೊಂದಿಸಿದರೆ, ಅದರೊಂದಿಗೆ ಸಿಂಕ್ ಮಾಡಲು ನೀವು ಇನ್ನೊಂದು ಸಾಧನದಿಂದ ಸಿಂಕ್ ಕೋಡ್ ಅನ್ನು ಮರು ನಮೂದಿಸಬೇಕಾಗುತ್ತದೆ. ನೀವು ಮುಂದುವರಿಯಲು ಖಚಿತವಾಗಿ ಬಯಸುವಿರಾ?</translation>
<translation id="6092564993102418148">ಆಯ್ಕೆಮಾಡಿದ ಸಾಧನವನ್ನು ಸಿಂಕ್ ಚೈನ್‌ನಿಂದ ತೆಗೆದುಹಾಕಲು ನೀವು ಖಚಿತವಾಗಿ ಬಯಸುವಿರಾ?</translation>
<translation id="4400414577602898435">ಎಚ್ಚರಿಕೆ: ಇದು ಈ ಕೋಡ್ ಪದಗಳನ್ನು ರಚಿಸಿದ ಸಾಧನದೊಂದಿಗೆ ಸಂಭಾವ್ಯವಾಗಿ ನಿಮ್ಮ ಪಾಸ್‌ವರ್ಡ್‌ಗಳನ್ನು ಒಳಗೊಂಡಂತೆ ನಿಮ್ಮ Brave ಡೇಟಾವನ್ನು ಹಂಚಿಕೊಳ್ಳುತ್ತದೆ.

    ಈ ಕೋಡ್ ಪದಗಳನ್ನು ನೀವು ಹೊಂದಿರುವ ಸಾಧನದಿಂದ ರಚಿಸಲಾಗಿದೆಯೇ ಎಂಬುದನ್ನು ದಯವಿಟ್ಟು ಎರಡು ಬಾರಿ ಪರಿಶೀಲಿಸಿ.

    ನೀವು ಇದನ್ನು ಮಾಡಲು ಖಚಿತವಾಗಿ ಬಯಸುವಿರಾ?</translation>
<translation id="7443185843787879670">Brave ನಿಮ್ಮ ಆಪರೇಟಿಂಗ್ ಸಿಸ್ಟಂನ ಸುರಕ್ಷಿತ ಸಂಗ್ರಹಣೆಯನ್ನು ಪ್ರವೇಶಿಸಲು ಸಾಧ್ಯವಾಗಲಿಲ್ಲ. ಪಾಸ್‌ವರ್ಡ್‌ಗಳು ಮತ್ತು ಕುಕೀಗಳಂತಹ ಡೇಟಾವನ್ನು ಸುರಕ್ಷಿತಗೊಳಿಸಲು ಇದನ್ನು ಬಳಸಲಾಗುತ್ತದೆ; ಸಾಧನಗಳ ನಡುವೆ ನಿಮ್ಮ ಬ್ರೌಸರ್ ಪ್ರೊಫೈಲ್ ಅನ್ನು ಸಂಪರ್ಕಿಸಲು Brave ಸಿಂಕ್‌ಗೆ ಸಹ ಇದು ಅಗತ್ಯವಿದೆ. ಇದರರ್ಥ Brave ಸಿಂಕ್ ಚಾಲನೆಯಲ್ಲಿಲ್ಲ. ಈ ಸಮಸ್ಯೆಯನ್ನು ಪರಿಹರಿಸಲು, ದಯವಿಟ್ಟು <ph name="BEGIN_LINK_SYNC_GUIDE"/>Brave ಸಿಂಕ್ ದೋಷನಿವಾರಣೆ ಮಾರ್ಗದರ್ಶಿ<ph name="END_LINK_SYNC_GUIDE"/> ಅನ್ನು ನೋಡಿ.</translation>
<translation id="6802736947576520626">ಸಿಂಕ್ ಎನ್‌ಕ್ರಿಪ್ಶನ್ ಕೀ ಎನ್ನುವುದು ನೀವು ಮೊದಲು Brave ಸಿಂಕ್ ಹೊಂದಿಸಿದಾಗ ಬಳಸಲಾಗಿರುವುದಕ್ಕಿಂತ ವಿಭಿನ್ನವಾಗಿದೆ. ಇಲ್ಲಿ ಸುಲಭವಾದ ಸರಿಪಡಿಸುವಿಕೆಯು ನಿಮ್ಮ ಇತರ ಸಿಂಕ್ ಮಾಡಲಾದ ಸಾಧನಗಳಲ್ಲೊಂದರ ಪಾಸ್‌ಫ್ರೇಸ್ ಬಳಸಿಕೊಂಡು ಸಿಂಕ್ ಚೈನ್ ಅನ್ನು ಮರುಹೊಂದಿಸುವುದು ಮತ್ತು ಮರು-ಸೇರಿಕೊಳ್ಳುವುದಾಗಿದೆ.</translation>
<translation id="4889767840132638381">ಸಿಂಕ್ ಚೈನ್ ಮರುಹೊಂದಿಸಿ ಮತ್ತು ಮರು-ಸೇರಿಸಿ</translation>
<translation id="1680065323266179640">ಸಿಂಕ್ ಖಾತೆ ಅಳಿಸಿ</translation>
<translation id="9064376100690171155">ಖಾತೆಯನ್ನು ಶಾಶ್ವತವಾಗಿ ಅಳಿಸಿ</translation>
<translation id="228906529296554286">ನಿಮ್ಮ ಖಾತೆಯನ್ನು ಅಳಿಸುವುದರಿಂದ Brave ಸರ್ವರ್‌ಗಳಿಂದ ನಿಮ್ಮ ಎನ್‌ಕ್ರಿಪ್ಟ್ ಮಾಡಲಾದ ಡೇಟಾವನ್ನು ಅಳಿಸುತ್ತದೆ ಮತ್ತು ನಿಮ್ಮ ಎಲ್ಲಾ ಸಂಪರ್ಕಿತ ಸಾಧನಗಳಲ್ಲಿ ಸಿಂಕ್ ಅನ್ನು ನಿಷ್ಕ್ರಿಯಗೊಳಿಸುತ್ತದೆ.</translation>
<translation id="7578652532113583362">ಆದರೆ ಅದು ಆ ಸಾಧನಗಳಲ್ಲಿ ಸ್ಥಳೀಯವಾಗಿ ಸಂಗ್ರಹಿಸಿಲಾದ ಡೇಟಾವನ್ನು ಅಳಿಸುವುದಿಲ್ಲ.</translation>
<translation id="2516405584294312544">ಈ ಅಳಿಸುವಿಕೆಯು ಶಾಶ್ವತವಾಗಿದೆ ಮತ್ತು ಡೇಟಾ ಪುನಃಪಡೆಯುವಿಕೆ ಸಾಧ್ಯವಾಗುವುದಿಲ್ಲ. ಮತ್ತೊಮ್ಮೆ ಸಿಂಕ್ ಬಳಸುವುದನ್ನು
    ಆರಂಭಿಸಲು ನೀವು ನಿರ್ಧರಿಸಿದರೆ, ನೀವು ಹೊಸ ಖಾತೆಯನ್ನು ರಚಿಸಬೇಕಾಗುತ್ತದೆ ಮತ್ತು ಪ್ರತಿ ಸಾಧನವನ್ನು ಒಂದಾದರೊಂದರಂತೆ ಮರು-ಸೇರಿಸಬೇಕಾಗುತ್ತದೆ.</translation>
<translation id="4860996720371753023">ಖಾತೆ ಅಳಿಸುವಿಕೆ ಪ್ರಗತಿಯಲ್ಲಿದೆ...</translation>
<translation id="4094590686212463338">ಈ ಸಿಂಕ್ ಚೈನ್‌ಗೆ ಸೇರಲಾಗಲಿಲ್ಲ. ಸಿಂಕ್ ಚೈನ್ ಅನ್ನು ಅಳಿಸಲಾಗಿದೆ.</translation>
<translation id="4908081302669157000">ಫೋನ್ ಸಂಖ್ಯೆಗಳು, ಇಮೇಲ್‌ಗಳು ಮತ್ತು ವಿಳಾಸಗಳು</translation>
<translation id="294985549514492876">ವೆಬ್ ಆ್ಯಪ್‌ಗಳು (PWA ಗಳು)</translation>
<translation id="7029809446516969842">ಪಾಸ್‌ವರ್ಡ್‌ಗಳು</translation>
<translation id="6011308810877101166">ಸರ್ಚಿಂಗ್‌ ಸುಧಾರಿಸಲು ಸಲಹೆ ನೀಡಿ</translation>
<translation id="2332576387809612040">ಬ್ರೇವ್‌ ಆನ್ ಇರುವಾಗ, ನೀವು ಅಡ್ರೆಸ್‌ ಬಾರ್‌ ಅಥವಾ ಸರ್ಚಿಂಗ್‌ ಬಾಕ್ಸ್‌ನಲ್ಲಿ ಟೈಪ್ ಮಾಡುವುದನ್ನು ನಿಮ್ಮ ಡೀಫಾಲ್ಟ್ ಸರ್ಚಿಂಗ್‌ ಎಂಜಿನ್‌ಗೆ ಕಳುಹಿಸುತ್ತದೆ, ಇದರಿಂದ ಉತ್ತಮ ಸಲಹೆ ಪಡೆಯಬಹುದು. ಬ್ರೇವ್‌ ಆಫ್ ಇರುವಾಗ, ಬ್ರೇವ್ ನಿಮ್ಮ ಡಿವೈಸ್‌ನಲ್ಲಿ ರಚಿಸಲಾದ ಸಲಹೆಗಳನ್ನು ಮಾತ್ರ ತೋರಿಸುತ್ತದೆ. ಖಾಸಗಿ ವಿಂಡೋಗಳಲ್ಲಿ ಇದು ಯಾವಾಗಲೂ ಆಫ್ ಆಗಿರುತ್ತದೆ.</translation>
<translation id="5522403133543437426">ಅಡ್ರೆಸ್‌ ಬಾರ್‌ನಲ್ಲಿ ಬಳಸಲಾದ ಸರ್ಚ್‌ ಎಂಜಿನ್‌.</translation>
<translation id="280472502078788655">ಖಾಸಗಿ ವಿಂಡೋಗಳಿಗಾಗಿ ಅಡ್ರೆಸ್‌ ಬಾರ್‌ನಲ್ಲಿ ಸರ್ಚ್‌ ಎಂಜಿನ್‌ನ್ನು ಬಳಸಲಾಗುತ್ತದೆ.</translation>
<translation id="7232120595886556478">ಸಾಮಾನ್ಯ ವಿಂಡೋ</translation>
<translation id="6739674350896546324">ಖಾಸಗಿ ವಿಂಡೋಸ್‌ಗಾಗಿ ಸರ್ಚ್‌ ಎಂಜಿನ್</translation>
<translation id="1280261732441045146"><ph name="SEARCH_ENGINE_NAME"/> ಈಗ ಖಾಸಗಿ ವಿಂಡೋಗಳಿಗಾಗಿ ನಿಮ್ಮ ಡೀಫಾಲ್ಟ್ ಸರ್ಚ್‌ ಎಂಜಿನ್ ಆಗಿದೆ</translation>
<translation id="5363742888375478536">ಬ್ರೇವ್ ಬ್ರೌಸರ್ ಬಳಸುವಾಗ ಉತ್ತಮ ಬ್ರೌಸಿಂಗ್ ಅನುಭವಕ್ಕಾಗಿ ಬ್ರೇವ್ ಸರ್ಚಿಂಗ್‌ ಶಿಫಾರಸು ಮಾಡಲಾಗಿದೆ.</translation>
<translation id="7298195798382681320">ಶಿಫಾರಸು ಮಾಡಲಾಗಿದೆ</translation>
<translation id="6864914031231797928">ವಿಸ್ತರಣೆಗಳಿಗಾಗಿ Google ಲಾಗಿನ್ ಅನುಮತಿಸಿ</translation>
<translation id="1519976482053221804">ಬ್ರೌಸರ್‌ನಲ್ಲಿ ಕಾಸ್ಟ್ ಫೀಚರ್ ಅನ್ನು ಮೀಡಿಯಾ ರೂಟರ್ ಸಕ್ರಿಯಗೊಳಿಸುತ್ತದೆ.</translation>
<translation id="2707635989000984973">ತಡೆಯಲಾಗದ ಡೊಮೇನ್‌ಗಳ ಡೊಮೇನ್ ಹೆಸರುಗಳನ್ನು ಪರಿಹರಿಸಿ</translation>
<translation id="732344438514476996">ತಡೆಯಲಾಗದ ಡೊಮೇನ್‌ಗಳ ಗೌಪ್ಯತೆ ಪರಿಗಣನೆಗಳ ಕುರಿತು <ph name="BEGIN_LINK"/>ಹೆಚ್ಚು ತಿಳಿಯಿರಿ<ph name="END_LINK"/></translation>
<translation id="641308776160806829">Ethereum Name Service (ENS) ಡೊಮೇನ್ ಹೆಸರುಗಳನ್ನು ಪರಿಹರಿಸಿ</translation>
<translation id="6421218422395686663">ENS ಆಫ್‍‍ಚೈನ್ ಲುಕ್‍ಅಪ್ ಅನ್ನು ಅನುಮತಿಸಿ.</translation>
<translation id="4608449984413688436">Solana Name Service (SNS) ಡೊಮೇನ್ ಹೆಸರುಗಳನ್ನು ಪರಿಹರಿಸಿ</translation>
<translation id="7831978744512353629">ENS ಆಫ್‍‍ಚೈನ್ ಲುಕ್‍ಅಪ್ ಗೌಪ್ಯತೆ ಪರಿಗಣನೆಗಳ ಕುರಿತು <ph name="BEGIN_LINK"/>ಹೆಚ್ಚು ತಿಳಿಯಿರಿ<ph name="END_LINK"/>.</translation>
<translation id="6241402707160226266">Tor ಜೊತೆಗೆ ಖಾಸಗಿ ವಿಂಡೋ</translation>
<translation id="8762452230727230396">ನೀವು ಭೇಟಿ ನೀಡುವ ಸೈಟ್ಗಳಿಂದ ನಿಮ್ಮ IP ವಿಳಾಸವನ್ನು Tor ಮರೆಮಾಡುತ್ತದೆ.</translation>
<translation id="951983619130191090">Tor ನೆಟ್‌ವರ್ಕ್‌ಗೆ ಸಂಪರ್ಕಗೊಳ್ಳಲು ಇತರರಿಗೆ ಸಹಾಯ ಮಾಡುವುದಕ್ಕಾಗಿ ಸ್ವಯಂಪ್ರೇರಿತರಾಗಿ ಮುಂದೆ ಬನ್ನಿ</translation>
<translation id="2223668809371912019">ನಿಮ್ಮ ನೆಟ್‌ವರ್ಕ್ ಸಂಪರ್ಕದ ಮೂಲಕ Tor ನೆಟ್‌ವರ್ಕ್‌ಗೆ ಸಂಪರ್ಕಗೊಳ್ಳಲು ಸೆನ್ಸಾರ್ ಮಾಡಲಾದ ದೇಶಗಳಲ್ಲಿನ ಬಳಕೆದಾರರಿಗೆ ಅವಕಾಶ ನೀಡಲು Snowflake ವಿಸ್ತರಣೆಯನ್ನು ಸಕ್ರಿಯಗೊಳಿಸಿ.</translation>
<translation id="2959986444009520721">ಬ್ರಿಡ್ಜ್‌ಗಳನ್ನು ಬಳಸಿ</translation>
<translation id="271237727681958372">Tor ನಿರ್ಬಂಧಗೊಂಡಿರುವಲ್ಲಿ Tor ನೆಟ್‌ವರ್ಕ್ ಅನ್ನು ಪ್ರವೇಶಿಸಲು ಬ್ರಿಡ್ಜ್‌ಗಳು ನಿಮಗೆ ಸಹಾಯ ಮಾಡುತ್ತವೆ. ನೀವು ಎಲ್ಲಿದ್ದೀರಿ ಎಂಬುದನ್ನು ಆಧರಿಸಿ, ಒಂದು ಬ್ರಿಡ್ಜ್ ಇನ್ನೊಂದಕ್ಕಿಂತ ಉತ್ತಮವಾಗಿ ಕಾರ್ಯನಿರ್ವಹಿಸಬಹುದು.</translation>
<translation id="7206799843254049470">Tor ಸಂಪರ್ಕ ಸೆಟ್ಟಿಂಗ್‌ಗಳು</translation>
<translation id="3194502271166340944">Tor ಜೊತೆಗಿನ ಖಾಸಗಿ ವಿಂಡೋಸ್ Tor ನೆಟ್‌ವರ್ಕ್‌ಗೆ ಹೇಗೆ ಸಂಪರ್ಕಿಸುತ್ತದೆ ಎಂಬುದನ್ನು ನಿಯಂತ್ರಿಸುತ್ತದೆ</translation>
<translation id="3717364961460790491">ಈ ಕಾರ್ಯಕ್ಷಮತೆಗೆ Snowflake ವಿಸ್ತರಣೆ ಅಗತ್ಯವಿದ್ದು ಅದನ್ನು ಡೌನ್‌ಲೋಡ್ ಮಾಡಲಾಗಲಿಲ್ಲ. ದಯವಿಟ್ಟು ನಿಮ್ಮ ಇಂಟರ್ನೆಟ್ ಸಂಪರ್ಕವನ್ನು ಪರಿಶೀಲಿಸಿ ಹಾಗೂ ಮತ್ತೊಮ್ಮೆ ಪ್ರಯತ್ನಿಸಿ.</translation>
<translation id="4859228830700205299">ಅಂತರ್ನಿರ್ಮಿತ ಬ್ರಿಡ್ಜ್ ಆಯ್ಕೆಮಾಡಿ</translation>
<translation id="3233137871426528317">torproject.org ನಿಂದ ಬ್ರಿಡ್ಜ್‌ಗಾಗಿ ವಿನಂತಿಸಿ</translation>
<translation id="5701503934456421898">ಹೊಸ ಬ್ರಿಡ್ಜ್‌ಗೆ ವಿನಂತಿಸಿ...</translation>
<translation id="8149806369020180959">ಬ್ರಿಡ್ಜ್ ಒದಗಿಸಿ</translation>
<translation id="454073978993625597">ವಿಶ್ವಾಸಾರ್ಹ ಮೂಲದಿಂದ ಬ್ರಿಡ್ಜ್ ಮಾಹಿತಿಯನ್ನು ನಮೂದಿಸಿ.</translation>
<translation id="4425607417590286548">ಬದಲಾವಣೆಗಳನ್ನು ಅನ್ವಯಿಸಿ</translation>
<translation id="2128143836897950793">ಬ್ರಿಡ್ಜ್‌ಗಳನ್ನು ಪಡೆಯಲು 'ಹೊಸ ಬ್ರಿಡ್ಜ್‌ಗಾಗಿ ವಿನಂತಿಸಿ...' ಕ್ಲಿಕ್ ಮಾಡಿ</translation>
<translation id="3314921753580327793">ವಿಳಾಸವನ್ನು ಟೈಪ್ ಮಾಡಿ: ಪೋರ್ಟ್ (ಪ್ರತಿ ಸಾಲಿಗೆ ಒಂದು)</translation>
<translation id="3755189300481406891">ಬ್ರಿಡ್ಜ್‌ಗಾಗಿ ವಿನಂತಿಸಿ</translation>
<translation id="6924425739431382319">BridgeDB ಅನ್ನು ಸಂಪರ್ಕಿಸಲಾಗುತ್ತಿದೆ. ದಯಮಾಡಿ ನಿರೀಕ್ಷಿಸಿ.</translation>
<translation id="811745063252080651">ಬ್ರಿಡ್ಜ್‌ಗಾಗಿ ವಿನಂತಿಸಲು CAPTCHA ಅನ್ನು ಪರಿಹರಿಸಿ.</translation>
<translation id="6936835573742749135">CAPTCHA ಗೆ ವಿನಂತಿಸಲು ಸಾಧ್ಯವಿಲ್ಲ. ನಂತರ ಮತ್ತೆ ಪ್ರಯತ್ನಿಸಿ.</translation>
<translation id="2653659639078652383">ಸಲ್ಲಿಸಿ</translation>
<translation id="1294350054292274934">Tor ವಿಂಡೋಗಳಲ್ಲಿ .onion ವಿಳಾಸಗಳನ್ನು ಮಾತ್ರ ಪರಿಹರಿಸಿ</translation>
<translation id="4745128937437681681">Tor ವಿಂಡೋಗಳ ಹೊರಗೆ Onion ಸೇವೆಗಳು ಲಭ್ಯವಿರುವುದಿಲ್ಲ</translation>
<translation id="6305528566126073902">ಬ್ರೌಸರ್‌ನಲ್ಲಿ ರಕ್ಷಿಸಲಾದ ಸ್ಟ್ರೀಮಿಂಗ್ ವೀಡಿಯೊ ಮತ್ತು ಇತರ ವಿಷಯವನ್ನು ವೀಕ್ಷಿಸಲು Widevine ಡಿಜಿಟಲ್ ಹಕ್ಕುಗಳ ನಿರ್ವಹಣೆ (DRM) ಅಂಶವನ್ನು ಬಳಸಿ</translation>
<translation id="1314131187310290315">ಮ್ಯಾನಿಫೆಸ್ಟ್ V2 ವಿಸ್ತರಣೆಗಳು</translation>
<translation id="2488433650767270565">ಮುಂದಿನ ಮ್ಯಾನಿಫೆಸ್ಟ್ V2 ವಿಸ್ತರಣೆಗಳನ್ನು Chrome ವೆಬ್ ಸ್ಟೋರ್‌ನಿಂದ ತೆಗೆದುಹಾಕಲಾಗುತ್ತದೆ, ಆದರೆ ಅವುಗಳನ್ನು ಇನ್ನೂ ಸಹ Brave ನಲ್ಲಿ ಬೆಂಬಲಿಸಲಾಗುತ್ತದೆ. ಡೌನ್‌ಲೋಡ್ ಮಾಡಲು ಮತ್ತು ಸ್ಥಾಪಿಸಲು ಅಥವಾ ಅಸ್ಥಾಪಿಸಲು ಟಾಗಲ್ ಮಾಡಿ.</translation>
<translation id="6918225713618473646">ಬ್ರೇವ್ ಈ ಮ್ಯಾನಿಫೆಸ್ಟ್ V2 ವಿಸ್ತರಣೆಗಳನ್ನು ಬ್ರೇವ್ ಸರ್ವರ್‌ಗಳಲ್ಲಿ ಹೋಸ್ಟ್ ಮಾಡುತ್ತದೆ, ಆದರೆ ಅವುಗಳ ವಿಷಯ, ಭದ್ರತೆ ಅಥವಾ ಕ್ಷಮತೆಯನ್ನು ಪರೀಕ್ಷೆ ಮಾಡುವುದಿಲ್ಲ ಅಥವಾ ಪರಿಶೀಲಿಸುವುದಿಲ್ಲ. ಸಹಾಯಕ್ಕಾಗಿ ಪ್ರತಿ ಎಕ್ಸ್‌ಟೆನ್ಷನ್ಸ್‌ನ ಅಧಿಕೃತ ಪುಟವನ್ನು ನೋಡಿ. ಮ್ಯಾನಿಫೆಸ್ಟ್ V2 ಗಾಗಿ ಬ್ರೇವ್‌ನ ಯೋಜನೆಗಳನ್ನು <ph name="BEGIN_LINK"/>ಇಲ್ಲಿ<ph name="END_LINK"/> ಓದಿ;.</translation>
<translation id="578671172657727816">NoScript™ ಸಕ್ರಿಯಗೊಳಿಸಿ</translation>
<translation id="9068475464170522036">NoScript ಎನ್ನುವುದು ಮ್ಯಾನಿಫೆಸ್ಟ್ V2 ವಿಸ್ತರಣೆಯಾಗಿದ್ದು ಅದು ನಿಮಗೆ ನೀಡಲಾಗಿರುವ ಪುಟದಲ್ಲಿ ರನ್ ಆಗುತ್ತಿರುವ ಅಥವಾ ರನ್ ಆಗಲು ಪ್ರಯತ್ನಿಸುತ್ತಿರುವ ಪ್ರತ್ಯೇಕ ಸ್ಕ್ರಿಪ್ಟ್‌ಗಳನ್ನು ನಿರ್ಬಂಧಿಸಲು ಅಥವಾ ಅನಿರ್ಬಂಧಿಸಲು ಅವಕಾಶ ನೀಡುತ್ತದೆ.</translation>
<translation id="1394592156621788100">uBlock Origin™ ಸಕ್ರಿಯಗೊಳಿಸಿ</translation>
<translation id="2638983091068889519">uBlock Origin ಎನ್ನುವುದು ಮ್ಯಾನಿಫೆಸ್ಟ್ V2 ವಿಸ್ತರಣೆಯಾಗಿದ್ದು ಅದು ಸುಧಾರಿತ ಬಳಕೆದಾರರಿಗೆ ಸಾಕಷ್ಟು ಆಯ್ಕೆಗಳೊಂದಿಗೆ ಶಕ್ತಿಶಾಲಿಯಾದ ವಿಷಯ ನಿರ್ಬಂಧಿಸುವಿಕೆ ಪರಿಕರಗಳನ್ನು ಒದಗಿಸುತ್ತದೆ.</translation>
<translation id="3909078036552544838">uMatrix™ ಸಕ್ರಿಯಗೊಳಿಸಿ</translation>
<translation id="8796148218203577506">uMatrix ಎನ್ನುವುದು ಮ್ಯಾನಿಫೆಸ್ಟ್ V2 ವಿಸ್ತರಣೆಯಾಗಿದ್ದು ಅದು ಹಲವಾರು ಗೌಪ್ಯತೆ-ವೃದ್ಧಿಸುವಿಕೆ ಪರಿಕರಗಳೊಂದಿಗೆ ಪಾಯಿಂಟ್-ಎಂಡ್ ಕ್ಲಿಕ್ ಮ್ಯಾಟ್ರಿಕ್ಸ್ ಆಧಾರಿತ ಫೈರ್‌ವಾಲ್ ಅನ್ನು ಒದಗಿಸುತ್ತದೆ.</translation>
<translation id="2385774023523989298">AdGuard™ ಸಕ್ರಿಯಗೊಳಿಸಿ</translation>
<translation id="188228077840632890">AdGuard ಎನ್ನುವುದು ಮ್ಯಾನಿಫೆಸ್ಟ್ V2 ವಿಸ್ತರಣೆಯಾಗಿದ್ದು ಅದು ಜಾಹೀರಾತು ನಿರ್ಬಂಧಿಸುವಿಕೆ, ಪೋಷಕ ನಿಯಂತ್ರಣ ಆಯ್ಕೆಗಳು ಮತ್ತು ಇತರ AdGuard ಸೇವಾ ನೀಡುವಿಕೆಗಳೊಂದಿಗೆ ಏಕೀಕರಣವನ್ನು ಒದಗಿಸುತ್ತದೆ.</translation>
<translation id="8137559199583651773">ವಿಸ್ತರಣೆಗಳನ್ನು ನಿರ್ವಹಿಸಿ</translation>
<translation id="7013485839273047434">ಇನ್ನಷ್ಟು ಎಕ್ಸ್‌ಟೆನ್ಶನ್‌ಗಳನ್ನು ಪಡೆಯಿರಿ</translation>
<translation id="4954512758656527938">ಡೀಫಾಲ್ಟ್ ಈಥೇರಿಯಮ್ ವ್ಯಾಲೆಟ್</translation>
<translation id="7701023802820268122">ಡೀಫಾಲ್ಟ್ ಸೊಲಾನಾ ವ್ಯಾಲೆಟ್</translation>
<translation id="3991455933137809014">ಡೀಫಾಲ್ಟ್ ಕಾರ್ಡಾನೊ ವ್ಯಾಲೆಟ್</translation>
<translation id="8488282162676695335">Brave ವ್ಯಾಲೆಟ್</translation>
<translation id="6942354363301686374">ವಿಸ್ತರಣೆಗಳು (ಫಾಲ್‌ಬ್ಯಾಕ್ ಇಲ್ಲ)</translation>
<translation id="702381242110464396">ವಿಸ್ತರಣೆಗಳು (Brave ವ್ಯಾಲೆಟ್ ಫಾಲ್‌ಬ್ಯಾಕ್)</translation>
<translation id="4718664830805652430">ಡೀಫಾಲ್ಟ್ ಬೇಸ್ ಕರೆನ್ಸಿ</translation>
<translation id="7992507032049865603">ಡೀಫಾಲ್ಟ್ ಬೇಸ್ ಕ್ರಿಪ್ಟೋಕರೆನ್ಸಿ</translation>
<translation id="3044369626313583722">Brave ವ್ಯಾಲೆಟ್ ಬಟನ್ ತೋರಿಸಿ</translation>
<translation id="7568430944629653319">NFT ಅನ್ವೇಷಣೆಯನ್ನು ಸಕ್ರಿಯಗೊಳಿಸಿ</translation>
<translation id="970496996377628529">ಮೂರನೇ ಪಾರ್ಟಿ API ಗಳನ್ನು ಬಳಸಿಕೊಂಡು ನಿಮ್ಮ ಸ್ವಂತ ವ್ಯಾಲೆಟ್‌ಗೆ NFT ಗಳನ್ನು ಸ್ವಯಂಚಾಲಿತವಾಗಿ ಸೇರಿಸಿ.</translation>
<translation id="8421293929927030255">ಖಾಸಗಿ Windowsಗಳಲ್ಲಿ Brave ವ್ಯಾಲೆಟ್ ಸಕ್ರಿಯಗೊಳಿಸಿ.</translation>
<translation id="1729224157015744629">ಎಚ್ಚರಿಕೆ: ಖಾಸಗಿ ವಿಂಡೋ ಸೆಷನ್‌ನಲ್ಲಿ ವ್ಯಾಲೆಟ್ ವಿಳಾಸವನ್ನು ಮರುಬಳಕೆ ಮಾಡುವುದರಿಂದ ಖಾಸಗಿ ವಿಂಡೋ ಸೆಷನ್ ಅನ್ನು ಖಾಸಗಿಯಲ್ಲದ ವಿಂಡೋ ಸೆಷನ್‌ಗೆ ಲಿಂಕ್ ಮಾಡಲು ಸೈಟ್ ಅನ್ನು ಸಕ್ರಿಯಗೊಳಿಸಬಹುದು.</translation>
<translation id="8239147115686034860">ಸ್ವಯಂಚಾಲಿತವಾಗಿ Brave ವ್ಯಾಲೆಟ್ ಲಾಕ್ ಮಾಡಿ</translation>
<translation id="414639769490080648">Brave ವ್ಯಾಲೆಟ್ ಸ್ವಯಂಚಾಲಿತವಾಗಿ ಲಾಕ್ ಆಗುವ ತನಕ ಕಾಯಬೇಕಾದ ನಿಮಿಷಗಳ ಸಂಖ್ಯೆ</translation>
<translation id="856371974127598760">ವ್ಯಾಲೆಟ್ ನೆಟ್‌ವರ್ಕ್‌ಗಳು</translation>
<translation id="5975930666279943472">ವ್ಯಾಲೆಟ್ ವಹಿವಾಟು ಮತ್ತು ನೋನ್ಸ್ ಮಾಹಿತಿಯನ್ನು ತೆರವು ಮಾಡಿ</translation>
<translation id="5693968582510626466">ವಹಿವಾಟುಗಳನ್ನು ತೆರವುಗೊಳಿಸುವುದು ಡೆವಲಪರ್‌ಗಳಿಗೆ ಅಥವಾ ಸ್ಥಳೀಯ ಸರ್ವರ್‌ನಲ್ಲಿ ಸ್ಥಿತಿಯನ್ನು ತೆರವುಗೊಳಿಸುವಾಗ ಉಪಯುಕ್ತವಾಗಿರಬಹುದು</translation>
<translation id="6171369470447621882">Zcash ಸಿಂಕ್‌ನ್ನು ಮರುಹೊಂದಿಸಿ</translation>
<translation id="6705112675071480687">ಎಲ್ಲಾ ರಕ್ಷಿತ ಖಾತೆಗಳಿಗೆ Zcash ಸಿಂಕ್ ಪ್ರೋಗ್ರೆಸ್‌ನ್ನು ಮರುಹೊಂದಿಸುತ್ತದೆ</translation>
<translation id="2012093487873597892">ನೀವು Zcash ಸಿಂಕ್‌ನ್ನು ಖಚಿತವಾಗಿ ಮರುಹೊಂದಿಸಲು ಬಯಸುವಿರಾ? ಎಲ್ಲಾ ರಕ್ಷಿತ ಖಾತೆಗಳಿಗೆ ಸಿಂಕ್ ಪ್ರೋಗ್ರೆಸ್‌ನ್ನು ಕೈಬಿಡಲಾಗುತ್ತದೆ. ಖಚಿತಪಡಿಸಲು "<ph name="CONFIRMATION_PHRASE"/>" ಎಂದು ಟೈಪ್ ಮಾಡಿ.</translation>
<translation id="5031551083187285762">ನಿಮ್ಮ Zcash ಖಾತೆಗಳ ಸಿಂಕ್‌ನ್ನು ಮರುಹೊಂದಿಸಲಾಗಿದೆ.</translation>
<translation id="9216386092464743272">ನಿಮ್ಮ ಎಲ್ಲಾ ವ್ಯಾಲೆಟ್ ವಹಿವಾಟನ್ನು ಮತ್ತು ನೋನ್ಸ್ ಮಾಹಿತಿಯನ್ನು ಮರುಹೊಂದಿಸಲು ನೀವು ಖಚಿತವಾಗಿ ಬಯಸುವಿರಾ? ಈ ಆಯ್ಕೆಯನ್ನು ಬಹುಪಾಲು ಸ್ಥಳೀಯ ಟೆಸ್ಟ್ ಸರ್ವರ್ ಅನ್ನು ರನ್ ಮಾಡುತ್ತಿರುವ ಡೆವಲಪರ್‌ಗಳು ಬಳಸುತ್ತಾರೆ. ದೃಢಪಡಿಸಲು "<ph name="CONFIRMATION_PHRASE"/>" ಅನ್ನು ಟೈಪ್ ಮಾಡಿ.</translation>
<translation id="2326850911705720398">ವ್ಯಾಲೆಟ್ ಡೇಟಾ ರೀಸೆಟ್ ಮಾಡಿ ಮತ್ತು ಕ್ಲಿಯರ್ ಮಾಡಿ</translation>
<translation id="6369495274982305511">ನಿಮ್ಮ ವ್ಯಾಲೆಟ್ ಮರುಹೊಂದಿಸಲು ನೀವು ಖಚಿತವಾಗಿ ಬಯಸುವಿರಾ? ನಿಮ್ಮ ವ್ಯಾಲೆಟ್ ಅನ್ನು ಬ್ಯಾಕಪ್ ಮಾಡದೇ ಇದ್ದರೆ, ಮರುಹೊಂದಿಸುವುದರಿಂದ ನೀವು ಎಲ್ಲಾ ಖಾತೆ ಡೇಟಾ ಕಳೆದುಕೊಳ್ಳುವುದಕ್ಕೆ ಕಾರಣವಾಗುತ್ತದೆ (ಯಾವುದೇ ಸಂಬಂಧಿಸಿದ ಫಂಡ್‌ಗಳನ್ನು ಒಳಗೊಂಡಂತೆ). ದೃಢಪಡಿಸಲು "<ph name="CONFIRMATION_PHRASE"/>" ಟೈಪ್ ಮಾಡಿ.</translation>
<translation id="3752403403443723332">ನಿಮ್ಮ ವ್ಯಾಲೆಟ್ ಮರುಹೊಂದಿಸಲಾಗಿದೆ.</translation>
<translation id="594766067816395072">ನಿಮ್ಮ ವ್ಯಾಲೆಟ್ ವಹಿವಾಟು ಮಾಹಿತಿಯನ್ನು ಮರುಹೊಂದಿಸಲಾಗಿದೆ.</translation>
<translation id="57798285717509216">ನೀವು ಸಹಿ ಮಾಡುವುದಕ್ಕೂ ಮೊದಲು ವಹಿವಾಟುಗಳ ಫಲಿತಾಂಶಗಳನ್ನು ನೋಡಿ. <ph name="BEGIN_LINK"/>&lt;u&gt;ಹೆಚ್ಚು ತಿಳಿಯಿರಿ&lt;/u&gt;<ph name="END_LINK"/></translation>
<translation id="4226543734057230801">Ethereum ನೆಟ್‌ವರ್ಕ್‌ಗಳು</translation>
<translation id="3504157706952484145">Filecoin ನೆಟ್‌ವರ್ಕ್‌ಗಳು</translation>
<translation id="1561541094377237745">Solana ನೆಟ್‌ವರ್ಕ್‌ಗಳು</translation>
<translation id="7141438739990875547">Bitcoin ನೆಟ್‌ವರ್ಕ್‌ಗಳು</translation>
<translation id="1077567586443625607">Zcash ನೆಟ್‌ವರ್ಕ್‌ಗಳು</translation>
<translation id="1177180573354712438">ಕಾರ್ಡಾನೋ ನೆಟ್‌ ವರ್ಕ್</translation>
<translation id="3176794108951154148">Polkadot ನೆಟ್‌ವರ್ಕ್‌ಗಳು</translation>
<translation id="3159419679550543837">ಟೆಸ್ಟ್ ನೆಟ್‌ವರ್ಕ್‌ಗಳನ್ನು ತೋರಿಸಿ</translation>
<translation id="3215569562674795548">ಹೊಸ ನೆಟ್‌ವರ್ಕ್ ಎಡಿಟ್ ಮಾಡಿ ಅಥವಾ ಸೇರಿಸಿ</translation>
<translation id="4418993400653250511">ಚೈನ್‌ನ ಐಡಿ</translation>
<translation id="3423620355610881890">ಧನಾತ್ಮಕ ದಶಮಾಂಶ ಸಂಖ್ಯೆ</translation>
<translation id="8110465398315041268">ನೆಟ್‌ವರ್ಕ್ ಹುಡುಕಿ</translation>
<translation id="3579705520805744214">ಚೈನ್ ಐಡಿ ಅಥವಾ ಹೆಸರು</translation>
<translation id="8502525913969149079">ಚೈನ್‌ನ ಹೆಸರು</translation>
<translation id="1034112277864078119">ಚೈನ್ ಹೆಸರು ಹೆಸರು</translation>
<translation id="4672314527143443556">ಚೈನ್‌ನ ಕರೆನ್ಸಿ ಹೆಸರು</translation>
<translation id="4652114030688989556">ಕರೆನ್ಸಿ ಹೆಸರು ನಮೂದಿಸಿ</translation>
<translation id="1079960017149736097">ಚೈನ್‌ನ ಕರೆನ್ಸಿ ಸಂಕೇತ</translation>
