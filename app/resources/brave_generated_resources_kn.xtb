<translation id="496896260395129787">ಈ Brave ಸಿಂಕ್ ಖಾತೆಯನ್ನು ಮತ್ತೊಂದು ಸಾಧನದಿಂದ ಅಳಿಸಲಾಗಿದೆ. ಸಿಂಕ್ ನಿಷ್ಕ್ರಿಯಗೊಳಿಸುವ ಉದ್ದೇಶ ನಿಮಗಿಲ್ಲದಿದ್ದರೆ,<ph name="LINK_TEXT"/></translation>
<translation id="4353815407425635948"><ph name="INFOBAR_TEXT"/>ಖಾತೆಯನ್ನು ಮರು-ರಚಿಸಿ</translation>
<translation id="6965382102122355670">ಸರಿ</translation>
<translation id="3975865347033939965">ಸಿಂಕ್ ಸೇವೆಯನ್ನು ಪ್ರಾರಂಭಿಸಲಾಗಲಿಲ್ಲ, Brave ಸಿಂಕ್ ಚಾಲನೆಯಲ್ಲಿಲ್ಲ</translation>
