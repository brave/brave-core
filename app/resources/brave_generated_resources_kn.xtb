<translation id="8172263161008556851">ಸಂಭಾಷಣೆಯಲ್ಲಿ ಸಲಹೆ ನೀಡಲಾದ ಪ್ರಾಂಪ್ಟ್‌ಗಳನ್ನು ತೋರಿಸಿ</translation>
<translation id="5781842473834867765">ನನ್ನ ಸಂಭಾಷಣೆಯ ಇತಿಹಾಸವನ್ನು ಸಂಗ್ರಹಿಸಿ</translation>
<translation id="1082960401708055995">ಸಂಭಾಷಣೆ ಸಂಗ್ರಹಣೆಯನ್ನು ನಿಷ್ಕ್ರಿಯಗೊಳಿಸುವುದರಿಂದ ಹಿಂದೆ ಸಂಗ್ರಹಿಸಿದ ಎಲ್ಲಾ ಸಂಭಾಷಣೆಗಳನ್ನು ಶಾಶ್ವತವಾಗಿ ಅಳಿಸಲಾಗುತ್ತದೆ. ಈ ಕ್ರಿಯೆಯನ್ನು ರದ್ದುಗೊಳಿಸಲು ಆಗುವುದಿಲ್ಲ.</translation>
<translation id="1014480593522400586">ಲಿಯೋ ಡೇಟಾ ತೆರವುಗೊಳಿಸಿ</translation>
<translation id="5256236967791936135">ಲಿಯೋ AI ಅನ್ನು ರೀಸೆಟ್ಟಿಂಗ್‌ ಮಾಡುವುದರಿಂದ ಭವಿಷ್ಯದಲ್ಲಿ ಬ್ರೇವ್ ಲಿಯೋ AIನ್ನು ಬಳಸಬೇಕಾಗುತ್ತದೆ ಮತ್ತು ನಿಮ್ಮ ಚಾಟ್ ಇತಿಹಾಸ, ಕಸ್ಟಮೈಸೇಶನ್‌ಗಳು ಮತ್ತು ಹಿಸ್ಟರಿಯನ್ನೂ ಸಹ ತೆರವು ಮಾಡುತ್ತದೆ. ನಿಮ್ಮ ಚಾಟ್ ಹಿಸ್ಟರಿ ತೆರವು ಮಾಡುವುದರಿಂದ ಬ್ರೇವ್ ಲಿಯೋ AI ಜೊತೆಗಿನ ನಿಮ್ಮ ಹಿಂದಿನ ಎಲ್ಲಾ ಸಂವಾದಗಳು ಅಳಿಸಿಹೋಗುತ್ತವೆ. ಈ ಕ್ರಿಯೆಯನ್ನು ರದ್ದುಗೊಳಿಸಲಾಗುವುದಿಲ್ಲ.</translation>
<translation id="5574059574002819179">ಸ್ವಯಂಸಂಪೂರ್ಣ ಸಲಹೆಗಳನ್ನು ಸರಿಹೊಂದಿಸಿ</translation>
<translation id="7942415993090181327">ಚಾಟ್‌ ಇತಿಹಾಸ</translation>
<translation id="5084498230659987096">ಬ್ರೇವ್ ಲಿಯೋ ಬ್ರೌಸರ್‌ನಲ್ಲಿ ಗೌಪ್ಯತೆ-ಮೊದಲು AI ಚಾಟ್ ಮತ್ತು ಇತರ AI-ಚಾಲಿತ ಇಂಟರ್‌ಫೇಸ್‌ಗಳನ್ನು ಒದಗಿಸುತ್ತದೆ. Leo ನಿಮ್ಮ ಡೇಟಾವನ್ನು ಎಂದಿಗೂ ಬಳಸುವುದಿಲ್ಲ ಅಥವಾ ಮಾದರಿ ತರಬೇತಿಗಾಗಿ ಅದನ್ನು ಬಳಸುವುದಿಲ್ಲ. ಎಲ್ಲಾ ವಿನಂತಿಗಳನ್ನು ಅನಾಮಧೇಯಗೊಳಿಸುವ ಸರ್ವರ್ ಮೂಲಕ ಪ್ರಾಕ್ಸಿ ಮಾಡಲಾಗುತ್ತದೆ.</translation>
