<translation id="5860033963881614850">ಆಫ್</translation>
<translation id="2393250835562952455">ಆಟೋಹೈಡ್‌</translation>
<translation id="5977931179408079967">ಸ್ಥಿತಿ</translation>
<translation id="3790384768741064842">ಬಲಕ್ಕೆ ಸರಿಸಿ</translation>
<translation id="7444424316576061724">ಎಡಕ್ಕೆ ಸರಿಸಿ</translation>
<translation id="7060352228894039151">ಮೌಸ್ಓವರ್‌ನಲ್ಲಿ</translation>
<translation id="8981254605840444865">ಸೆಟ್ಟಿಂಗ್‌ಗಳನ್ನು ತೋರಿಸಿ</translation>
<translation id="59174027418879706">ಸಕ್ರಿಯಗೊಳಿಸಲಾಗಿದೆ</translation>
<translation id="4176463684765177261">ನಿಷ್ಕ್ರಿಯಗೊಳಿಸಲಾಗಿದೆ</translation>
<translation id="8258999165172757081">ಸೇರಿಸಲಾಗಿದೆ</translation>
<translation id="6959315322491671328">ತೆಗೆದುಹಾಕಲು ರೈಟ್-ಕ್ಲಿಕ್ ಮಾಡಿ</translation>
<translation id="495046168593986294">ಮೇಲಕ್ಕೆ ಸ್ಕ್ರಾಲ್ ಮಾಡಿ</translation>
<translation id="4021716437419160885">ಕೆಳಕ್ಕೆ ಸ್ಕ್ರಾಲ್ ಮಾಡಿ</translation>
<translation id="2702801445560668637">ಓದುವ ಪಟ್ಟಿ</translation>
<translation id="2533715613366623756">ಬುಕ್‌ಮಾರ್ಕ್ ಮ್ಯಾನೇಜರ್</translation>
<translation id="3405021928725149239">ಬುಕ್‌ಮಾರ್ಕ್ ಮ್ಯಾನೇಜರ್</translation>
<translation id="6284218950354553099">Brave ಗೆ ದೈನಂದಿನ ಬಳಕೆ ಪಿಂಗ್ ಅನ್ನು ಸ್ವಯಂಚಾಲಿತವಾಗಿ ಕಳುಹಿಸಿ</translation>
<translation id="694500751416448436">ಈ ಖಾಸಗಿ ಪಿಂಗ್ ಸಕ್ರಿಯ ಬಳಕೆದಾರರನ್ನು ಅಂದಾಜು ಮಾಡಲು Brave ಗೆ ಅವಕಾಶ ನೀಡುತ್ತದೆ.</translation>
<translation id="1872784258300710671">ಕೆಲವು ವೈಶಿಷ್ಟ್ಯಗಳ ಒಟ್ಟಾರೆ ಬಳಕೆಯನ್ನು ಅಂದಾಜು ಮಾಡಲು Brave ಸಂಪೂರ್ಣವಾಗಿ ಖಾಸಗಿ ಉತ್ಪನ್ನ ವಿಶ್ಲೇಷಣೆಯನ್ನು ಬಳಸುತ್ತದೆ</translation>
<translation id="8712637175834984815">ಅರ್ಥವಾಯಿತು</translation>
<translation id="4394049700291259645">ನಿಷ್ಕ್ರಿಯಗೊಳಿಸಿ</translation>
<translation id="7142548388914389999">ಗೌಪ್ಯತೆ-ಕಾಪಾಡುವ ಉತ್ಪನ್ನ ವಿಶ್ಲೇಷಣೆ (P3A) ಅನುಮತಿಸಿ</translation>
<translation id="8707615221880318679">ನಿರ್ದಿಷ್ಟ ವೈಶಿಷ್ಟ್ಯಗಳ ಒಟ್ಟಾರೆ ಬಳಕೆಯನ್ನು ಅಂದಾಜಿಸಲು ಮತ್ತು ಅವುಗಳನ್ನು ನಿಮಗೆ ಉತ್ತಮವಾಗಿಸಲು ಈ ಖಾಸಗಿ ಪ್ರತಿಕ್ರಿಯೆಗಳು Brave ಗೆ ಸಹಾಯ ಮಾಡುತ್ತವೆ.</translation>
<translation id="193368604235852218">Web3</translation>
<translation id="4738583579791001083">Web3 ಡೊಮೇನ್‌ಗಳು</translation>
<translation id="4552520379838695057">ಕ್ಷಮಿಸಿ, ಆ ಪುಟ ಕಾಣೆಯಾಗಿದೆ.</translation>
<translation id="7299769530898469069">ಉಳಿಸಲಾದ ಆವೃತ್ತಿ ಲೋಡ್ ಮಾಡಲು ಸಾಧ್ಯವಾಗಲಿಲ್ಲ</translation>
