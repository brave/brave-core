<translation id="1529674267267221673">ನೀವು ವೆಬ್‌ಸೈಟ್‌ನಲ್ಲಿ ರೈಟ್-ಕ್ಲಿಕ್ ಮಾಡಿದಾಗ ಸಂದರ್ಭ ಮೆನುವಿನಲ್ಲಿ Leo ಗೋಚರಿಸುತ್ತದೆ. ಇದು ಸಂದರ್ಭವನ್ನು ಪ್ರಸ್ತುತ ವೆಬ್ ಪುಟದಿಂದ Leo ಗೆ ಕಳುಹಿಸುತ್ತದೆ.</translation>
<translation id="5226020406479918122">ಟ್ಯಾಬ್ ಫೋಕಸ್ ಮೋಡ್</translation>
<translation id="3705539672403311123">ಟ್ಯಾಬ್ ಸರ್ಚಿಂಗ್‌ ಪುಟದಲ್ಲಿ ಟ್ಯಾಬ್ ಆರ್ಗನೈಸೇಷನ್‌ ಸಕ್ರಿಯಗೊಳಿಸಿ. ತೆರೆದಾಗ, ಇದು ಎಲ್ಲಾ ಖಾಸಗಿಯಲ್ಲದ ಟ್ಯಾಬ್‌ಗಳ ಶೀರ್ಷಿಕೆಗಳು ಮತ್ತು ಮೂಲಗಳನ್ನು ವರ್ಗೀಕರಿಸಲು leoಗೆ ಸ್ವಯಂಚಾಲಿತವಾಗಿ ಕಳುಹಿಸುತ್ತದೆ. <ph name="BEGIN_LINK"/>ಇನ್ನಷ್ಟು ತಿಳಿಯಿರಿ<ph name="END_LINK"/></translation>
