<translation id="8008271349880309090">ಮಾದರಿ ಆಯ್ಕೆ ಮೆನುವಿನಲ್ಲಿ ಕಾಣಿಸಿಕೊಳ್ಳುವಂತೆ ಮಾದರಿಯ ಹೆಸರು</translation>
<translation id="1355326130503900056">ಸರ್ವಿಂಗ್ ಫ್ರೇಮ್‌ವರ್ಕ್‌ನ ವಿನಂತಿಯಲ್ಲಿ ಕಾಣಿಸಿಕೊಳ್ಳಬೇಕಾದ ಮಾದರಿಯ ಹೆಸರು, ಉದಾ. phi-3 (ಸರ್ವಿಂಗ್ ಫ್ರೇಮ್‌ವರ್ಕ್‌ನಿಂದ ಈ ಹೆಸರು ನಿಖರವಾಗಿ ಹೊಂದಿಕೆಯಾಗದಿದ್ದರೆ ಇಂಟಿಗ್ರೇಷನ್‌ ಕಾರ್ಯನಿರ್ವಹಿಸುವುದಿಲ್ಲ ಎಂಬುದನ್ನು ಗಮನಿಸಿ)</translation>
<translation id="3213787232304349732">ನಿಮ್ಮ ಸರ್ವಿಂಗ್ ಫ್ರೇಮ್‌ವರ್ಕ್ ರಿಕ್ವೆಸ್ಟ್‌ಗಳನ್ನು ಆಲಿಸುತ್ತಿರುವ URL. ನಿಮಗೆ ಖಚಿತವಿಲ್ಲದಿದ್ದರೆ, ಸರ್ವಿಂಗ್ ಫ್ರೇಮ್‌ವರ್ಕ್ ಡಾಕ್ಯುಮೆಂಟ್ಸ್‌ ಪರಿಶೀಲಿಸಿ. ಉದಾ. for Ollama, ಇದು ಯಾವಾಗಲೂ http://localhost:11434/v1/chat/completions</translation>
<translation id="1058790648388035953">ಕೆಲವು ಸರ್ವಿಂಗ್ ಫ್ರೇಮ್‌ವರ್ಕ್‌ಗಳಿಗೆ API ಕೀ ಅಥವಾ ಆ್ಯಕ್ಸೆಸ್‌ ಟೋಕನ್‌ನಂತಹ ದೃಢೀಕರಣ ರುಜುವಾತುಗಳ ಅಗತ್ಯವಿರಬಹುದು. ಇವುಗಳನ್ನು ವಿನಂತಿಯ ಹೆಡರ್‌ಗೆ ಸೇರಿಸಲಾಗುತ್ತದೆ.</translation>
<translation id="4335128003329183586">ಕಂಟೆಕ್ಸ್ಟ್‌ ಗಾತ್ರ</translation>
<translation id="3153779001670804829">ಒಂದೇ ಸಂವಾದದಲ್ಲಿ ಗರಿಷ್ಠ ಸಂಖ್ಯೆಯ ಟೋಕನ್‌ಗಳನ್ನು ಪ್ರಕ್ರಿಯೆಗೊಳಿಸಬಹುದಾದ ಮಾದರಿ. ದೀರ್ಘ ಸಂಭಾಷಣೆಗಳನ್ನು ನಿರ್ವಹಿಸಲು ದೊಡ್ಡ ಮಟ್ಟದಲ್ಲಿ 
ಅವಕಾಶ ನೀಡುತ್ತದೆ. ವಿಭಿನ್ನ ಮಾದರಿಗಳು ವಿಭಿನ್ನವಾಗಿ ಗರಿಷ್ಠ ಮಟ್ಟದಲ್ಲಿ ಬೆಂಬಲಿಸುತ್ತವೆ.</translation>
<translation id="217141195370578385">Brave ಈ ವಿನಂತಿಗಳನ್ನು ಪ್ರಾಕ್ಸಿ ಮಾಡುವುದಿಲ್ಲ, ದಯವಿಟ್ಟು ಆಯ್ಕೆಮಾಡಿದ ಪೂರೈಕೆದಾರರ ಗೌಪ್ಯತೆ ನಿಯಮಗಳನ್ನು ಓದಿ.</translation>
<translation id="2645532768679870478">ಸುರಕ್ಷಿತ ಡೇಟಾ ಪ್ರಸರಣಕ್ಕಾಗಿ ಸ್ಥಳೀಯವಲ್ಲದ ಎಂಡ್‌ ಪಾಯಿಂಟ್‌ಗಳು HTTPS ಪ್ರೋಟೋಕಾಲ್ ಅನ್ನು ಬಳಸಬೇಕು.</translation>
