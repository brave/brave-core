<translation id="1181037720776840403">ತೆಗೆದುಹಾಕು</translation>
<translation id="7513769021866698486">ಐಟಂ ಎಡಿಟ್ ಮಾಡಿ</translation>
<translation id="4002066346123236978">ಶೀರ್ಷಿಕೆ</translation>
<translation id="7400418766976504921">URL</translation>
<translation id="5877900074358050101">ಸೈಡ್‌ಬಾರ್ ಐಟಂ ಶೀರ್ಷಿಕೆ</translation>
<translation id="1613695740874407223">ಸೈಡ್‌ಬಾರ್ ಐಟಂ url</translation>
<translation id="4877147287319222750">ಸೈಡ್‌ಬಾರ್‌ಗೆ ಸೇರಿಸಿ</translation>
<translation id="2422927186524098759">ಸೈಡ್‌ಬಾರ್</translation>
