<translation id="7093267802941377072">Tùy chọn "Chặn tất cả cookie" đã bị vô hiệu hóa. Để tìm hiểu cách bắt buộc bật tùy chọn này, hãy truy cập <ph name="BEGIN_LINK"/>trang trợ giúp của chúng tôi<ph name="END_LINK"/></translation>
<translation id="6196640612572343990">Chặn cookie của bên thứ ba</translation>
<translation id="5657156137487675418">Cho phép mọi cookie.</translation>
<translation id="6883611015375728278">Chặn tất cả cookie</translation>
<translation id="7390783310074170337">Chế độ xem mặc định</translation>
<translation id="130615081792797568">Chế độ xem đơn giản</translation>
<translation id="2360360976480535628">Chế độ xem nâng cao</translation>
<translation id="101592339984642584">Lọc nội dung</translation>
<translation id="2398817776566547893">Bật bộ lọc tùy chỉnh chặn các trình theo dõi theo khu vực và ngôn ngữ cụ thể và Phiền toái</translation>
<translation id="3482656215021340727">Thêm danh sách bộ lọc tùy chỉnh</translation>
<translation id="1020877116991797978">Thêm danh sách bổ sung được tạo và duy trì bởi cộng đồng đáng tin cậy của bạn.</translation>
<translation id="7617831480435794399">Chỉ đăng ký danh sách từ các tổ chức mà bạn tin tưởng. Trình duyệt của bạn sẽ kiểm tra định kỳ các cập nhật danh sách từ URL bạn nhập, tiết lộ địa chỉ IP của bạn cho máy chủ của họ.</translation>
<translation id="8580328754808744073">Tạo bộ lọc tùy chỉnh</translation>
<translation id="4618274268052410139">Thêm bộ lọc tùy chỉnh bạn đã tạo, mỗi bộ lọc trên một dòng, vào trường bên dưới. Đảm bảo sử dụng <ph name="BEGIN_LINK"/>Cú pháp bộ lọc chặn quảng cáo<ph name="END_LINK"/>.</translation>
<translation id="7791543448312431591">Thêm</translation>
<translation id="3075903430639801825">Tiêu đề danh sách</translation>
<translation id="9204006549413740506">Cập nhật mới nhất</translation>
<translation id="6745592621698551453">Cập nhật ngay bây giờ</translation>
<translation id="5334844597069022743">Xem nguồn</translation>
<translation id="4720556299488643018">Hủy đăng ký</translation>
<translation id="6532106788206463496">Lưu thay đổi</translation>
<translation id="4516904298421534459">Lọc danh sách</translation>
<translation id="4435215931544457255">Danh sách cộng đồng phổ biến bổ sung. Lưu ý rằng việc bật quá nhiều bộ lọc sẽ làm giảm tốc độ duyệt web.</translation>
<translation id="802154636333426148">Tải xuống không thành công</translation>
