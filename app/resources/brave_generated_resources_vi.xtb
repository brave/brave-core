<translation id="5438573563213942361">Danh sách tùy chỉnh</translation>
<translation id="4182731739150761577">Hiển thị danh sách đầy đủ</translation>
<translation id="2776571540844891267">Cập nhật danh sách</translation>
<translation id="7424267932649051704">Cập nhật không thành công - Hãy thử lại</translation>
<translation id="8426801388284487512">Đã cập nhật danh sách</translation>
