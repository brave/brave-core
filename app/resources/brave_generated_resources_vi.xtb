<translation id="3512883292907992390">Cho phép các trang web tự động phát video</translation>
<translation id="1876603079388924308">Chặn các trang web tự động phát video</translation>
<translation id="1448289340149908413">Ethereum</translation>
<translation id="6583467242903731748">Hỏi khi trang web muốn truy cập vào API của nhà cung cấp Ethereum</translation>
<translation id="7017590444693657895">Chặn các trang web truy cập API của nhà cung cấp Ethereum</translation>
<translation id="5390923430722428146">Solana</translation>
<translation id="4539536028173362640">Hỏi khi một trang web muốn truy cập vào API của nhà cung cấp Solana</translation>
<translation id="2777102601740875941">Chặn các trang web truy cập API của nhà cung cấp Solana</translation>
<translation id="6420374098612710803">Cardano</translation>
<translation id="2791323819881188032">Hỏi khi trang web muốn truy cập vào API của nhà cung cấp Cardano</translation>
<translation id="2354424632502836676">Chặn các trang web truy cập API của nhà cung cấp Cardano</translation>
<translation id="4206299587103092719">Đăng nhập bằng Google</translation>
<translation id="9110294136812584522">Các trang web có thể yêu cầu sử dụng Đăng nhập bằng Google cũ thông qua cookie của bên thứ ba</translation>
<translation id="2903783737778379345">Không cho phép Đăng nhập bằng Google cũ thông qua cookie của bên thứ ba</translation>
<translation id="2570833232754279153">Không cho phép sử dụng cookie của bên thứ ba cho Đăng nhập bằng Google cũ</translation>
<translation id="6880817299303842099">Cho phép sử dụng cookie của bên thứ ba cho Đăng nhập bằng Google cũ</translation>
<translation id="5794692721727586076">Trò chuyện Leo AI</translation>
<translation id="8115153008662981040">Các trang web có thể yêu cầu mở trò chuyện Leo AI</translation>
<translation id="1145070115730668595">Không cho phép trang web mở trò chuyện Leo AI</translation>
<translation id="5565355416171743213">Bắt đầu sử dụng đồng bộ hóa</translation>
<translation id="4332558599726753990">Cài đặt Đồng bộ</translation>
<translation id="2187778349654214731">Để bắt đầu, bạn sẽ cần cài đặt Brave trên tất cả các thiết bị bạn dự định đồng bộ hóa. Sau đó, liên kết chúng với nhau một cách bảo mật bằng mã đồng bộ hóa.</translation>
<translation id="7530575064080939974">Quản lý thiết bị đã đồng bộ hóa của bạn</translation>
<translation id="8668872235103666008">Không thể đồng bộ Brave trên thiết bị của bạn</translation>
<translation id="7575156386943878014">Trình quản lý Đồng bộ hóa</translation>
<translation id="1755198127524719638">Cài đặt Đồng bộ</translation>
<translation id="7558480201297099157">Quản lý các thông tin bạn muốn đồng bộ hóa trên các thiết bị. Các cài đặt này chỉ tác động đến thiết bị này.</translation>
<translation id="7731928563672901833">Danh sách Thiết bị</translation>
<translation id="28332161031213248">Danh sách thiết bị bên dưới bao gồm tất cả các thiết bị trong chuỗi đồng bộ của bạn. Mỗi thiết bị có thể được quản lý từ bất kỳ thiết bị nào khác.</translation>
<translation id="1313162974556054106">Tên Thiết bị</translation>
<translation id="923757506389336140"><ph name="DEVICE_NAME"/> (Thiết bị Này)</translation>
<translation id="3686835020221422649">Hoạt động Lần cuối</translation>
<translation id="2569646144216067185">Số từ: <ph name="WORD_COUNT"/></translation>
<translation id="7885157704277298658">Đã sao chép!</translation>
<translation id="8802630444265810662">Mã QR phải được quét bằng thiết bị di động để truyền mã đồng bộ hóa của bạn</translation>
<translation id="6221331245829088299">Đã xảy ra lỗi khi hiển thị mã QR, xin vui lòng làm mới và thử lại.</translation>
<translation id="298546024891487702">Để bắt đầu, bạn sẽ cần cài đặt Brave trên tất cả các thiết bị bạn dự định đồng bộ. Để liên kết các thiết bị này lại với nhau, hãy bắt đầu chuỗi đồng bộ mà bạn sẽ sử dụng để liên kết bảo mật tất cả các thiết bị của bạn lại với nhau.</translation>
<translation id="6200528822592747640">Bắt đầu Chuỗi Đồng bộ mới</translation>
<translation id="5184726904895809379">Tôi có Mã Đồng bộ</translation>
<translation id="8780295742023331191">Xem Mã Đồng bộ</translation>
<translation id="9017050385815017931">Điện thoại/Máy tính bảng</translation>
<translation id="1736420071277903564">Máy tính</translation>
<translation id="3407602902101449803">Mã QR Chuỗi Đồng bộ</translation>
<translation id="8369686073965491869">Trên thiết bị di động của bạn, vào mục Đồng bộ Brave trong bảng Cài đặt và nhấp vào nút</translation>
<translation id="6527776448555649991">“Quét Mã Đồng bộ”.</translation>
<translation id="1400862780574843709">Sử dụng máy ảnh của bạn để quét Mã QR bên dưới.</translation>
<translation id="5086223971958279691">Mã Chuỗi Đồng bộ</translation>
<translation id="2899261497479389619">Trên máy tính mục tiêu của bạn, vào mục Đồng bộ Brave trong cài đặt và nhấp vào nút</translation>
<translation id="4827439149833241990">“Tôi có Mã Đồng bộ”.</translation>
<translation id="8299617838343103908">Nhập từ mã chuỗi đồng bộ được hiển thị bên dưới.</translation>
<translation id="4485276108749547761">Hãy coi mã này như một mật khẩu. Nếu ai đó có được mã này, họ có thể đọc và sửa đổi dữ liệu đã đồng bộ hóa của bạn.</translation>
<translation id="3034163433136515805">Xem Mã QR</translation>
<translation id="5373825572723282843">Nhập mã đồng bộ</translation>
<translation id="1265244359514651398">Nhập cụm mật khẩu chuỗi đồng bộ hóa của bạn bên dưới.</translation>
<translation id="1061533051865606843">Thêm Thiết bị Mới</translation>
<translation id="5093410893656857925">Chọn Loại Thiết bị</translation>
<translation id="4581190919849683048">Bạn muốn đồng bộ hóa đến loại thiết bị nào?</translation>
<translation id="4112587618563511470">Mã đồng bộ hóa không hợp lệ, xin vui lòng kiểm tra và thử lại.</translation>
<translation id="3995714999835224798">Mã này không hợp lệ</translation>
<translation id="4432071071853308688">Mã này trống</translation>
<translation id="955848693465029904">Lỗi thiết lập đồng bộ nội bộ</translation>
<translation id="7456398316301207582">Lỗi xóa tài khoản nội bộ</translation>
<translation id="859506441384380749">Mã này được tạo ra bởi một phiên bản cũ của Brave, hãy nâng cấp thiết bị kia của bạn trước</translation>
<translation id="3132642509209154999">Mã này đã hết hạn. Vui lòng tạo một mã mới trên thiết bị kia của bạn và thử lại.</translation>
<translation id="2859229680945501779">Mã này không hợp lệ. Vui lòng kiểm tra xem thời gian và múi giờ có được đặt chính xác trên thiết bị của bạn không.</translation>
<translation id="2339730291919608488">Rời chuỗi đồng bộ</translation>
<translation id="115699408012835975">Nếu bạn đặt lại Đồng bộ hóa, bạn sẽ phải nhập lại mã đồng bộ hóa từ một thiết bị khác để đồng bộ hóa với thiết bị đó. Bạn có chắc muốn tiếp tục không?</translation>
<translation id="6092564993102418148">Bạn có chắc chắn muốn gỡ thiết bị đã chọn khỏi chuỗi đồng bộ hóa không?</translation>
<translation id="4400414577602898435">Cảnh báo: việc này sẽ chia sẻ dữ liệu Brave của bạn, bao gồm cả mật khẩu của bạn, với thiết bị đã tạo ra các từ mã này.

    Vui lòng kiểm tra kỹ xem các từ mã này có được tạo bởi thiết bị mà bạn sở hữu hay không.

    Bạn có chắc chắn muốn làm điều này?</translation>
<translation id="7443185843787879670">Brave không thể truy cập bộ nhớ an toàn của hệ điều hành của bạn. Đây là những gì được sử dụng để bảo mật dữ liệu như mật khẩu và cookie; Brave Đồng bộ cũng cần để kết nối hồ sơ trình duyệt của bạn giữa các thiết bị. Điều này có nghĩa là Brave Đồng bộ không chạy. Để giải quyết vấn đề này, vui lòng xem <ph name="BEGIN_LINK_SYNC_GUIDE"/>Hướng dẫn khắc phục sự cố Brave Đồng bộ<ph name="END_LINK_SYNC_GUIDE"/>.</translation>
<translation id="6802736947576520626">Có vẻ như khóa mã hóa đồng bộ hóa khác với khóa được sử dụng khi bạn thiết lập Brave Đồng bộ lần đầu. Cách khắc phục đơn giản nhất ở đây là đặt lại và tham gia lại chuỗi đồng bộ bằng cách sử dụng cụm mật khẩu từ một trong các thiết bị được đồng bộ hóa khác của bạn.</translation>
<translation id="4889767840132638381">Đặt lại và tham gia lại chuỗi đồng bộ</translation>
<translation id="1680065323266179640">Xóa tài khoản Đồng bộ</translation>
<translation id="9064376100690171155">Xóa vĩnh viễn tài khoản</translation>
<translation id="228906529296554286">Việc xóa tài khoản của bạn sẽ xóa dữ liệu được mã hóa của bạn khỏi máy chủ Brave và tắt Đồng bộ trên tất cả các thiết bị được kết nối của bạn.</translation>
<translation id="7578652532113583362">Tuy nhiên, việc xóa tài khoản Đồng bộ sẽ không xóa dữ liệu được lưu trữ cục bộ trên các thiết bị đó.</translation>
<translation id="2516405584294312544">Việc xóa này là vĩnh viễn và không có cách nào để khôi phục dữ liệu. Nếu bạn quyết định
    bắt đầu sử dụng lại Đồng bộ hóa, bạn sẽ cần tạo một tài khoản mới và thêm lại từng thiết bị.</translation>
<translation id="4860996720371753023">Đang xóa tài khoản...</translation>
<translation id="4094590686212463338">Không thể tham gia chuỗi đồng bộ hóa này. Chuỗi đồng bộ hóa đã bị xóa.</translation>
<translation id="4908081302669157000">Số điện thoại, email và địa chỉ</translation>
<translation id="294985549514492876">Ứng dụng web (PWA)</translation>
<translation id="7029809446516969842">Mật khẩu</translation>
<translation id="6011308810877101166">Cải thiện gợi ý tìm kiếm</translation>
<translation id="2332576387809612040">Khi được bật, Brave sẽ gửi nội dung bạn nhập vào thanh địa chỉ hoặc hộp tìm kiếm đến công cụ tìm kiếm mặc định của bạn để đưa ra các gợi ý tốt hơn. Nếu bạn chọn tắt, Brave chỉ hiển thị các đề xuất được tạo trên thiết bị của bạn. Tùy chọn này luôn ở trạng thái tắt trong cửa sổ duyệt web riêng tư.</translation>
<translation id="5522403133543437426">Công cụ tìm kiếm được sử dụng trên thanh địa chỉ.</translation>
<translation id="280472502078788655">Công cụ tìm kiếm được sử dụng trên thanh địa chỉ cho cửa sổ riêng tư.</translation>
<translation id="7232120595886556478">Cửa sổ bình thường</translation>
<translation id="6739674350896546324">Công cụ tìm kiếm cho Cửa sổ Riêng tư</translation>
<translation id="1280261732441045146">Giờ đây <ph name="SEARCH_ENGINE_NAME"/> là công cụ tìm kiếm mặc định của bạn cho cửa sổ riêng tư</translation>
<translation id="5363742888375478536">Chúng tôi khuyến nghị sử dụng Brave Tìm kiếm để có trải nghiệm duyệt tốt nhất trên trình duyệt Brave.</translation>
<translation id="7298195798382681320">Đề xuất</translation>
<translation id="6864914031231797928">Cho phép đăng nhập bằng Google cho các tiện ích mở rộng</translation>
<translation id="1519976482053221804">Bộ định tuyến phương tiện cho phép tính năng truyền trong trình duyệt</translation>
<translation id="2707635989000984973">Xử lý các tên miền Unstoppable Domains</translation>
<translation id="732344438514476996"><ph name="BEGIN_LINK"/>Tìm hiểu thêm<ph name="END_LINK"/> về các cân nhắc quyền riêng tư của Unstoppable Domains</translation>
<translation id="641308776160806829">Xử lý các tên miền Ethereum Name Service (ENS)</translation>
<translation id="6421218422395686663">Cho phép tra cứu chuỗi ngoại tuyến ENS.</translation>
<translation id="4608449984413688436">Xử lý các tên miền Solana Name Service (SNS)</translation>
<translation id="7831978744512353629"><ph name="BEGIN_LINK"/>Tìm hiểu thêm<ph name="END_LINK"/> về các cân nhắc quyền riêng tư trong tra cứu chuỗi ngoại tuyến ENS.</translation>
<translation id="6241402707160226266">Cửa sổ riêng tư với Tor</translation>
<translation id="8762452230727230396">Tor ẩn địa chỉ IP của bạn khỏi các trang web bạn truy cập.</translation>
<translation id="951983619130191090">Tình nguyện giúp người khác kết nối với mạng Tor</translation>
<translation id="2223668809371912019">Bật tiện ích mở rộng Snowflake để cho phép người dùng ở các quốc gia bị kiểm duyệt kết nối với mạng Tor thông qua kết nối mạng của bạn.</translation>
<translation id="2959986444009520721">Sử dụng cầu nối</translation>
<translation id="271237727681958372">Cầu nối giúp bạn truy cập Mạng Tor ở những nơi Tor bị chặn. Tùy thuộc vào vị trí của bạn, cầu nối này có thể hoạt động tốt hơn các cầu nối khác.</translation>
<translation id="7206799843254049470">Cài đặt kết nối Tor</translation>
<translation id="3194502271166340944">Kiểm soát cách Cửa sổ Riêng tư có Tor kết nối với mạng Tor</translation>
<translation id="3717364961460790491">Không thể tải xuống tiện ích mở rộng Snowflake cần thiết cho chức năng này. Vui lòng kiểm tra kết nối internet của bạn và thử lại.</translation>
<translation id="4859228830700205299">Chọn cầu nối tích hợp sẵn</translation>
<translation id="3233137871426528317">Yêu cầu cầu nối từ torproject.org</translation>
<translation id="5701503934456421898">Yêu cầu Cầu nối mới...</translation>
<translation id="8149806369020180959">Cung cấp cầu nối</translation>
<translation id="454073978993625597">Nhập thông tin cầu từ nguồn đáng tin cậy.</translation>
<translation id="4425607417590286548">Áp dụng thay đổi</translation>
<translation id="2128143836897950793">Nhấp vào 'Yêu cầu Cầu nối mới...' để nhận cầu</translation>
<translation id="3314921753580327793">Nhập address:port (mỗi dòng nhập một)</translation>
<translation id="3755189300481406891">Yêu cầu Cầu nối</translation>
<translation id="6924425739431382319">Đang liên hệ BridgeDB. Vui lòng chờ.</translation>
<translation id="811745063252080651">Giải mã CAPTCHA để yêu cầu cầu nối.</translation>
<translation id="6936835573742749135">Không thể yêu cầu CAPTCHA. Thử lại sau.</translation>
<translation id="2653659639078652383">Gửi</translation>
<translation id="1294350054292274934">Chỉ giải quyết các địa chỉ .onion trong cửa sổ Tor</translation>
<translation id="4745128937437681681">Dịch vụ Onion sẽ không khả dụng bên ngoài cửa sổ Tor</translation>
<translation id="6305528566126073902">Sử dụng thành phần quản lý bản quyền kỹ thuật số Widevine (DRM) để xem video phát trực tuyến được bảo vệ và nội dung khác trong trình duyệt</translation>
<translation id="1314131187310290315">Tiện ích mở rộng Manifest V2</translation>
<translation id="2488433650767270565">Các tiện ích mở rộng Manifest V2 sau đây sẽ bị xóa khỏi Cửa hàng Chrome trực tuyến nhưng vẫn được hỗ trợ trong Brave. Chuyển đổi để tải xuống và cài đặt hoặc để gỡ cài đặt.</translation>
<translation id="6918225713618473646">Brave lưu trữ các phần mở rộng Manifest V2 này trên máy chủ Brave, nhưng không xem xét hoặc xác minh nội dung, bảo mật hoặc hành vi của chúng. Vui lòng tham khảo trang web chính thức của từng phần mở rộng để được hỗ trợ. Bạn có thể xem các kế hoạch của Brave cho Manifest V2 <ph name="BEGIN_LINK"/>tại đây<ph name="END_LINK"/>.</translation>
<translation id="578671172657727816">Bật NoScript™</translation>
<translation id="9068475464170522036">NoScript là tiện ích mở rộng Manifest V2 cho phép bạn chặn và bỏ chặn các tập lệnh riêng lẻ đang chạy hoặc cố gắng chạy trên một trang nhất định.</translation>
<translation id="1394592156621788100">Bật uBlock Origin™</translation>
<translation id="2638983091068889519">uBlock Origin là tiện ích mở rộng Manifest V2 cung cấp các công cụ chặn nội dung mạnh mẽ với nhiều tùy chọn cho người dùng nâng cao.</translation>
<translation id="3909078036552544838">Bật uMatrix™</translation>
<translation id="8796148218203577506">uMatrix là tiện ích mở rộng Manifest V2 cung cấp tường lửa dựa trên ma trận trỏ và nhấp, với nhiều công cụ nâng cao quyền riêng tư.</translation>
<translation id="2385774023523989298">Bật AdGuard™</translation>
<translation id="188228077840632890">AdGuard là tiện ích mở rộng Manifest V2 cung cấp tùy chọn chặn quảng cáo, kiểm soát của phụ huynh và tích hợp với các dịch vụ AdGuard khác.</translation>
<translation id="8137559199583651773">Quản lý tiện ích</translation>
<translation id="7013485839273047434">Tải về thêm phần mở rộng</translation>
<translation id="4954512758656527938">Ví Ethereum mặc định</translation>
<translation id="7701023802820268122">Ví Solana mặc định</translation>
<translation id="3991455933137809014">Ví Cardano mặc định</translation>
<translation id="8488282162676695335">Ví Brave</translation>
<translation id="6942354363301686374">Tiện ích mở rộng (không dự phòng)</translation>
<translation id="702381242110464396">Tiện ích mở rộng (Dự phòng Ví Brave)</translation>
<translation id="4718664830805652430">Tiền tệ cơ sở mặc định</translation>
<translation id="7992507032049865603">Tiền mã hóa cơ sở mặc định</translation>
<translation id="3044369626313583722">Hiển thị nút Ví Brave</translation>
<translation id="7568430944629653319">Bật khám phá NFT</translation>
<translation id="970496996377628529">Tự động thêm NFT mà bạn sở hữu vào Ví bằng API của bên thứ ba.</translation>
<translation id="8421293929927030255">Kích hoạt Ví Brave trong cửa sổ riêng tư</translation>
<translation id="1729224157015744629">Cảnh báo: Việc sử dụng lại địa chỉ ví trong phiên cửa sổ riêng tư có thể cho phép trang web liên kết phiên cửa sổ riêng tư với phiên cửa sổ không riêng tư</translation>
<translation id="8239147115686034860">Tự động khóa Ví Brave</translation>
<translation id="414639769490080648">Số phút phải chờ cho đến khi Ví Brave được tự động khóa lại</translation>
<translation id="856371974127598760">Mạng ví</translation>
<translation id="5975930666279943472">Xóa giao dịch ví và thông tin số giao dịch</translation>
<translation id="5693968582510626466">Việc xóa các giao dịch có thể hữu ích cho các nhà phát triển hoặc khi xóa trạng thái trên máy chủ cục bộ</translation>
<translation id="6171369470447621882">Đặt lại trạng thái đồng bộ hóa Zcash</translation>
<translation id="6705112675071480687">Đặt lại tiến trình đồng bộ hóa Zcash cho tất cả tài khoản được bảo vệ</translation>
<translation id="2012093487873597892">Bạn có chắc muốn đặt lại trạng thái đồng bộ hóa Zcash? Tiến trình đồng bộ hóa cho tất cả các tài khoản được bảo vệ sẽ bị hủy. Nhập "<ph name="CONFIRMATION_PHRASE"/>" để xác nhận.</translation>
<translation id="5031551083187285762">Trạng thái đồng bộ hóa tài khoản Zcash của bạn đã được đặt lại.</translation>
<translation id="9216386092464743272">Bạn có chắc chắn muốn đặt lại tất cả giao dịch ví và thông tin số giao dịch của mình không? Tùy chọn này chủ yếu được sử dụng bởi các nhà phát triển đang chạy máy chủ kiểm thử nội bộ. Nhập "<ph name="CONFIRMATION_PHRASE"/>" để xác nhận.</translation>
<translation id="2326850911705720398">Thiết lập lại và xóa dữ liệu ví</translation>
<translation id="6369495274982305511">Bạn có chắc chắn muốn đặt lại ví của mình không? Nếu ví của bạn không được sao lưu, việc đặt lại sẽ khiến bạn mất tất cả dữ liệu tài khoản (bao gồm mọi khoản tiền liên kết). Gõ "<ph name="CONFIRMATION_PHRASE"/>" để xác nhận.</translation>
<translation id="3752403403443723332">Ví của bạn đã được đặt lại.</translation>
<translation id="594766067816395072">Thông tin giao dịch ví của bạn đã được đặt lại.</translation>
<translation id="57798285717509216">Xem kết quả giao dịch trước khi ký. <ph name="BEGIN_LINK"/>&lt;u&gt;Tìm hiểu thêm&lt;/u&gt;<ph name="END_LINK"/></translation>
<translation id="4226543734057230801">Mạng Ethereum</translation>
<translation id="3504157706952484145">Mạng Filecoin</translation>
<translation id="1561541094377237745">Mạng Solana</translation>
