<translation id="3176794108951154148">Mạng Polkadot</translation>
<translation id="3159419679550543837">Hiển thị các mạng thử nghiệm</translation>
<translation id="3215569562674795548">Chỉnh sửa hoặc thêm mạng mới</translation>
<translation id="4418993400653250511">Mã chuỗi</translation>
<translation id="3423620355610881890">Một số thập phân dương</translation>
<translation id="8110465398315041268">Tìm kiếm mạng</translation>
<translation id="3579705520805744214">Mã hoặc tên chuỗi</translation>
<translation id="8502525913969149079">Tên chuỗi</translation>
<translation id="1034112277864078119">Nhập tên chuỗi</translation>
<translation id="4672314527143443556">Tên tiền tệ của chuỗi</translation>
<translation id="4652114030688989556">Nhập tên tiền tệ</translation>
<translation id="1079960017149736097">Ký hiệu tiền tệ của chuỗi</translation>
<translation id="1288105009659846362">Nhập ký hiệu tiền tệ</translation>
<translation id="665660671251623018">Số thập phân tiền tệ của chuỗi</translation>
<translation id="2978054488731497946">Nhập số thập phân tiền tệ</translation>
<translation id="2727514928168763432">URL RPC</translation>
<translation id="7059127752542505809">Nhập URL</translation>
<translation id="3047726704186619366">URL biểu tượng</translation>
<translation id="2487558607408469181">Chặn URL trình khám phá</translation>
<translation id="2156993118928861787">Địa chỉ không hợp lệ</translation>
<translation id="2042467807419742999">Trường này không được để trống.</translation>
<translation id="7504462451153306677">Định dạng không hợp lệ, ID chuỗi là một số dương</translation>
<translation id="650071759190249039">Lỗi nội bộ, không thể thêm mạng.</translation>
<translation id="336035846712292194">Vui lòng điền tất cả thông tin về đồng tiền nguyên bản</translation>
<translation id="1062463687579789365">Tùy biến mạng ví</translation>
<translation id="2234108191702901162">Không thể thêm mạng</translation>
<translation id="8996633027318264334">Bạn có thực sự muốn xóa <ph name="KEY_NAME"/>không?</translation>
<translation id="8633484167132172058">Mạng mặc định luôn hiển thị trong danh sách mạng ví</translation>
<translation id="232693303726691609">Hiện/ẩn mạng trong danh sách mạng ví</translation>
<translation id="7893578599666249602">Bạn có thực sự muốn đặt lại <ph name="KEY_NAME"/> không?</translation>
<translation id="2618193846561624884">Bạn có muốn cập nhật mạng hiện có không?</translation>
<translation id="1643029991199044105">Chuyển qua các tab được sử dụng gần đây nhất bằng Ctrl-Tab</translation>
<translation id="2775956301559569472">Hiển thị lời nhắc Wayback Machine trên các trang 404</translation>
<translation id="3095201688102519917">Cảnh báo tôi trước khi đóng cửa sổ với nhiều tab</translation>
<translation id="7120553802660696133">Đóng cửa sổ khi đóng tab cuối cùng</translation>
<translation id="3394171693948989253">Hiển thị lời nhắc toàn màn hình để nhấn Esc khi thoát</translation>
<translation id="6129027151000961048">Leo</translation>
<translation id="2751872555001636931">Hiển thị biểu tượng Leo trong thanh bên</translation>
<translation id="8055509865174199683">Hiển thị Leo trong menu ngữ cảnh trên trang web</translation>
<translation id="1529674267267221673">Leo sẽ xuất hiện trong menu ngữ cảnh khi bạn nhấp chuột phải vào trang web. Thao tác này sẽ gửi ngữ cảnh từ trang web hiện tại tới Leo.</translation>
<translation id="5226020406479918122">Chế độ Tập trung thẻ</translation>
<translation id="3705539672403311123">Bật sắp xếp thẻ trong trang Tìm kiếm thẻ. Khi mở, tính năng này sẽ tự động gửi tiêu đề và nguồn gốc của tất cả thẻ không riêng tư đến Leo để phân loại. <ph name="BEGIN_LINK"/>Tìm hiểu thêm<ph name="END_LINK"/></translation>
<translation id="8172263161008556851">Hiển thị lời nhắc được đề xuất trong cuộc trò chuyện</translation>
<translation id="5781842473834867765">Lưu lịch sử trò chuyện</translation>
<translation id="1082960401708055995">Tắt tùy chọn lưu lịch sử trò chuyện sẽ xóa vĩnh viễn tất cả cuộc trò chuyện đã được lưu. Hành động này không thể được hoàn tác.</translation>
<translation id="1014480593522400586">Xóa dữ liệu Leo</translation>
<translation id="5256236967791936135">Việc thiết lập lại Leo AI sẽ yêu cầu bạn chọn tham gia sử dụng Brave
Leo AI trong tương lai và cũng sẽ xóa lịch sử trò chuyện, các tùy chỉnh và ký ức. Xóa lịch sử trò chuyện của bạn sẽ xóa tất cả các cuộc trò chuyện trước đó của bạn với Brave Leo AI. Hành động này không thể được hoàn tác.</translation>
<translation id="5574059574002819179">Điều chỉnh đề xuất tự động hoàn thành</translation>
<translation id="7942415993090181327">Lịch sử trò chuyện</translation>
<translation id="5084498230659987096">Brave Leo cung cấp tính năng trò chuyện AI tôn trọng quyền riêng tư và các giao diện tích hợp AI khác trong trình duyệt. Leo không bao giờ học từ dữ liệu của bạn hoặc sử dụng dữ liệu đó để đào tạo mô hình. Tất cả yêu cầu đều được chuyển tiếp qua máy chủ ẩn danh.</translation>
<translation id="6458721693611638005">Đọc thêm về cách Brave bảo vệ việc bạn sử dụng AI trong chính sách quyền riêng tư của Leo. <ph name="BEGIN_LINK"/>Tìm hiểu thêm<ph name="END_LINK"/></translation>
<translation id="614530507403667291">Mô hình mặc định cho các cuộc trò chuyện mới</translation>
<translation id="6340526405444716530">Cá nhân hóa</translation>
<translation id="5077965667729100040">Tùy chỉnh câu trả lời và ký ức của Leo</translation>
<translation id="8826914609353373601">Quản lý đăng ký trả phí</translation>
<translation id="235457946228076038">Mang theo mô hình của riêng bạn</translation>
<translation id="8631951653187535788">Bạn có chắc chắn muốn xóa mô hình này không? Nếu mô hình này đang được sử dụng trong bất kỳ cuộc trò chuyện đang hoạt động nào thì cuộc trò chuyện đó sẽ thay đổi để sử dụng mô hình mặc định của Leo.</translation>
<translation id="1907126221851170941">Thêm mô hình</translation>
<translation id="8346224718149026088">Sửa mô hình</translation>
<translation id="3468298837301810372">Nhãn</translation>
<translation id="3553035516792776805">Tên yêu cầu mô hình</translation>
<translation id="7634775528597575156">Điểm cuối máy chủ</translation>
<translation id="6374563306438145841">Khóa API</translation>
<translation id="3295756655687327124">Hỗ trợ Hình ảnh</translation>
<translation id="1415432774589088566">Nếu mô hình này chấp nhận đầu vào là hình ảnh, ví dụ như llama 3.2b vision</translation>
<translation id="8008271349880309090">Tên của mô hình sẽ xuất hiện trong menu chọn mô hình</translation>
<translation id="1355326130503900056">Tên của mô hình khi sẽ xuất hiện trong yêu cầu tới khung phục vụ, ví dụ phi-3 (lưu ý rằng nếu tên này không khớp chính xác với những gì khung phục vụ mong đợi thì sẽ không tích hợp được)</translation>
<translation id="3213787232304349732">URL nơi khung phục vụ của bạn đang lắng nghe các yêu cầu. Nếu bạn không chắc chắn thì hãy kiểm tra tài liệu về khung phục vụ. Ví dụ: đối với Ollama, đây luôn là http://localhost:11434/v1/chat/completions</translation>
<translation id="1058790648388035953">Một số khung phục vụ có thể yêu cầu thông tin xác thực, chẳng hạn như khóa API hoặc mã thông báo truy cập. Những thông tin này sẽ được thêm vào tiêu đề yêu cầu.</translation>
<translation id="4335128003329183586">Kích thước ngữ cảnh</translation>
<translation id="3153779001670804829">Số token tối đa mô hình có thể xử lý trong một tương tác duy nhất. Kích thước ngữ cảnh lớn hơn cho phép mô hình xử lý các cuộc hội thoại dài hơn. Các mô hình khác nhau hỗ trợ các kích thước ngữ cảnh tối đa khác nhau.</translation>
<translation id="217141195370578385">Brave không ủy quyền cho những yêu cầu này, vui lòng đọc điều khoản bảo mật của nhà cung cấp đã chọn.</translation>
<translation id="2645532768679870478">Các điểm cuối không phải cục bộ nên sử dụng giao thức HTTPS để truyền dữ liệu an toàn.</translation>
<translation id="8177205483022887785">Bạn đã nhập URL không hợp lệ. Vui lòng nhập URL hợp lệ.</translation>
<translation id="6333402912272476257">Điểm cuối này có khả năng không an toàn.</translation>
<translation id="4025470490371933693">Không cho phép IP riêng tư</translation>
<translation id="3670571614478401810">Địa chỉ bạn nhập có vẻ là từ một mạng riêng tư, như bộ định tuyến hoặc máy chủ cục bộ. Brave tự động chặn các địa chỉ này để giữ an toàn cho bạn, nhưng bạn có thể bật nếu bạn tin rằng chúng an toàn.</translation>
<translation id="4932437543207655965">Để tiếp tục, truy cập brave://flags/, tìm "brave-ai-chat-allow-private-ips" và bật tính năng này. Sau khi bật, bạn có thể sử dụng địa chỉ mạng riêng tư trong cài đặt Leo.</translation>
<translation id="5249539665306267943">Thêm mô hình mới</translation>
<translation id="7265212806651512211">Bạn vẫn chưa kết nối mô hình.</translation>
<translation id="7304802428852949897">Các mô hình của bạn</translation>
<translation id="7435587476558117990">Kết nối LLM do bạn tự lưu trữ hoặc do bên thứ ba lưu trữ với Leo và sử dụng chúng trong trình duyệt.</translation>
<translation id="8137606697798069075">Bạn có thể sử dụng bất kỳ nền tảng nào hỗ trợ OpenAI Chat Protocol, như Ollama. <ph name="BEGIN_LINK"/>Tìm hiểu thêm<ph name="END_LINK"/></translation>
<translation id="2642905648178380593">Lưu mô hình</translation>
<translation id="6304169450064541679">Prompt hệ thống</translation>
<translation id="3081947790648024460">Hướng dẫn tùy chỉnh và/hoặc ngữ cảnh được cung cấp cho mô hình để hướng dẫn phản hồi của mô hình theo một hướng hoặc phong cách cụ thể. Sử dụng %datetime% khi bạn muốn chèn ngày và giờ hiện tại.</translation>
<translation id="5688878061573389791">≈<ph name="TOKENS_COUNT"/> token</translation>
<translation id="6911466383346197271">Tùy chỉnh Leo</translation>
<translation id="5702085383070170010">Thông tin về bạn</translation>
<translation id="2493241731563937877">Cho Leo biết về bạn để có những câu trả lời được cá nhân hóa hơn. <ph name="BEGIN_LINK"/>Tìm hiểu thêm<ph name="END_LINK"/></translation>
<translation id="8536280915366791221">Bật tùy chỉnh Leo</translation>
<translation id="698972836993887081">Bật ký ức về người dùng</translation>
<translation id="4256342809997283108">Leo nên gọi bạn là gì?</translation>
<translation id="1362393385416256849">Nhập tên bạn muốn Leo sử dụng khi nhắc đến bạn</translation>
<translation id="7841672648317556034">Công việc của bạn là gì?</translation>
<translation id="1228535384519357095">Chia sẻ một số thông tin về công việc của bạn với Leo</translation>
<translation id="1300619108689988155">Leo nên trả lời câu hỏi của bạn như thế nào?</translation>
<translation id="5071940952740278148">Mô tả giọng điệu và đặc tính bạn mong muốn Leo sử dụng khi trả lời</translation>
<translation id="5647284470247510206">Còn điều gì Leo cần biết về bạn không?</translation>
<translation id="7228073810237286235">Cho Leo biết bất kỳ điều gì bạn muốn Leo lưu ý khi trả lời</translation>
<translation id="683188035663069399">Đã lưu thay đổi</translation>
<translation id="6708571471662618310">Nội dung quá dài</translation>
<translation id="8213464188712611711">Ký ức</translation>
<translation id="736384197563279828">Tất cả thông tin Leo đã học được về bạn và sẽ không bao giờ quên. <ph name="BEGIN_LINK"/>Tìm hiểu thêm<ph name="END_LINK"/></translation>
<translation id="4664222465181795837">Chưa tạo ký ức nào</translation>
<translation id="8914960762169062277">Thêm ký ức để giúp Leo hiểu bạn hơn.</translation>
<translation id="4358891361699697299">Thêm ký ức mới</translation>
<translation id="6028732745612718012">Chỉnh sửa ký ức này</translation>
<translation id="3970015815965490773">Tạo ký ức mới</translation>
<translation id="1206639071829035972">Bạn muốn Leo nhớ thông tin gì?</translation>
<translation id="2076082422799949288">Xóa ký ức này</translation>
<translation id="1721787502053471881">Bạn có chắc muốn xóa ký ức này? Hành động này không thể hoàn tác.</translation>
<translation id="5239685926753073108">Xóa tất cả ký ức</translation>
<translation id="2600803466586623124">Bạn có chắc muốn xóa tất cả ký ức? Hành động này không thể hoàn tác.</translation>
<translation id="7311244614769792472">Không tìm thấy kết quả nào</translation>
<translation id="1838374766361614909">Xóa tìm kiếm</translation>
<translation id="5126255551970171328">Tìm kiếm bộ nhớ</translation>
<translation id="7402116145895962069">Đồng bộ mô hình cục bộ Ollama của bạn</translation>
<translation id="4835154437390745810">Được quản lý bởi Ollama</translation>
<translation id="5985516785067818307">Người tham gia khảo sát</translation>
<translation id="8347743943525229984">Cho phép Brave thực hiện khảo sát</translation>
<translation id="3204080538332044581">Cho phép Brave hiển thị liên kết đến các khảo sát riêng tư trên trang thẻ mới của bạn. Khảo sát giúp chúng tôi phát triển các tính năng tốt hơn và đo lường hiệu quả của các chiến dịch quảng cáo trên trình duyệt. <ph name="BEGIN_LINK"/>Tìm hiểu thêm<ph name="END_LINK"/></translation>
<translation id="349846214503465941">Bật Danh sách phát</translation>
<translation id="7903608716704052878">Tự động thêm tệp để xem ngoại tuyến</translation>
<translation id="384666453982355633">Tùy chọn này sẽ tự động lưu vào bộ đệm các tệp phương tiện để bạn có thể phát chúng mà không cần kết nối Internet</translation>
