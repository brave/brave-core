<translation id="1643029991199044105">Alterne entre os separadores mais recentes com Ctrl-Tab</translation>
<translation id="2775956301559569472">Mostrar lembrete do Wayback Machine em páginas de erro 404</translation>
<translation id="3095201688102519917">Avisar antes de fechar janela com vários separadores</translation>
