[package]
name = "kuchikiki"
version = "0.8.9-speedreader"
authors = [
  "Brave Authors",
  "Ralph Giles <rgiles@brave.com>",
  "Simon Sapin <simon.sapin@exyr.org>",
]
license = "MIT"
description = "(口利き) HTML tree manipulation library"
repository = "https://github.com/brave/kuchikiki"
edition = "2018"

[lib]
name = "kuchikiki"

[dependencies]
cssparser = "0.35"
html5ever = "0.35"
selectors = "0.32"
indexmap = "2.14"
precomputed-hash = "0.1"

[dev-dependencies]
tempfile = "3"
