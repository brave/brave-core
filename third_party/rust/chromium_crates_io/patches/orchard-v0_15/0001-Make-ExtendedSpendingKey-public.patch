From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Brave <noreply@brave.com>
Date: Mon, 1 Jan 2024 00:00:00 +0000
Subject: [PATCH] Make ExtendedSpendingKey public

brave-core's Orchard wallet code derives keys directly via
`orchard::zip32::ExtendedSpendingKey`. Expose the type and its `master` /
`derive_child` constructors which are `pub(crate)` upstream.
---
 .../vendor/orchard-v0_15/src/zip32.rs              | 6 +++---
 1 file changed, 3 insertions(+), 3 deletions(--)

diff --git a/brave/third_party/rust/chromium_crates_io/vendor/orchard-v0_15/src/zip32.rs b/brave/third_party/rust/chromium_crates_io/vendor/orchard-v0_15/src/zip32.rs
index 0000000..1111111 100644
--- a/brave/third_party/rust/chromium_crates_io/vendor/orchard-v0_15/src/zip32.rs
+++ b/brave/third_party/rust/chromium_crates_io/vendor/orchard-v0_15/src/zip32.rs
@@ -139,4 +139,4 @@
 /// [orchardextendedkeys]: https://zips.z.cash/zip-0032#orchard-extended-keys
 #[derive(Debug, Clone)]
-pub(crate) struct ExtendedSpendingKey {
+pub struct ExtendedSpendingKey {
     depth: u8,
@@ -180,3 +180,3 @@ impl ExtendedSpendingKey {
     /// Panics if the seed is shorter than 32 bytes or longer than 252 bytes.
-    fn master(seed: &[u8]) -> Result<Self, Error> {
+    pub fn master(seed: &[u8]) -> Result<Self, Error> {
         let m_orchard = HardenedOnlyKey::master(&[seed]);
@@ -204,3 +204,3 @@ impl ExtendedSpendingKey {
     /// Discards index if it results in an invalid sk
-    fn derive_child(&self, index: ChildIndex) -> Result<Self, Error> {
+    pub fn derive_child(&self, index: ChildIndex) -> Result<Self, Error> {
