+    def __redirect_cc(ctx, cmd):
+        source_file_idx = None
+        for i, arg in enumerate(cmd.args):
+            if arg in ['-c', '/c']:
+                source_file_idx = i + 1
+                break
+
+        if source_file_idx == None or source_file_idx >= len(cmd.args):
+            return cmd
+
+        source_file = cmd.args[source_file_idx]
+        print('__redirect_cc: source_file:', source_file)
+
+        override_file = None
+        if source_file.startswith('../../'):
+            override_file = source_file.replace('../../', '../../brave/chromium_src/')
+        elif source_file.startswith('gen/'):
+            override_file = source_file.replace('gen/', '../../brave/chromium_src/')
+        else:
+            source_file_parts = source_file.split('/')
+            if len(source_file_parts) > 1 and source_file_parts[1] == 'gen':
+                override_file = '../../brave/chromium_src/' + '/'.join(source_file_parts[2:])
+            else:
+                return cmd
+
+        print('__redirect_cc: override_file:', override_file)
+        print('__redirect_cc: ctx.fs.canonpath(override_file):', ctx.fs.canonpath(override_file))
+        print('__redirect_cc: ctx.fs.exists(ctx.fs.canonpath(override_file)):', ctx.fs.exists(ctx.fs.canonpath(override_file)))
+
+        if override_file and ctx.fs.exists(ctx.fs.canonpath(override_file)):
+            args = list(cmd.args)
+            args[source_file_idx] = override_file
+
+            new_cmd = {}
+            for key in dir(cmd):
+                new_cmd[key] = getattr(cmd, key)
+            new_cmd["args"] = tuple(args)
+            new_cmd_struct = struct(**new_cmd)
+
+            ctx.actions.fix(args = args)
+            return new_cmd_struct
+
+        return cmd
+
+
+    brave_chromium_src_files = (
+        '.css',
+        '.html',
+        '.icon',
+        '.json',
+        '.mojom',
+        '.pdl',
+        '.py',
+        '.ts',
+        '.xml',
+    )
+    def __brave_chromium_utils(ctx, cmd, inputs):
+        new_cmd = {}
+        for key in dir(cmd):
+            new_cmd[key] = getattr(cmd, key)
+
+        new_inputs = cmd.inputs + inputs
+        chromium_output_mapping = {}
+        for input in cmd.inputs:
+            if input.endswith(brave_chromium_src_files):
+                override_file = "brave/chromium_src/" + input
+                if ctx.fs.exists(override_file):
+                    new_inputs.append(override_file)
+                dot_idx = input.rfind('.')
+                if dot_idx != -1:
+                    override_file = input[:dot_idx] + '-chromium.' + input[dot_idx + 1:]
+                    if ctx.fs.exists(override_file):
+                        new_inputs.append(override_file)
+                        chromium_output_mapping[path.base(input).replace('.ts', '.js')] = path.base(override_file).replace('.ts', '.js')
+                        chromium_output_mapping[path.base(input).replace('.ts', '.d.ts')] = path.base(override_file).replace('.ts', '.d.ts')
+                    dot_idx = input.rfind('.', 0, dot_idx)
+                    if dot_idx != -1:
+                        override_file = input[:dot_idx] + '-chromium.' + input[dot_idx + 1:]
+                        if ctx.fs.exists(override_file):
+                            new_inputs.append(override_file)
+                            chromium_output_mapping[path.base(input).replace('.ts', '.js')] = path.base(override_file).replace('.ts', '.js')
+                            chromium_output_mapping[path.base(input).replace('.ts', '.d.ts')] = path.base(override_file).replace('.ts', '.d.ts')
+
+        # Need additional output handling for -chromium files.
+        new_outputs = cmd.outputs + []
+        for output in cmd.outputs:
+            output_filename = path.base(output)
+            chromium_filename = chromium_output_mapping.get(output_filename)
+            if chromium_filename:
+                chromium_output = output[:len(output) - len(output_filename)] + chromium_filename
+                new_outputs.append(chromium_output)
+                print('added to output:', output, 'chromium file:', chromium_output)
+
+        new_cmd["inputs"] = new_inputs
+        new_cmd["outputs"] = new_outputs
+        print('new_inputs:', new_inputs)
+        print('new_outputs:', new_outputs)
+        new_cmd_struct = struct(**new_cmd)
+
+        ctx.actions.fix(inputs = new_inputs, outputs = new_outputs)
+
+        return new_cmd_struct
+
