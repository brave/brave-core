+// static
+std::string RenderProcessHostImpl::BuildJavaScriptFlags(
+    bool jit_disabled, 
+    bool v8_optimizations_disabled, 
+    const std::string& existing_flags) {
+  std::string js_flags;
+  if (jit_disabled) {
+    js_flags = "--jitless";
+  } else if (v8_optimizations_disabled) {
+    js_flags = "--disable-optimizing-compilers";
+  }
+  if (!js_flags.empty()) {
+    if (!existing_flags.empty()) {
+      base::StrAppend(&js_flags, {",", existing_flags});
+    }
+  }
+  return js_flags;
+}
