+// static
+std::string RenderProcessHostImpl::BuildJavaScriptFlags(
+    bool jit_disabled, 
+    bool v8_optimizations_disabled, 
+    const std::string& existing_flags) {
+  // Determine the primary flag based on priority (JIT disabled takes precedence)
+  std::string primary_flag = jit_disabled ? "--jitless" 
+                           : v8_optimizations_disabled ? "--disable-optimizing-compilers" 
+                           : "";
+  
+  // If no special flags are needed, return existing flags unchanged
+  if (primary_flag.empty()) {
+    return existing_flags;
+  }
+  
+  // Combine primary flag with existing flags
+  return existing_flags.empty() ? primary_flag 
+                                : base::StrCat({primary_flag, ",", existing_flags});
+}
