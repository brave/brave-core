+std::optional<std::vector<URLID>> HistoryBackend::QueryUrlIds(
+    const std::vector<GURL>& urls) {
+  if (!db_) {
+    return std::nullopt;
+  }
+  std::vector<URLID> result(urls.size(), 0);
+  for (auto [url, id] : base::zip(urls, result)) {
+    id = db_->GetRowForURL(url, nullptr);
+  }
+  return result;
+}
