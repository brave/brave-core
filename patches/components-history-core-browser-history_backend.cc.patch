+std::vector<URLID> HistoryBackend::QueryURLIDs(const std::vector<GURL>& urls) {
+  std::vector<URLID> result(urls.size(), 0);
+  if (!db_) {
+    return result;
+  }
+  for (size_t i = 0; i < urls.size(); ++i) {
+    result[i] = db_->GetRowForURL(urls[i], nullptr);
+  }
+  return result;
+}
