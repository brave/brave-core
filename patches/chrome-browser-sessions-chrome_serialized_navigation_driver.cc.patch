+std::string ChromeSerializedNavigationDriver::GetSanitizedPageStateForPickle(
+    const sessions::SerializedNavigationEntry* navigation) const {
+  std::string page_state =
+      ContentSerializedNavigationDriver::GetSanitizedPageStateForPickle(
+          navigation);
+  LOG(ERROR) << "GetSanitizedPageStateForPickle: " << navigation->virtual_url();
+  if (navigation->virtual_url().scheme_piece().starts_with(
+          "partitioned-tabs-")) {
+    blink::PageState page_state_obj =
+        blink::PageState::CreateFromEncodedData(page_state);
+    page_state =
+        page_state_obj
+            .PrefixURL(std::string(navigation->virtual_url().scheme_piece()))
+            .ToEncodedData();
+  }
+  return page_state;
