+// Tests for JavaScript flags handling using the extracted BuildJavaScriptFlags helper function
+class RenderProcessHostJavaScriptFlagsTest : public RenderProcessHostUnitTest {
+ public:
+  void SetUp() override {
+    RenderProcessHostUnitTest::SetUp();
+  }
+
+  void TestJavaScriptFlagsHandling(bool jit_disabled,
+                                   bool v8_optimizations_disabled,
+                                   const std::string& existing_flags,
+                                   const std::string& expected_flags) {
+    // Call the extracted static helper function directly
+    std::string result = RenderProcessHostImpl::BuildJavaScriptFlags(
+        jit_disabled, v8_optimizations_disabled, existing_flags);
+    
+    // Verify the result
+    EXPECT_EQ(expected_flags, result);
+  }
+};
+
+TEST_F(RenderProcessHostJavaScriptFlagsTest, JitDisabledWithNoExistingFlags) {
+  TestJavaScriptFlagsHandling(
+      /*jit_disabled=*/true, /*v8_optimizations_disabled=*/false,
+      /*existing_flags=*/"", /*expected_flags=*/"--jitless");
+}
+
+TEST_F(RenderProcessHostJavaScriptFlagsTest, V8OptimizationsDisabledWithNoExistingFlags) {
+  TestJavaScriptFlagsHandling(
+      /*jit_disabled=*/false, /*v8_optimizations_disabled=*/true,
+      /*existing_flags=*/"", /*expected_flags=*/"--disable-optimizing-compilers");
+}
+
+TEST_F(RenderProcessHostJavaScriptFlagsTest, JitDisabledWithExistingFlags) {
+  TestJavaScriptFlagsHandling(
+      /*jit_disabled=*/true, /*v8_optimizations_disabled=*/false,
+      /*existing_flags=*/"--existing-flag", 
+      /*expected_flags=*/"--jitless,--existing-flag");
+}
+
+TEST_F(RenderProcessHostJavaScriptFlagsTest, V8OptimizationsDisabledWithExistingFlags) {
+  TestJavaScriptFlagsHandling(
+      /*jit_disabled=*/false, /*v8_optimizations_disabled=*/true,
+      /*existing_flags=*/"--existing-flag", 
+      /*expected_flags=*/"--disable-optimizing-compilers,--existing-flag");
+}
+
+TEST_F(RenderProcessHostJavaScriptFlagsTest, BothFlagsDisabledPrefersJitless) {
+  // When both JIT and V8 optimizations are disabled, JIT disabled takes precedence
+  TestJavaScriptFlagsHandling(
+      /*jit_disabled=*/true, /*v8_optimizations_disabled=*/true,
+      /*existing_flags=*/"", /*expected_flags=*/"--jitless");
+}
+
+TEST_F(RenderProcessHostJavaScriptFlagsTest, BothFlagsDisabledWithExistingFlags) {
+  // When both JIT and V8 optimizations are disabled, JIT disabled takes precedence
+  TestJavaScriptFlagsHandling(
+      /*jit_disabled=*/true, /*v8_optimizations_disabled=*/true,
+      /*existing_flags=*/"--existing-flag", 
+      /*expected_flags=*/"--jitless,--existing-flag");
+}
+
+TEST_F(RenderProcessHostJavaScriptFlagsTest, NoFlagsDisabledWithNoExistingFlags) {
+  TestJavaScriptFlagsHandling(
+      /*jit_disabled=*/false, /*v8_optimizations_disabled=*/false,
+      /*existing_flags=*/"", /*expected_flags=*/"");
+}
+
+TEST_F(RenderProcessHostJavaScriptFlagsTest, NoFlagsDisabledWithExistingFlags) {
+  // When no special flags are disabled, existing flags should remain unchanged
+  TestJavaScriptFlagsHandling(
+      /*jit_disabled=*/false, /*v8_optimizations_disabled=*/false,
+      /*existing_flags=*/"--existing-flag", /*expected_flags=*/"--existing-flag");
+}
+
+TEST_F(RenderProcessHostJavaScriptFlagsTest, MultipleExistingFlags) {
+  TestJavaScriptFlagsHandling(
+      /*jit_disabled=*/true, /*v8_optimizations_disabled=*/false,
+      /*existing_flags=*/"--flag1 --flag2", 
+      /*expected_flags=*/"--jitless,--flag1 --flag2");
+}
+
+TEST_F(RenderProcessHostJavaScriptFlagsTest, EmptyExistingFlagsString) {
+  // Test with empty string as existing flags (edge case)
+  TestJavaScriptFlagsHandling(
+      /*jit_disabled=*/true, /*v8_optimizations_disabled=*/false,
+      /*existing_flags=*/"", /*expected_flags=*/"--jitless");
+}
