
{%- set objc_class_name = "%s%s"|format(class_prefix, struct.name) -%}
{%- set mapped_type = struct|cpp_mapped_typename %}
@implementation {{objc_class_name}} {
  {{mapped_type}} _cppObj;
}
{%- for field in struct.fields %}
{%-   set name = field.name|objc_property_formatter %}
@dynamic {{name}};
{%- endfor %}
- (instancetype)init
{
  return [super init];
}
- (id)copyWithZone:(nullable NSZone *)zone
{
  return [[{{objc_class_name}} alloc] initWith{{struct.name}}:_cppObj];
}
@end

@implementation {{objc_class_name}} (Private)
- (instancetype)initWith{{struct.name}}:(const {{mapped_type}}&)obj
{
  if ((self = [super init])) {
    _cppObj = obj;
  }
  return self;
}
- (const {{mapped_type}}&)cppObjPtr
{
  return _cppObj;
}
- ({{mapped_type}}&)mutableCppObjRef
{
  return _cppObj;
}
@end
