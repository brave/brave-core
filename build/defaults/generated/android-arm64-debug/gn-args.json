{
  "gn_args": {
    "android_aab_to_apk": false,
    "branding_path_component": "brave",
    "branding_path_product": "brave",
    "chrome_pgo_phase": 0,
    "disable_android_lint": false,
    "disable_fieldtrial_testing_config": true,
    "enable_cdm_host_verification": false,
    "enable_full_stack_frames_for_profiling": false,
    "enable_hevc_parser_and_hw_decoder": true,
    "enable_mdns": true,
    "enable_mojom_message_id_scrambling": false,
    "enable_platform_hevc": true,
    "enable_precompiled_headers": false,
    "enable_pseudolocales": false,
    "enable_update_notifications": false,
    "enable_widevine": true,
    "ffmpeg_branding": "Chrome",
    "ignore_missing_widevine_signing_cert": false,
    "is_asan": false,
    "is_component_build": true,
    "is_debug": true,
    "is_lsan": false,
    "is_msan": false,
    "is_official_build": false,
    "is_ubsan": false,
    "is_ubsan_no_recover": false,
    "is_ubsan_vptr": false,
    "is_universal_binary": false,
    "proprietary_codecs": true,
    "root_extra_deps": ["//brave"],
    "safe_browsing_mode": 2,
    "skip_signing": true,
    "target_android_output_format": "apk",
    "target_cpu": "arm64",
    "target_os": "android",
    "translate_genders": false,
    "use_libfuzzer": false,
    "use_reclient": false,
    "use_remoteexec": false,
    "use_siso": true,
    "v8_enable_verify_heap": false
  }
}
