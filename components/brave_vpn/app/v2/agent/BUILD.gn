import("//brave/components/brave_vpn/common/buildflags/buildflags.gni")
if (is_mac) {
  import("//build/config/mac/rules.gni")
  import("//build/util/branding.gni")
}
if (is_win) {
  import("//chrome/process_version_rc_template.gni")
}

assert(enable_brave_vpn_v2)

source_set("core") {
  sources = [
    "agent_app.cc",
    "agent_app.h",
  ]

  public_deps = [ "//base" ]
}

if (is_win) {
  process_version_rc_template("version_resources") {
    sources = [ "win/agent.ver" ]
    output = "$target_gen_dir/brave_vpn_agent_app.rc"
  }
}

executable("agent") {
  output_name = "brave_vpn_agent_app"

  sources = [ "main.cc" ]
  deps = [
    ":core",
    "//base",
    "//base:base_static",
  ]

  if (is_mac) {
    frameworks = [ "AppKit.framework" ]
  }

  if (is_win) {
    deps += [
      ":version_resources",
      "//build/win:default_exe_manifest",
    ]

    public_configs = [ "//build/config/win:windowed" ]
  }
}

if (is_mac) {
  vpn_agent_product_full_name = "$chrome_product_full_name VPN Agent"
  vpn_agent_bundle_id = "$chrome_mac_bundle_id.vpn.agent"

  # Assembles the agent executable and Info.plist into an app bundle.
  mac_app_bundle("brave_vpn_agent_bundle") {
    info_plist = "mac/Info.plist"
    output_name = vpn_agent_product_full_name
    extra_substitutions = [ "MAC_BUNDLE_IDENTIFIER=$vpn_agent_bundle_id" ]

    sources = [ "main.cc" ]
    frameworks = [ "AppKit.framework" ]

    deps = [
      ":core",
      "//base",
      "//base:base_static",
    ]
  }

  # Drops the assembled app into the browser framework's Helpers directory.
  bundle_data("brave_vpn_agent_bundle_data") {
    sources = [ "$root_out_dir/$vpn_agent_product_full_name.app" ]
    outputs = [ "{{bundle_contents_dir}}/Helpers/{{source_file_part}}" ]
    public_deps = [ ":brave_vpn_agent_bundle" ]
  }
}
