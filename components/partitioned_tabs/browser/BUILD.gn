import("//brave/components/partitioned_tabs/buildflags/buildflags.gni")

assert(enable_partitioned_tabs)

component("browser") {
  defines = [ "IS_PARTITIONED_TABS_BROWSER_IMPL" ]

  sources = [
    # "partitioned_tabs_handler.cc",
    "partitioned_tabs_handler.h",
    "partitioned_tabs_handler_registry.cc",
    "partitioned_tabs_handler_registry.h",
    "session_info_handler.cc",
    "session_info_handler.h",
  ]

  public_deps = [ "//brave/components/partitioned_tabs/buildflags" ]

  deps = [
    "//base",
    "//components/pref_registry",
    "//components/prefs",
    "//components/sessions",
    "//components/user_prefs",
    "//content/public/browser",
    "//net/base/registry_controlled_domains",
    "//services/network/public/cpp",
    "//third_party/re2",
    "//url",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [
    # "partitioned_tabs_handler_unittest.cc",
    # "partitioned_tabs_handler_registry_unittest.cc",
  ]

  deps = [
    ":browser",
    "//base",
    "//base/test:test_support",
    "//components/sync_preferences:test_support",
    "//mojo/public/cpp/bindings",
    "//testing/gmock",
    "//testing/gtest",
  ]
}
