static_library("content") {
  sources = [
    "background_web_contents.cc",
    "background_web_contents.h",
  ]

  public_deps = [ "//base" ]

  deps = [
    "//content/public/browser",
    "//services/network/public/cpp",
    "//ui/base",
    "//url",
  ]
}

source_set("unit_tests") {
  testonly = true
  sources = [ "background_web_contents_unittest.cc" ]

  deps = [
    ":content",
    "//content/test:test_support",
    "//testing/gmock",
    "//testing/gtest",
    "//url",
  ]
}
