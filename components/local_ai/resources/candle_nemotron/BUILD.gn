import("//brave/components/common/typescript.gni")
import("//tools/grit/repack.gni")

# Bundle the candle_nemotron WASM crate + wasm-bindgen JS glue into
# a single `candle_nemotron.bundle.js` served by the worker WebUI
# (chrome-untrusted://on-device-speech-recognition-worker/).
transpile_web_ui("candle_nemotron_module") {
  resource_name = "candle_nemotron_module"

  entry_points = [ [
        "candle_nemotron",
        rebase_path("index.js"),
      ] ]

  inputs = [
    rebase_path("//brave/third_party/wasm/Cargo.lock"),
    rebase_path("src/lib.rs"),
    rebase_path("src/audio.rs"),
    rebase_path("src/decode.rs"),
    rebase_path("src/model.rs"),
    rebase_path("src/model/attention.rs"),
    rebase_path("src/model/builder.rs"),
    rebase_path("src/model/cache.rs"),
    rebase_path("src/model/conformer.rs"),
    rebase_path("src/model/encoder.rs"),
    rebase_path("src/model/joint.rs"),
    rebase_path("src/model/predictor.rs"),
  ]

  imports_from = [ "//brave/components/local_ai/resources/candle_nemotron/" ]

  rust_packages = [ rebase_path("Cargo.toml") ]

  no_iife = true
  output_module = true
  public_asset_path = "chrome-untrusted://on-device-speech-recognition-worker/"
}

pack_web_resources("candle_nemotron_module_generated") {
  resource_name = "candle_nemotron_module"
  output_dir = "$root_gen_dir/brave/components/local_ai/resources"
  deps = [ ":candle_nemotron_module" ]
}
