import("//brave/components/brave_wallet/common/buildflags/buildflags.gni")

source_set("unit_tests") {
  testonly = true

  sources = [
    "bundle_parser_unittest.cc",
    "csp_validator_unittest.cc",
    "manifest_verifier_unittest.cc",
    "origin_state_unittest.cc",
    "webcat_cache_unittest.cc",
  ]

  deps = [
    "//base",
    "//base/test:test_support",
    "//brave/components/webcat/core",
    "//crypto",
    "//testing/gtest",
    "//url",
  ]

  if (enable_brave_wallet) {
    sources += [ "ens_text_record_unittest.cc" ]
    deps += [
      "//brave/components/brave_wallet/browser",
      "//brave/components/brave_wallet/common",
    ]
  }
}
