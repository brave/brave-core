import("//brave/components/brave_wallet/common/buildflags/buildflags.gni")

assert(enable_snaps)

source_set("execution_environment") {
  sources = [
    "hidden_web_contents_snap_bridge_controller.cc",
    "hidden_web_contents_snap_bridge_controller.h",
    "snap_bridge_controller.cc",
    "snap_bridge_controller.h",
    "wallet_page_snap_bridge_controller.cc",
    "wallet_page_snap_bridge_controller.h",
  ]

  deps = [
    "//base",
    "//brave/components/brave_wallet/common",
    "//brave/components/brave_wallet/common:mojom",
    "//brave/components/constants",
    "//content/public/browser",
    "//mojo/public/cpp/bindings",
    "//url",
  ]

  # KeyringService is forward-declared in
  # hidden_web_contents_snap_bridge_controller.h. The parent browser
  # static_library that depends on this source_set provides the full
  # definition.
}

source_set("unit_tests") {
  testonly = true
  sources = [
    "hidden_web_contents_snap_bridge_controller_unittest.cc",
    "wallet_page_snap_bridge_controller_unittest.cc",
  ]

  deps = [
    ":execution_environment",
    "//base",
    "//base/test:test_support",
    "//brave/components/brave_wallet/browser",
    "//brave/components/brave_wallet/browser:test_support",
    "//brave/components/brave_wallet/browser/snap:test_support",
    "//brave/components/brave_wallet/common",
    "//brave/components/brave_wallet/common:mojom",
    "//components/prefs:test_support",
    "//components/sync_preferences:test_support",
    "//content/test:test_support",
    "//services/network:test_support",
    "//services/network/public/cpp",
    "//testing/gmock",
    "//testing/gtest",
  ]
}
