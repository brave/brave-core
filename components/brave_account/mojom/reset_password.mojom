module brave_account.mojom;

struct ResetPasswordVerifyInitResult {
  // Currently empty, serves as a placeholder for success.
};

struct ResetPasswordVerifyCompleteResult {
  // Currently empty, serves as a placeholder for success.
};

struct ResetPasswordPasswordInitResult {
  // Response generated by the backend from the client's blindedMessage.
  string serializedResponse;
};

struct ResetPasswordPasswordFinalizeResult {
  // Currently empty, serves as a placeholder for success.
};

enum ResetPasswordClientErrorCode {
  kCalledInWrongState,
  kUnexpected,
  kOpaqueError,
  kVerificationTokenEncryptionFailed,
  kVerificationTokenDecryptionFailed,
  kAuthenticationTokenEncryptionFailed,
};

struct ResetPasswordClientError {
  ResetPasswordClientErrorCode error_code;
};

enum ResetPasswordServerErrorCode {
  // Sentinel: server returned a malformed response
  // (e.g. success body missing required fields).
  kInvalidResponse                                    = -1,
  // Sentinel: server returned "code": null in the JSON body.
  kNull                                               = 0,
  // Sentinel: server returned an unrecognized "code" in the JSON body.
  kUnknown                                            = 1,

  // /v2/verify/init:
  // - internal:
  kIntentNotAllowed                                   = 13003,
  kInvalidTokenAudience                               = 14007,
  // - user-facing:
  kTooManyVerifications                               = 13001,
  kAccountDoesNotExist                                = 13005,
  kEmailDomainNotSupported                            = 13006,
  kFailedToSendEmailDueToInvalidFormat                = 13007,
  kDailyVerificationLimitReachedForEmail              = 13013,

  // /v2/verify/complete:
  // - internal: -
  // - user-facing:
  kVerificationNotFoundOrInvalidIdOrCode              = 13002,
  kEmailAlreadyVerified                               = 13009,
  kMaximumCodeVerificationAttemptsExceeded            = 13010,
  kInvalidVerificationCode                            = 13011,
  kTokenHasExpired                                    = 14014,

  // /v2/accounts/password/init:
  // - internal:
  // kIntentNotAllowed                                = 13003,
  // - user-facing:
  // kTooManyVerifications                            = 13001,
  // kEmailDomainNotSupported                         = 13006,
  // kDailyVerificationLimitReachedForEmail           = 13013,

  // /v2/accounts/password/finalize:
  // - internal:
  kInterimPasswordStateNotFound                       = 14001,
  kInterimPasswordStateExpired                        = 14002,
  // - user-facing: -
};

struct ResetPasswordServerError {
  // < 0: network error code (net_error_list.h)
  // >= 0: HTTP status code (http_status_code_list.h) if available,
  //       otherwise net::OK
  int32 net_error_or_http_status;
  ResetPasswordServerErrorCode error_code;
};

union ResetPasswordError {
  ResetPasswordClientError client_error;
  ResetPasswordServerError server_error;
};
