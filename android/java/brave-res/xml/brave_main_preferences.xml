<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orderingFromXml="false">
    <PreferenceCategory
        android:key="brave_account_section"
        android:order="1"
        android:title="@string/brave_account_title"/>
    <org.chromium.chrome.browser.settings.BraveAccountPreference
        android:key="user_info"
        android:order="1"
        app:title_truncate_middle="true"
        android:selectable="false"/>
    <org.chromium.chrome.browser.settings.BraveAccountPreference
        android:key="change_password"
        android:order="2"
        android:title="@string/settings_brave_account_change_password_button_label"
        app:title_text_color="@color/schemes_primary"/>
    <org.chromium.chrome.browser.settings.BraveAccountPreference
        android:key="sign_out"
        android:order="3"
        android:icon="@drawable/ic_outside"
        android:title="@string/settings_brave_account_log_out_button_label"
        app:title_text_color="@color/schemes_primary"/>
    <org.chromium.chrome.browser.settings.BraveAccountPreference
        android:key="almost_there"
        android:order="4"
        android:selectable="false"/>
    <org.chromium.chrome.browser.settings.BraveAccountPreference
        android:key="enter_verification_code"
        android:order="5"
        app:title_text_color="@color/schemes_primary"/>
    <org.chromium.chrome.browser.settings.BraveAccountPreference
        android:key="resend_confirmation_email"
        android:order="6"
        android:title="@string/settings_brave_account_resend_confirmation_email_button_label"
        app:title_text_color="@color/schemes_primary"
        android:summary="@string/settings_brave_account_verification_row_description_3"/>
    <org.chromium.chrome.browser.settings.BraveAccountPreference
        android:key="cancel_verification"
        android:order="7"
        app:title_text_color="@color/systemfeedback_error_text"/>
    <org.chromium.chrome.browser.settings.BraveAccountPreference
        android:key="get_started"
        android:order="8"
        android:icon="@drawable/ic_social_brave_release_favicon_fullheight_color"
        android:title="@string/settings_brave_account_get_started_button_label"/>
    <PreferenceCategory
        android:key="features_section"
        android:order="2"
        android:title="@string/prefs_section_features"/>
    <org.chromium.components.browser_ui.settings.ChromeBasePreference
        android:fragment="org.chromium.chrome.browser.privacy.settings.BravePrivacySettings"
        android:key="brave_shields_and_privacy"
        android:icon="@drawable/ic_shield_done"
        android:order="1"
        android:title="@string/brave_shields_and_privacy"/>
    <org.chromium.components.browser_ui.settings.ChromeBasePreference
        android:fragment="org.chromium.chrome.browser.settings.BraveNewsPreferencesV2"
        android:key="brave_news_v2"
        android:icon="@drawable/ic_product_brave_news"
        android:order="2"
        android:title="@string/brave_news_title"/>
    <org.chromium.components.browser_ui.settings.ChromeBasePreference
        android:fragment="org.chromium.chrome.browser.settings.BraveWalletPreferences"
        android:key="brave_wallet"
        android:icon="@drawable/ic_product_brave_wallet"
        android:order="3"
        android:title="@string/brave_ui_brave_wallet"/>
    <org.chromium.components.browser_ui.settings.ChromeBasePreference
        android:fragment="org.chromium.chrome.browser.vpn.settings.BraveVpnPreferences"
        android:key="brave_vpn"
        android:icon="@drawable/ic_product_vpn"
        android:order="4"
        android:title="@string/brave_firewall_vpn"/>
    <org.chromium.components.browser_ui.settings.ChromeBasePreference
        android:fragment="org.chromium.chrome.browser.settings.BraveLeoPreferences"
        android:key="brave_leo"
        android:icon="@drawable/ic_product_brave_leo"
        android:order="4"
        android:title="@string/menu_brave_leo"/>
    <org.chromium.components.browser_ui.settings.ChromeBasePreference
        android:fragment="org.chromium.chrome.browser.playlist.settings.BravePlaylistPreferences"
        android:key="brave_playlist"
        android:icon="@drawable/ic_open_playlist"
        android:order="4"
        android:title="@string/brave_playlist"/>
    <PreferenceCategory
        android:key="general_section"
        android:order="5"
        android:title="@string/prefs_section_general"/>
    <org.chromium.components.browser_ui.settings.ChromeBasePreference
        android:fragment="org.chromium.chrome.browser.settings.BraveSearchEnginesPreferences"
        android:key="brave_search_engines"
        android:order="6"
        android:icon="@drawable/ic_search"
        android:title="@string/brave_search_engines"/>

    <org.chromium.components.browser_ui.settings.ChromeBasePreference
        android:fragment="org.chromium.chrome.browser.settings.BraveSearchEnginesPreferences"
        android:key="home_screen_widget"
        android:order="7"
        android:icon="@drawable/ic_widget_search2"
        android:title="@string/home_screen_widget"/>

    <org.chromium.components.browser_ui.settings.ChromeBasePreference
        android:fragment="org.chromium.chrome.browser.settings.BraveStatsPreferences"
        android:key="brave_stats"
        android:order="9"
        android:icon="@drawable/ic_bar_chart_search"
        android:title="@string/brave_stats"/>
    <org.chromium.components.browser_ui.settings.ChromeSwitchPreference
        android:key="closing_all_tabs_closes_brave"
        android:order="13"
        android:defaultValue="false"
        android:icon="@drawable/ic_window_tab_close"
        android:title="@string/prefs_closing_all_tabs_closes_brave"
        app:isPreferenceVisible="false"/>
    <org.chromium.components.browser_ui.settings.ChromeBasePreference
        android:fragment="org.chromium.chrome.browser.privacy.settings.BraveBrowserLockSettingsFragment"
        android:key="brave_browser_lock"
        android:order="13"
        android:icon="@drawable/ic_biometric_login"
        android:title="@string/brave_browser_lock_title"
        android:summary="@string/brave_browser_lock_screen_description"
        android:persistent="false"/>
    <org.chromium.components.browser_ui.settings.ChromeBasePreference
        android:key="brave_origin"
        android:order="14"
        android:icon="@drawable/ic_product_origin"
        android:title="@string/menu_origin"/>
    <PreferenceCategory
        android:key="display_section"
        android:order="15"
        android:title="@string/prefs_section_display"/>
    <org.chromium.components.browser_ui.settings.ChromeBasePreference
        android:fragment="org.chromium.chrome.browser.settings.MediaPreferences"
        android:key="media"
        android:order="16"
        android:icon="@drawable/ic_media_player"
        android:title="@string/prefs_media"/>
    <org.chromium.components.browser_ui.settings.ChromeBasePreference
        android:fragment="org.chromium.chrome.browser.settings.AppearancePreferences"
        android:key="brave_appearance"
        android:order="17"
        android:icon="@drawable/ic_appearance"
        android:title="@string/prefs_appearance"/>
    <org.chromium.components.browser_ui.settings.ChromeBasePreference
        android:fragment="org.chromium.chrome.browser.settings.BackgroundImagesPreferences"
        android:key="background_images"
        android:order="18"
        android:icon="@drawable/ic_window_tab_new"
        android:title="@string/prefs_new_tab_page"/>
    <org.chromium.components.browser_ui.settings.ChromeBasePreference
        android:fragment="org.chromium.chrome.browser.settings.BraveSyncScreensPreference"
        android:key="brave_sync_layout"
        android:order="22"
        android:icon="@drawable/ic_product_sync"
        android:title="@string/sync_category_title"/>
    <Preference
        android:fragment="org.chromium.chrome.browser.language.settings.BraveLanguageSettings"
        android:key="brave_languages"
        android:order="23"
        icon="@drawable/ic_product_translate"
        android:title="@string/language_settings"/>
    <PreferenceCategory
        android:key="support_section"
        android:order="24"
        android:title="@string/prefs_support_section"/>
    <Preference
        android:key="rate_brave"
        android:order="28"
        android:icon="@drawable/ic_star_circle"
        android:title="@string/prefs_rate_brave"/>
    <org.chromium.components.browser_ui.settings.ChromeBasePreference
        android:fragment="org.chromium.chrome.browser.download.settings.BraveDownloadSettings"
        android:key="brave_downloads"
        android:order="24"
        android:icon="@drawable/ic_download"
        android:title="@string/menu_downloads"/>
    <PreferenceCategory
        android:key="about_section"
        android:order="24"
        android:title="@string/prefs_about_section"/>
</PreferenceScreen>
