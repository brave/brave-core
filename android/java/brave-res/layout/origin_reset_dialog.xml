<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_bg_no_shadow"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/reset_dialog_title"
        style="@style/HeadingH3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/origin_reset_to_defaults"
        android:textColor="@color/schemes_on_surface" />

    <TextView
        android:id="@+id/reset_dialog_message"
        style="@style/DefaultRegular"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/origin_reset_dialog_message"
        android:textColor="@color/schemes_on_surface" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="end"
        android:orientation="horizontal">

        <Button
            android:id="@+id/reset_dialog_cancel"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:text="@string/cancel"
            android:textAllCaps="false"
            android:textAppearance="@style/ComponentsButtonDefault"
            android:textColor="@color/schemes_on_surface_variant" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/reset_dialog_confirm"
            style="@style/LargeFilledButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:backgroundTint="@color/button_background"
            android:text="@string/origin_reset_dialog_button"
            android:textAllCaps="false"
            android:textAppearance="@style/ComponentsButtonDefault"
            android:textColor="@color/schemes_on_primary" />

    </LinearLayout>

</LinearLayout>
