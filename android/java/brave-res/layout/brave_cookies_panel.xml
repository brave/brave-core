<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/colorSurfaceContainer">

    <!-- Top App Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="18dp">

        <!-- Back button -->
        <include
            android:id="@+id/cookies_back_button"
            layout="@layout/brave_panel_back_button"/>

        <!-- Title -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="@string/block_cookies"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:textColor="?attr/colorOnSurface"
            android:maxLines="1"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="14sp"
            android:autoSizeMaxTextSize="22sp"
            android:ellipsize="end"
            android:includeFontPadding="false"/>

    </LinearLayout>

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Options Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/advanced_options_bg"
            tools:ignore="UselessParent">

            <!-- Description -->
            <TextView
                style="@style/DefaultRegular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/cookies_description"
                android:textColor="?attr/colorOnSurface"
                android:paddingHorizontal="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="24dp"/>

            <!-- Radio options -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Option 1: Block all -->
                <LinearLayout
                    android:id="@+id/cookies_block_all_option"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground">

                    <TextView
                        style="@style/LargeRegular"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/block_cookies_option_1"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginEnd="8dp"/>

                    <androidx.appcompat.widget.AppCompatRadioButton
                        android:id="@+id/cookies_block_all_radio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:buttonTint="?attr/colorPrimary"
                        android:clickable="false"
                        android:focusable="false"/>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorSurfaceContainer"/>

                <!-- Option 2: Block 3rd-party -->
                <LinearLayout
                    android:id="@+id/cookies_block_third_party_option"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground">

                    <TextView
                        style="@style/LargeRegular"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/block_cookies_option_2"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginEnd="8dp"/>

                    <androidx.appcompat.widget.AppCompatRadioButton
                        android:id="@+id/cookies_block_third_party_radio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:buttonTint="?attr/colorPrimary"
                        android:clickable="false"
                        android:focusable="false"/>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorSurfaceContainer"/>

                <!-- Option 3: Allow all -->
                <LinearLayout
                    android:id="@+id/cookies_allow_option"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground">

                    <TextView
                        style="@style/LargeRegular"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/block_cookies_option_3"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginEnd="8dp"/>

                    <androidx.appcompat.widget.AppCompatRadioButton
                        android:id="@+id/cookies_allow_radio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:buttonTint="?attr/colorPrimary"
                        android:clickable="false"
                        android:focusable="false"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
