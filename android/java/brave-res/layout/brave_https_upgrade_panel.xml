<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/container_background">

    <!-- Top App Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="18dp">

        <!-- Back button -->
        <include
            android:id="@+id/https_back_button"
            layout="@layout/brave_panel_back_button"/>

        <!-- Title -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:gravity="center_vertical"
            android:text="@string/https_upgrade_title"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:textColor="@color/text_primary"
            android:maxLines="1"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="14sp"
            android:autoSizeMaxTextSize="22sp"/>

    </LinearLayout>

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Options Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/advanced_options_bg"
            tools:ignore="UselessParent">

            <!-- Description -->
            <TextView
                style="@style/DefaultRegular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/https_upgrade_text"
                android:textColor="@color/text_primary"
                android:paddingHorizontal="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="24dp"/>

            <!-- Radio option 1: Strict -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/https_strict_option"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground">

                    <TextView
                        style="@style/LargeRegular"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/https_upgrade_option_1"
                        android:textColor="@color/text_primary"
                        android:layout_marginEnd="8dp"/>

                    <androidx.appcompat.widget.AppCompatRadioButton
                        android:id="@+id/https_strict_radio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="false"
                        android:focusable="false"
                        app:buttonTint="@color/schemes_primary"/>

                </LinearLayout>

                <!-- Radio option 2: Default -->
                <LinearLayout
                    android:id="@+id/https_default_option"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground">

                    <TextView
                        style="@style/LargeRegular"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/https_upgrade_option_2"
                        android:textColor="@color/text_primary"
                        android:layout_marginEnd="8dp"/>

                    <androidx.appcompat.widget.AppCompatRadioButton
                        android:id="@+id/https_default_radio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="false"
                        android:focusable="false"
                        app:buttonTint="@color/schemes_primary"/>

                </LinearLayout>

                <!-- Radio option 3: Disabled -->
                <LinearLayout
                    android:id="@+id/https_disabled_option"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground">

                    <TextView
                        style="@style/LargeRegular"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/https_upgrade_option_3"
                        android:textColor="@color/text_primary"
                        android:layout_marginEnd="8dp"/>

                    <androidx.appcompat.widget.AppCompatRadioButton
                        android:id="@+id/https_disabled_radio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="false"
                        android:focusable="false"
                        app:buttonTint="@color/schemes_primary"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
