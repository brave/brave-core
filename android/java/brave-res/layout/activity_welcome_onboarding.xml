<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/onboarding_variant_b"
        android:visibility="gone"
        android:paddingTop="@dimen/onboarding_padding_top"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/brave_splash"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:src="@drawable/ic_brave_splash_animated"
            android:contentDescription="@string/brave_onboarding_splash_logo_description"
            android:alpha="0"

            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/splash_anchor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_begin="0dp"/>

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/onboarding_steps_pager"
            android:layout_width="0dp"
            android:visibility="invisible"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/splash_anchor"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <include layout="@layout/activity_welcome_onboarding_default" />
</merge>
