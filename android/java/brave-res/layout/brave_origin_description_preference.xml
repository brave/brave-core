<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <TextView
        android:id="@+id/origin_description_title"
        style="@style/SmallSemibold"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/origin_description_title"
        android:textColor="@color/text_secondary" />

    <TextView
        android:id="@+id/origin_description_body"
        style="@style/SmallRegular"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/origin_description_body"
        android:textColor="@color/text_secondary" />

    <TextView
        android:id="@+id/origin_description_note"
        style="@style/SmallRegular"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/origin_description_note"
        android:textColor="@color/text_tertiary" />

</LinearLayout>
