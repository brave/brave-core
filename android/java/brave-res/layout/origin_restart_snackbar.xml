<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/origin_restart_snackbar_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/snackbar_title"
        style="@style/LargeRegular"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/origin_changing_brave_features_title"
        android:textColor="@android:color/white" />

    <TextView
        android:id="@+id/snackbar_message"
        style="@style/DefaultRegular"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/origin_changing_brave_features_message"
        android:textColor="@android:color/white" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical|end"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/snackbar_action"
            style="@style/ComponentsButtonDefault"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp"
            android:clickable="true"
            android:focusable="true"
            android:text="@string/origin_restart_now"
            android:textColor="@color/schemes_primary_fixed_dim" />

        <ImageButton
            android:id="@+id/snackbar_close"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@android:string/cancel"
            android:src="@drawable/ic_close"
            android:tint="@color/schemes_primary_fixed_dim" />

    </LinearLayout>

</LinearLayout>
