<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="65dp"
    android:height="40dp"
    android:viewportWidth="65"
    android:viewportHeight="40">

    <!-- Outer path filled with outline colour — provides the 2dp border without a stroke -->
    <path
        android:name="outline"
        android:fillColor="@color/schemes_outline"
        android:pathData="M20,0 L45,0 A20,20 0 0,1 45,40 L20,40 A20,20 0 0,1 20,0 Z" />

    <!-- Inner fill 2dp inset on every side (concentric, same arc centres) -->
    <path
        android:name="track"
        android:fillColor="@color/schemes_surface_container_highest"
        android:pathData="M20,2 L45,2 A18,18 0 0,1 45,38 L20,38 A18,18 0 0,1 20,2 Z" />

    <path
        android:name="thumb"
        android:fillColor="@color/schemes_outline"
        android:pathData="M10,20 A10,10 0 1,0 30,20 A10,10 0 1,0 10,20 Z" />
</vector>
