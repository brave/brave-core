<animated-selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:id="@+id/shields_switch_small_state_on"
        android:state_selected="true"
        android:drawable="@drawable/shields_switch_small_on" />
    <item
        android:id="@+id/shields_switch_small_state_off"
        android:drawable="@drawable/shields_switch_small_off" />

    <transition
        android:fromId="@+id/shields_switch_small_state_off"
        android:toId="@+id/shields_switch_small_state_on"
        android:drawable="@drawable/shields_switch_small_off_to_on"
        android:reversible="true" />
</animated-selector>
