<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Track fill with border -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="35dp" />
            <solid android:color="@color/schemes_surface_container_highest" />
            <stroke
                android:width="2dp"
                android:color="@color/schemes_outline" />
            <size
                android:width="42dp"
                android:height="26dp" />
        </shape>
    </item>

    <!-- Thumb on left side (12dp, centered vertically) -->
    <item
        android:left="7dp"
        android:top="7dp"
        android:right="23dp"
        android:bottom="7dp">
        <shape android:shape="oval">
            <solid android:color="@color/schemes_outline" />
            <size
                android:width="12dp"
                android:height="12dp" />
        </shape>
    </item>
</layer-list>
