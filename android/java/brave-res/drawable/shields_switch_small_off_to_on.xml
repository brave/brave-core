<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:drawable="@drawable/shields_switch_small_off">

    <target android:name="outline">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="fillColor"
                android:valueFrom="@color/schemes_outline"
                android:valueTo="@color/schemes_primary"
                android:duration="200"
                android:interpolator="@android:interpolator/fast_out_slow_in" />
        </aapt:attr>
    </target>

    <target android:name="track">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="fillColor"
                android:valueFrom="@color/schemes_surface_container_highest"
                android:valueTo="@color/schemes_primary"
                android:duration="200"
                android:interpolator="@android:interpolator/fast_out_slow_in" />
        </aapt:attr>
    </target>

    <target android:name="thumb">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="pathData"
                    android:valueType="pathType"
                    android:valueFrom="M7,13 A6,6 0 1,0 19,13 A6,6 0 1,0 7,13 Z"
                    android:valueTo="M19,13 A10,10 0 1,0 39,13 A10,10 0 1,0 19,13 Z"
                    android:duration="200"
                    android:interpolator="@android:interpolator/fast_out_slow_in" />
                <objectAnimator
                    android:propertyName="fillColor"
                    android:valueFrom="@color/schemes_outline"
                    android:valueTo="@color/schemes_on_primary"
                    android:duration="200"
                    android:interpolator="@android:interpolator/fast_out_slow_in" />
            </set>
        </aapt:attr>
    </target>
</animated-vector>
