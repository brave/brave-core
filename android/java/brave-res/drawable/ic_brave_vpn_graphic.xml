     Install VPN profile illustration: the dotted texture background (raster,
     because its single halftone path is too large for a VectorDrawable) with
     the crisp phone mock-up (vector) overlaid. Both layers share the 548x300
     canvas so they align without insets. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:drawable="@drawable/vpn_install_bg"
        android:gravity="fill"/>
    <item
        android:drawable="@drawable/vpn_install_phone"
        android:gravity="fill"/>
</layer-list>
