<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Track background - solid blue -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="35dp" />
            <solid android:color="@color/schemes_primary" />
            <size
                android:width="42dp"
                android:height="26dp" />
        </shape>
    </item>

    <!-- Thumb on right side (white, 20dp) -->
    <item
        android:left="19dp"
        android:top="3dp"
        android:right="3dp"
        android:bottom="3dp">
        <shape android:shape="oval">
            <solid android:color="@color/schemes_on_primary" />
            <size
                android:width="20dp"
                android:height="20dp" />
        </shape>
    </item>
</layer-list>
