<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <org.chromium.components.browser_ui.settings.ChromeBasePreference
        android:fragment="org.chromium.chrome.browser.search_engines.settings.BraveStandardSearchEnginePreference"
        android:key="standard_search_engine"
        android:order="1"
        android:title="@string/prefs_standard_search_engine"/>
    <org.chromium.components.browser_ui.settings.ChromeBasePreference
        android:fragment="org.chromium.chrome.browser.search_engines.settings.BravePrivateSearchEnginePreference"
        android:key="private_search_engine"
        android:order="2"
        android:title="@string/prefs_private_search_engine"/>
    <org.chromium.components.browser_ui.settings.ChromeBasePreference
        android:fragment="org.chromium.chrome.browser.quick_search_engines.settings.QuickSearchEnginesFragment"
        android:key="quick_search_engine"
        android:order="3"
        android:title="@string/quick_search_engines_with_hyphen"/>
    <org.chromium.components.browser_ui.settings.ChromeSwitchPreference
        android:key="show_autocomplete_in_address_bar"
        android:title="@string/show_autocomplete_in_address_bar"
        android:summary="@string/show_autocomplete_in_address_bar_summary"
        android:order="4"
        android:persistent="false"/>
    <org.chromium.components.browser_ui.settings.ChromeSwitchPreference
        android:key="search_suggestions"
        android:title="@string/show_search_suggestions_title"
        android:summary="@string/improve_search_suggestions_summary"
        android:persistent="false"
        android:order="5"/>
    <org.chromium.components.browser_ui.settings.ChromeSwitchPreference
        android:key="autocomplete_top_sites"
        android:order="6"
        android:title="@string/autocomplete_top_suggestions_title"
        android:persistent="false"/>
    <org.chromium.components.browser_ui.settings.ChromeSwitchPreference
        android:key="brave.other_search_engines_enabled"
        android:order="7"
        android:title="@string/index_other_search_engines_title"
        android:summary="@string/index_other_search_engines_text" />
    <org.chromium.components.browser_ui.settings.ChromeSwitchPreference
        android:key="send_web_discovery"
        android:order="8"
        android:title="@string/send_web_discovery_title"
        android:summary="@string/send_web_discovery_summary"
        android:defaultValue="false" />
    <PreferenceCategory
        android:key="custom_search_engines"
        android:order="9"
        android:title="@string/custom_search_engines">
        <org.chromium.components.browser_ui.settings.ChromeBasePreference
            android:fragment="org.chromium.brave.browser.search_engines.settings.AddCustomSearchEnginePreferenceFragment"
            android:key="add_custom_search_engine"
            android:order="1"
            android:title="@string/add_custom_search_engine"/>
    </PreferenceCategory>
</PreferenceScreen>
