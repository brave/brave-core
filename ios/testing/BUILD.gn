import("//brave/build/ios/mojom/mojom_objc_cpp.gni")
import("//brave/build/ios/mojom/mojom_wrappers.gni")
import("//build/config/ios/rules.gni")
import("//ios/build/config.gni")
import("//mojo/public/tools/bindings/mojom.gni")
import("//testing/test.gni")

test("ios_brave_unit_tests") {
  deps = [
    # Ensure that all unit tests are run
    "//ios/chrome/test:run_all_unittests",
    "//ios/chrome/test:test_support",

    # use fake hooks and pack resources
    "//ios/chrome/app:tests_fake_hook",
    "//ios/chrome/app/resources:packed_resources",
    "//ios/chrome/app/resources:system_strings",
    "//ios/testing:http_server_bundle_data",

    # Providers
    "//ios/chrome/test/providers",
    "//ios/chrome/test/providers/signin:trusted_vault_provider",

    # Unit tests
    ":legacy_unit_tests",
    ":mojom_objc_generator_unit_tests",

    # This is required until we can sort out overridden deps symbols
    "//brave/ios/browser",
  ]

  assert_no_deps = ios_assert_no_deps
}

mojom("mojom") {
  sources = [ "some_service.mojom" ]

  cpp_typemaps = [
    {
      types = [
        {
          mojom = "mojom.SomeStruct"
          cpp = "::SomeStructCpp"
        },
      ]
      traits_headers = [ "//brave/ios/testing/some_struct_traits.h" ]
    },
  ]
}

mojom_objc_cpp("mojom_objc_cpp") {
  sources = [ "some_service.mojom" ]
  mojom_target = ":mojom"
}

ios_objc_mojom_wrappers("some_service_mojom_wrappers") {
  mojom_target = ":mojom"
  sources = [ "some_service.mojom" ]
  objc_cpp_target = ":mojom_objc_cpp"
}

source_set("mojom_objc_generator_unit_tests") {
  testonly = true

  sources = [ "mojom_objc_generator_unittest.mm" ]

  deps = [
    ":mojom_objc_cpp",
    ":some_service_mojom_wrappers",
    "//base",
    "//ios/web/public/test",
    "//mojo/public/cpp/bindings",
    "//testing/gtest",
  ]

  frameworks = [ "Foundation.framework" ]
}

source_set("legacy_unit_tests") {
  testonly = true

  sources = [
    "certificate_unittest.mm",
    "dictionary_transform_unittest.mm",
    "test_foo.h",
    "test_foo.mm",
    "vector_transform_unittest.mm",
  ]

  deps = [
    "//base",
    "//brave/ios/browser/api/net",
    "//net",
    "//net/http:generate_transport_security_state",
    "//testing/gtest",
  ]

  frameworks = [
    "Foundation.framework",
    "Security.framework",
  ]
}
