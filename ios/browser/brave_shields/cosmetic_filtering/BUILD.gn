import("//ios/web/public/js_messaging/optimize_ts.gni")

source_set("cosmetic_filtering") {
  sources = [
    "cosmetic_filtering_args.h",
    "cosmetic_filtering_args.mm",
    "cosmetic_filtering_javascript_feature.h",
    "cosmetic_filtering_javascript_feature.mm",
    "cosmetic_filtering_tab_helper.h",
    "cosmetic_filtering_tab_helper.mm",
    "cosmetic_filtering_tab_helper_bridge.h",
  ]
  deps = [
    ":cosmetic_filtering_js",
    "//base",
    "//brave/ios/browser/api/url",
    "//components/prefs",
    "//ios/chrome/browser/shared/model/profile",
    "//ios/web/public",
    "//ios/web/public/js_messaging",
    "//url",
  ]
  public_deps = [
    "//base",
    "//brave/ios/web/js_messaging:message_handler_token",
    "//brave/ios/web/js_messaging:randomized_message_handler_name",
    "//ios/web/public/js_messaging",
