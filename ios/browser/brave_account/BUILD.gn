import("//brave/build/ios/mojom/mojom_wrappers.gni")

ios_objc_mojom_wrappers("mojom") {
  mojom_target = "//brave/components/brave_account/mojom"
  sources = [ "//brave/components/brave_account/mojom/brave_account.mojom" ]
}

source_set("brave_account") {
  sources = [
    "brave_account_authentication_provider.h",
    "brave_account_authentication_provider.mm",
    "brave_account_constants_bridge.h",
    "brave_account_constants_bridge.mm",
    "brave_account_feature_bridge.h",
    "brave_account_feature_bridge.mm",
    "brave_account_service_factory_ios.h",
    "brave_account_service_factory_ios.mm",
  ]

  deps = [
    "//base",
    "//brave/components/brave_account",
    "//brave/components/brave_account:features",
    "//brave/components/brave_account/mojom",
    "//brave/ios/browser/api/profile",
    "//ios/chrome/browser/shared/model/application_context",
    "//brave/ios/browser/brave_account:mojom",
    "//ios/chrome/browser/shared/model/profile",
    "//ios/chrome/browser/shared/model/profile:profile_keyed_service_factory",
    "//ios/web/public",
    "//mojo/public/cpp/bindings",
    "//services/network/public/cpp",
  ]

  frameworks = [ "Foundation.framework" ]
}
