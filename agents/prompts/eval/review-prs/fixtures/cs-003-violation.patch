+#ifndef BRAVE_COMPONENTS_TOR_TOR_PREFS_H_
+#define BRAVE_COMPONENTS_TOR_TOR_PREFS_H_
+
+class PrefRegistrySimple;
+
+namespace tor {
+
+// Pref controlling whether Tor is turned off for this profile.
+inline constexpr char kTorDisabled[] = "brave.tor.disabled";
+
+void RegisterTorPrefs(PrefRegistrySimple* registry);
+
+// Returns true when the user or policy has turned Tor off.
+bool IsTorDisabled();
+
+// Sets the disabled state for Tor.
+void SetTorDisabled(bool disabled);
