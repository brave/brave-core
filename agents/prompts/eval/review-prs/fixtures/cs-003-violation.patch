+ * License, v. 2.0. If a copy of the MPL was not distributed with this file,
+ * You can obtain one at https://mozilla.org/MPL/2.0/. */
+
+#include "brave/components/tor/tor_prefs.h"
+
+#include "components/prefs/pref_registry_simple.h"
+#include "components/prefs/pref_service.h"
+
+namespace tor {
+
+void RegisterTorPrefs(PrefRegistrySimple* registry) {
+  registry->RegisterBooleanPref(kTorDisabled, false);
+}
+
+bool IsTorDisabled() {
+  return GetPrefService()->GetBoolean(kTorDisabled);
+}
+
+void SetTorDisabled(bool disabled) {
+  GetPrefService()->SetBoolean(kTorDisabled, disabled);
+}
+
+}  // namespace tor
