+// Copyright 2026 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_UI_BROWSER_WINDOW_TEST_FAKE_BROWSER_WINDOW_FEATURES_EVAL_H_
+#define CHROME_BROWSER_UI_BROWSER_WINDOW_TEST_FAKE_BROWSER_WINDOW_FEATURES_EVAL_H_
+
+#include <memory>
+
+#include "base/memory/raw_ptr.h"
+#include "chrome/browser/ui/browser_window/test/fake_browser_window_eval.h"
+#include "ui/base/unowned_user_data/scoped_unowned_user_data.h"
+#include "ui/base/unowned_user_data/unowned_user_data_host.h"
+#include "ui/base/unowned_user_data/user_data_factory.h"
+
+namespace fake_bwf_eval {
+
+class FakeBookmarkController;
+class FakeEmbedderFeatures;
+class FakeProfileMenuController;
+class FakeSendTabController;
+class FakeSidePanelRegistry;
+
+class FakeBrowserWindowInterface {
+ public:
+  enum class Type {
+    kNormal,
+    kPopup,
+  };
+
+  explicit FakeBrowserWindowInterface(Type type);
+  ~FakeBrowserWindowInterface();
+
+  bool is_type_normal() const;
+
+  ui::UnownedUserDataHost& GetUnownedUserDataHost() {
+    return unowned_user_data_host_;
+  }
+
+ private:
+  Type type_;
+  ui::UnownedUserDataHost unowned_user_data_host_;
+};
+
+// Feature controllers register themselves as unowned user data and are reached
+// through the static `From()` accessor. Construct them with
+// `GetUserDataFactory().CreateInstance<>()` rather than `std::make_unique<>()`.
+class FakeBookmarkController {
+ public:
+  DECLARE_USER_DATA(FakeBookmarkController);
+
+  explicit FakeBookmarkController(FakeBrowserWindowInterface* browser);
+  FakeBookmarkController(const FakeBookmarkController&) = delete;
+  FakeBookmarkController& operator=(const FakeBookmarkController&) = delete;
+  ~FakeBookmarkController();
+
+  static FakeBookmarkController* From(FakeBrowserWindowInterface* browser);
+
+ private:
+  ui::ScopedUnownedUserData<FakeBookmarkController> scoped_user_data_;
+};
+
+class FakeEmbedderFeatures {
+ public:
+  DECLARE_USER_DATA(FakeEmbedderFeatures);
+
+  explicit FakeEmbedderFeatures(FakeBrowserWindowInterface* browser);
+  FakeEmbedderFeatures(const FakeEmbedderFeatures&) = delete;
+  FakeEmbedderFeatures& operator=(const FakeEmbedderFeatures&) = delete;
+  ~FakeEmbedderFeatures();
+
+  static FakeEmbedderFeatures* From(FakeBrowserWindowInterface* browser);
+
+ private:
+  ui::ScopedUnownedUserData<FakeEmbedderFeatures> scoped_user_data_;
+};
+
+class FakeProfileMenuController {
+ public:
+  DECLARE_USER_DATA(FakeProfileMenuController);
+
+  explicit FakeProfileMenuController(FakeBrowserWindowInterface* browser);
+  FakeProfileMenuController(const FakeProfileMenuController&) = delete;
+  FakeProfileMenuController& operator=(const FakeProfileMenuController&) =
+      delete;
+  ~FakeProfileMenuController();
+
+  static FakeProfileMenuController* From(FakeBrowserWindowInterface* browser);
+
+ private:
+  ui::ScopedUnownedUserData<FakeProfileMenuController> scoped_user_data_;
+};
+
+class FakeSendTabController {
+ public:
+  DECLARE_USER_DATA(FakeSendTabController);
+
+  explicit FakeSendTabController(FakeBrowserWindowInterface* browser);
+  FakeSendTabController(const FakeSendTabController&) = delete;
+  FakeSendTabController& operator=(const FakeSendTabController&) = delete;
+  ~FakeSendTabController();
+
+  static FakeSendTabController* From(FakeBrowserWindowInterface* browser);
+
+ private:
+  ui::ScopedUnownedUserData<FakeSendTabController> scoped_user_data_;
+};
+
+class FakeSidePanelRegistry {
+ public:
+  DECLARE_USER_DATA(FakeSidePanelRegistry);
+
+  explicit FakeSidePanelRegistry(FakeBrowserWindowInterface* browser);
+  FakeSidePanelRegistry(const FakeSidePanelRegistry&) = delete;
+  FakeSidePanelRegistry& operator=(const FakeSidePanelRegistry&) = delete;
+  ~FakeSidePanelRegistry();
+
+  static FakeSidePanelRegistry* From(FakeBrowserWindowInterface* browser);
+
+ private:
+  ui::ScopedUnownedUserData<FakeSidePanelRegistry> scoped_user_data_;
+};
+
+// Do not add public accessors for feature controllers. Reach them through the
+// UnownedUserData access pattern (`FooController::From(browser)`) instead of
+// adding a getter here.
+class FakeBrowserWindowFeatures {
+ public:
+  FakeBrowserWindowFeatures();
+  ~FakeBrowserWindowFeatures();
+
+  FakeBrowserWindowFeatures(const FakeBrowserWindowFeatures&) = delete;
+  FakeBrowserWindowFeatures& operator=(const FakeBrowserWindowFeatures&) =
+      delete;
+
+  void Init(FakeBrowserWindowInterface* browser);
+  void InitPostWindowConstruction(FakeBrowserWindowInterface* browser,
+                                  FakeBrowserWindow* window);
+  // Deprecated and intentionally empty: retained only to mirror the real
+  // BrowserWindowFeatures lifecycle. Do not add new feature initialization
+  // here; prefer InitPostWindowConstruction().
+  void InitPostBrowserViewConstruction();
+
+ private:
+  static ui::UserDataFactoryWithOwner<FakeBrowserWindowInterface>&
+  GetUserDataFactory();
+
+  // Members owned by all browser window types.
+  std::unique_ptr<FakeBookmarkController> fake_bookmark_controller_;
+  std::unique_ptr<FakeProfileMenuController> fake_profile_menu_controller_;
+  std::unique_ptr<FakeSidePanelRegistry> fake_side_panel_registry_;
+
+  // Members owned only when the browser is TYPE_NORMAL.
+  std::unique_ptr<FakeSendTabController> fake_send_tab_controller_;
+
+  // Non-owning references.
+  raw_ptr<FakeBrowserWindowInterface> browser_ = nullptr;
+
+  // Embedder features. Must be declared last.
+  std::unique_ptr<FakeEmbedderFeatures> fake_embedder_features_;
+};
+
+}  // namespace fake_bwf_eval
+
+#endif  // CHROME_BROWSER_UI_BROWSER_WINDOW_TEST_FAKE_BROWSER_WINDOW_FEATURES_EVAL_H_
