+// Copyright 2026 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/ui/browser_window/test/fake_browser_window_features_eval.h"
+
+#include "base/no_destructor.h"
+
+namespace fake_bwf_eval {
+
+FakeBrowserWindowInterface::FakeBrowserWindowInterface(Type type)
+    : type_(type) {}
+FakeBrowserWindowInterface::~FakeBrowserWindowInterface() = default;
+
+bool FakeBrowserWindowInterface::is_type_normal() const {
+  return type_ == Type::kNormal;
+}
+
+DEFINE_USER_DATA(FakeBookmarkController);
+FakeBookmarkController::FakeBookmarkController(
+    FakeBrowserWindowInterface* browser)
+    : scoped_user_data_(browser->GetUnownedUserDataHost(), *this) {}
+FakeBookmarkController::~FakeBookmarkController() = default;
+// static
+FakeBookmarkController* FakeBookmarkController::From(
+    FakeBrowserWindowInterface* browser) {
+  return browser ? Get(browser->GetUnownedUserDataHost()) : nullptr;
+}
+
+DEFINE_USER_DATA(FakeEmbedderFeatures);
+FakeEmbedderFeatures::FakeEmbedderFeatures(FakeBrowserWindowInterface* browser)
+    : scoped_user_data_(browser->GetUnownedUserDataHost(), *this) {}
+FakeEmbedderFeatures::~FakeEmbedderFeatures() = default;
+// static
+FakeEmbedderFeatures* FakeEmbedderFeatures::From(
+    FakeBrowserWindowInterface* browser) {
+  return browser ? Get(browser->GetUnownedUserDataHost()) : nullptr;
+}
+
+DEFINE_USER_DATA(FakeProfileMenuController);
+FakeProfileMenuController::FakeProfileMenuController(
+    FakeBrowserWindowInterface* browser)
+    : scoped_user_data_(browser->GetUnownedUserDataHost(), *this) {}
+FakeProfileMenuController::~FakeProfileMenuController() = default;
+// static
+FakeProfileMenuController* FakeProfileMenuController::From(
+    FakeBrowserWindowInterface* browser) {
+  return browser ? Get(browser->GetUnownedUserDataHost()) : nullptr;
+}
+
+DEFINE_USER_DATA(FakeSendTabController);
+FakeSendTabController::FakeSendTabController(
+    FakeBrowserWindowInterface* browser)
+    : scoped_user_data_(browser->GetUnownedUserDataHost(), *this) {}
+FakeSendTabController::~FakeSendTabController() = default;
+// static
+FakeSendTabController* FakeSendTabController::From(
+    FakeBrowserWindowInterface* browser) {
+  return browser ? Get(browser->GetUnownedUserDataHost()) : nullptr;
+}
+
+DEFINE_USER_DATA(FakeSidePanelRegistry);
+FakeSidePanelRegistry::FakeSidePanelRegistry(
+    FakeBrowserWindowInterface* browser)
+    : scoped_user_data_(browser->GetUnownedUserDataHost(), *this) {}
+FakeSidePanelRegistry::~FakeSidePanelRegistry() = default;
+// static
+FakeSidePanelRegistry* FakeSidePanelRegistry::From(
+    FakeBrowserWindowInterface* browser) {
+  return browser ? Get(browser->GetUnownedUserDataHost()) : nullptr;
+}
+
+FakeBrowserWindowFeatures::FakeBrowserWindowFeatures() = default;
+FakeBrowserWindowFeatures::~FakeBrowserWindowFeatures() = default;
+
+void FakeBrowserWindowFeatures::Init(FakeBrowserWindowInterface* browser) {
+  browser_ = browser;
+
+  // Members owned by all browser window types.
+  fake_bookmark_controller_ =
+      GetUserDataFactory().CreateInstance<FakeBookmarkController>(*browser,
+                                                                  browser);
+  fake_side_panel_registry_ =
+      GetUserDataFactory().CreateInstance<FakeSidePanelRegistry>(*browser,
+                                                                 browser);
+
+  // Embedder features are initialized last.
+  fake_embedder_features_ =
+      GetUserDataFactory().CreateInstance<FakeEmbedderFeatures>(*browser,
+                                                                browser);
+}
+
+void FakeBrowserWindowFeatures::InitPostWindowConstruction(
+    FakeBrowserWindowInterface* browser,
+    FakeBrowserWindow* window) {
+  // Members owned by all browser window types.
+  fake_profile_menu_controller_ =
+      GetUserDataFactory().CreateInstance<FakeProfileMenuController>(*browser,
+                                                                     browser);
+
+  // Members owned only when the browser is TYPE_NORMAL.
+  if (browser->is_type_normal()) {
+    fake_send_tab_controller_ =
+        GetUserDataFactory().CreateInstance<FakeSendTabController>(*browser,
+                                                                   browser);
+    window->ShowQRCodeBubble();
+  }
+}
+
+void FakeBrowserWindowFeatures::InitPostBrowserViewConstruction() {}
+
+// static
+ui::UserDataFactoryWithOwner<FakeBrowserWindowInterface>&
+FakeBrowserWindowFeatures::GetUserDataFactory() {
+  static base::NoDestructor<
+      ui::UserDataFactoryWithOwner<FakeBrowserWindowInterface>>
+      factory;
+  return *factory;
+}
+
+}  // namespace fake_bwf_eval
