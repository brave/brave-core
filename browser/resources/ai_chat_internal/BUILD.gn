import("//brave/components/ai_chat/core/common/buildflags/buildflags.gni")
import("//ui/webui/resources/tools/build_webui.gni")

assert(enable_ai_chat)

build_webui("ai_chat_internal") {
  grd_prefix = "ai_chat_internal"
  static_files = [ "index.html" ]
  ts_files = [ "app.ts" ]
  ts_deps = [
    "//brave/ui/webui/resources:build_ts",
    "//ui/webui/resources/mojo:build_ts",
    "//ui/webui/resources/js:build_ts",
  ]
  webui_context_type = "trusted"
  grit_output_dir = "$root_gen_dir/brave"
  mojo_files_deps = [
    "//brave/components/ai_chat/core/common/mojom:mojom_ts__generator",
  ]
  mojo_files = [
    "$root_gen_dir/brave/components/ai_chat/core/common/mojom/ai_chat_internal.mojom-webui.ts",
    "$root_gen_dir/brave/components/ai_chat/core/common/mojom/ai_chat.mojom-webui.ts",
    "$root_gen_dir/brave/components/ai_chat/core/common/mojom/bookmarks.mojom-webui.ts",
    "$root_gen_dir/brave/components/ai_chat/core/common/mojom/common.mojom-webui.ts",
    "$root_gen_dir/brave/components/ai_chat/core/common/mojom/customization_settings.mojom-webui.ts",
    "$root_gen_dir/brave/components/ai_chat/core/common/mojom/history.mojom-webui.ts",
    "$root_gen_dir/brave/components/ai_chat/core/common/mojom/ollama.mojom-webui.ts",
    "$root_gen_dir/brave/components/ai_chat/core/common/mojom/page_content_extractor.mojom-webui.ts",
    "$root_gen_dir/brave/components/ai_chat/core/common/mojom/settings_helper.mojom-webui.ts",
    "$root_gen_dir/brave/components/ai_chat/core/common/mojom/tab_tracker.mojom-webui.ts",
    "$root_gen_dir/brave/components/ai_chat/core/common/mojom/untrusted_frame.mojom-webui.ts",
  ]
  use_brave_grit = true
}
