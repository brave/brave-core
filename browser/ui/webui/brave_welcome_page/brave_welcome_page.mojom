module brave_welcome_page.mojom;

// The browser color scheme selected by the user.
enum ColorScheme {
  kSystem,
  kLight,
  kDark,
};

// WebUI-side handler for notifications from the browser.
interface WelcomePage {
  // Called when the current browser color scheme has changed.
  OnColorSchemeChanged();

  // Called when the vertical tabs enabled state has changed.
  OnVerticalTabsEnabledChanged();
};

// Browser-side handler for requests from the welcome page WebUI.
interface WelcomePageHandler {
  // Sets the WelcomePage remote interface that will receive notifications from
  // the browser.
  SetWelcomePage(pending_remote<WelcomePage> page);

  // Gets or sets the current browser color scheme.
  GetColorScheme() => (ColorScheme color_scheme);
  SetColorScheme(ColorScheme color_scheme) => ();

  // Gets or sets whether vertical tabs are enabled.
  GetVerticalTabsEnabled() => (bool enabled);
  SetVerticalTabsEnabled(bool enabled) => ();
};
