module brave_history_embeddings.mojom;

// chrome://history â†’ browser. Lets the side bar toggle write the
// Semantic History Search pref and listen for changes.
interface PageHandlerFactory {
  // Binds a `Page` for browserâ†’renderer notifications and binds a
  // `PageHandler` for rendererâ†’browser calls.
  //
  // Named distinctly from upstream's `CreatePageHandler` because
  // `BraveHistoryUI` derives from both this factory and upstream's
  // `history_embeddings::mojom::PageHandlerFactory`, causing a naming conflict.
  CreateInterfacePageHandler(pending_remote<Page> page,
                         pending_receiver<PageHandler> handler);
};

interface PageHandler {
  // Writes the new value of the brave.history_embeddings_enabled pref.
  SetEnabled(bool enabled);
};

// Notifications from the browser back to all chrome://history pages so any
// UI consuming the enabled state can react without a page reload.
interface Page {
  OnEnabledChanged(bool enabled);
};
