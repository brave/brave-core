import("//brave/components/brave_ads/buildflags/buildflags.gni")
import("//brave/components/brave_rewards/core/buildflags/buildflags.gni")
import("//brave/components/brave_wallet/common/buildflags/buildflags.gni")

assert(enable_brave_wallet)
assert(!is_android)

source_set("wallet_panel") {
  sources = [
    "wallet_panel_handler.cc",
    "wallet_panel_handler.h",
    "wallet_panel_ui.cc",
    "wallet_panel_ui.h",
  ]
  deps = [
    "//brave/browser/brave_wallet",
    "//brave/browser/brave_wallet:tab_helper",
    "//brave/components/brave_ads/buildflags",
    "//brave/components/brave_rewards/core/buildflags",
    "//brave/components/brave_wallet/browser",
    "//brave/components/brave_wallet/browser:constants",
    "//brave/components/brave_wallet/browser:permission_utils",
    "//brave/components/brave_wallet/browser:utils",
    "//brave/components/brave_wallet/browser:wallet_handler",
    "//brave/components/brave_wallet/common",
    "//brave/components/brave_wallet/common:mojom",
    "//brave/components/brave_wallet/common/buildflags",
    "//brave/components/brave_wallet_ui:resources",
    "//brave/components/brave_wallet_ui/panel:brave_wallet_panel_generated",
    "//brave/components/constants",
    "//brave/components/resources:static_resources_grit",
    "//brave/components/resources:strings_grit",
    "//chrome/browser/ui/browser_window",
    "//chrome/browser/ui/tabs:tab_strip",
    "//chrome/browser/ui/webui",
    "//chrome/browser/ui/webui:webui_util",
    "//chrome/browser/ui/webui/sanitized_image:sanitized_image_source",
    "//chrome/browser/ui/webui/top_chrome",
    "//components/favicon_base",
    "//components/permissions",
    "//content/public/browser",
    "//ui/webui",
  ]

  if (enable_brave_rewards) {
    deps += [
      "//brave/browser/brave_rewards",
      "//brave/browser/brave_rewards:util",
      "//brave/components/brave_rewards/core/mojom:webui",
    ]
  }

  if (enable_brave_ads) {
    deps += [ "//brave/browser/brave_ads" ]
  }
}

source_set("browser_tests") {
  testonly = true
  defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]

  sources = [ "wallet_panel_ui_browsertest.cc" ]
  deps = [
    ":wallet_panel",
    "//base/test:test_support",
    "//brave/browser/brave_wallet",
    "//brave/components/brave_wallet/browser",
    "//brave/components/brave_wallet/browser:utils",
    "//chrome/browser:browser_process",
    "//chrome/test:test_support",
    "//chrome/test:test_support_ui",
    "//content/test:test_support",
    "//testing/gtest",
  ]
}
