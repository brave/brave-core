import("//brave/components/brave_ads/buildflags/buildflags.gni")

static_library("handlers") {
  sources = [
    "brave_adblock_policy_handler.cc",
    "brave_adblock_policy_handler.h",
    "brave_fingerprinting_v2_policy_handler.cc",
    "brave_fingerprinting_v2_policy_handler.h",
    "brave_https_upgrade_policy_handler.cc",
    "brave_https_upgrade_policy_handler.h",
    "brave_referrers_policy_handler.cc",
    "brave_referrers_policy_handler.h",
    "brave_remember_1p_storage_policy_handler.cc",
    "brave_remember_1p_storage_policy_handler.h",
  ]

  deps = [
    "//base",
    "//brave/components/constants",
    "//components/content_settings/core/common",
    "//components/policy/core/browser",
    "//components/policy/core/common:common_constants",
    "//components/prefs",
  ]

  if (enable_brave_ads) {
    sources += [
      "brave_ads_enabled_policy_handler.cc",
      "brave_ads_enabled_policy_handler.h",
    ]
    deps += [
      "//brave/components/brave_ads/core/public:headers",
      "//brave/components/ntp_background_images/common",
    ]
  }
}

source_set("unit_tests") {
  testonly = true
  sources = [
    "brave_adblock_policy_handler_unittest.cc",
    "brave_fingerprinting_v2_policy_handler_unittest.cc",
    "brave_https_upgrade_policy_handler_unittest.cc",
    "brave_referrers_policy_handler_unittest.cc",
    "brave_remember_1p_storage_policy_handler_unittest.cc",
  ]

  deps = [
    ":handlers",
    "//base",
    "//brave/components/constants",
    "//components/content_settings/core/common",
    "//components/policy/core/browser",
    "//components/policy/core/common",
    "//components/prefs",
    "//testing/gmock",
    "//testing/gtest",
  ]

  if (enable_brave_ads) {
    sources += [ "brave_ads_enabled_policy_handler_unittest.cc" ]
    deps += [
      "//brave/components/brave_ads/core/public:headers",
      "//brave/components/ntp_background_images/common",
    ]
  }
}
