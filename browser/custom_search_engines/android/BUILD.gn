    ":java_resources",
    "//base:base_java",
    "//base:supplier_java",
    "//base:tasks_java",
    "//chrome/browser/preferences:java",
    "//chrome/browser/profiles/android:java",
    "//chrome/browser/search_engines/android:java",
    "//chrome/browser/settings:java",
