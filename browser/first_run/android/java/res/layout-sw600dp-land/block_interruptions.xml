<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginVertical="82dp"
    android:layout_marginHorizontal="96dp"
    android:elevation="4dp"
    android:background="@drawable/onboarding_card_background">

    <ImageView
        android:id="@+id/brave_brand"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_brave_brand"
        android:contentDescription="@null"
        android:paddingHorizontal="40dp"
        android:paddingTop="50dp"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/image_start_guide"
        app:layout_constraintBottom_toTopOf="@+id/brave_onboarding_title" />

    <TextView
        android:id="@+id/brave_onboarding_title"
        style="@style/HeadingH3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/block_interruptions"
        android:textColor="@color/text_primary"
        android:gravity="start|center_horizontal"
        android:paddingHorizontal="40dp"
        android:layout_marginTop="50dp"
        app:layout_constraintTop_toBottomOf="@+id/brave_brand"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/image_start_guide"
        app:layout_constraintBottom_toTopOf="@+id/brave_onboarding_subtitle"/>

    <TextView
        android:id="@+id/brave_onboarding_subtitle"
        style="@style/LargeRegular"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/block_interruptions_subtitle"
        android:textColor="@color/text_secondary"
        android:gravity="start|center_horizontal"
        android:paddingHorizontal="40dp"
        android:layout_marginTop="@dimen/onboarding_subtitle_margin_top"
        app:layout_constraintTop_toBottomOf="@+id/brave_onboarding_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/image_start_guide" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/image_start_guide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/onboarding_illustration"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:contentDescription="@string/brave_onboarding_block_interruptions_illustration_description"
        android:padding="@dimen/onboarding_illustration_padding"
        android:background="@color/schemes_surface_container"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@+id/image_start_guide"
        app:layout_constraintEnd_toEndOf="parent"
        app:lottie_rawRes="@raw/no_video_ads"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/onboarding_continue"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_margin="40dp"
        android:text="@string/continue_text"
        style="@style/LargeFilledButton"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/image_start_guide" />
</androidx.constraintlayout.widget.ConstraintLayout>
