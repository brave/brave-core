if (!is_android) {
  source_set("browser_tests") {
    testonly = true
    defines = [ "HAS_OUT_OF_PROC_TEST_RUNNER" ]

    sources = [ "brave_page_content_extraction_tab_helper_browsertest.cc" ]

    deps = [
      ":history_embeddings",
      "//base/test:test_support",
      "//brave/browser/ui/tabs:tabs_public",
      "//chrome/browser/page_content_annotations",
      "//chrome/browser/profiles",
      "//chrome/test:test_support",
      "//components/history_embeddings/core",
      "//components/page_content_annotations/content",
      "//content/public/browser",
      "//content/test:test_support",
      "//net:test_support",
      "//testing/gtest",
    ]
  }

  source_set("unit_tests") {
    testonly = true

    sources = [ "brave_page_content_extraction_tab_helper_unittest.cc" ]

    deps = [
      ":history_embeddings",
      "//base/test:test_support",
      "//chrome/browser",
      "//chrome/test:test_support",
      "//components/optimization_guide/proto:optimization_guide_proto",
      "//components/os_crypt/async/browser",
      "//components/page_content_annotations/content",
      "//components/tabs:test_support",
      "//content/test:test_support",
      "//testing/gtest",
    ]
  }
}

source_set("history_embeddings") {
  if (!is_android) {
    sources = [
      "brave_page_content_extraction_service.h",
      "brave_page_content_extraction_tab_helper.cc",
      "brave_page_content_extraction_tab_helper.h",
    ]

    public_deps = [ "//chrome/browser/ui/tabs" ]

    deps = [
      "//components/history_embeddings/core",
      "//components/optimization_guide/content/browser",
      "//components/optimization_guide/proto:optimization_guide_proto",
      "//components/page_content_annotations/content",
      "//components/page_content_annotations/core",
      "//content/public/browser",
      "//services/service_manager/public/cpp",
      "//ui/base",
    ]
  }

  public_deps += [
    "//base",
    "//chrome/browser/profiles",
    "//mojo/public/cpp/bindings",
  ]
}
